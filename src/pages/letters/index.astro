---
import Base from '../../layouts/Base.astro';

const allLetters = await Astro.glob('../../content/letters/*.md');
const letters = allLetters
  .filter(l => !l.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));

const featured = letters.filter(l => l.frontmatter.featured || l.frontmatter.startHere).slice(0, 2);
const archive  = letters.filter(l => !l.frontmatter.featured && !l.frontmatter.startHere);

const phFeatured = [
  {
    title: 'The system nobody builds',
    preview: 'Most of us spend years building careers, families, and homes. Very few of us ever stop to build the structure underneath our daily lives — the thing that quietly shapes how everything feels.',
    time: '4 min read'
  },
  {
    title: 'The invisible load',
    preview: 'You wake up tired. You move through the day feeling slightly behind. By evening you wonder why you\'re so exhausted when you didn\'t really do that much. The answer is usually invisible.',
    time: '4 min read'
  },
];
const phArchive = [
  { title: 'One clear move at a time',         preview: 'A different philosophy on what a good day actually requires of you.', time: '3 min read' },
  { title: 'Why productivity stopped working', preview: 'The framework was never the problem. The weight was.',                 time: '4 min read' },
];
---
<Base
  title="Letters"
  description="A Sunday letter for women who want to feel more like themselves again."
  currentPath="/letters"
>
<style>
  main { flex: 1; }

  .letters-hero-section {
    padding: 5rem 3rem 4rem;
    position: relative; z-index: 1;
  }
  .letters-hero-inner {
    max-width: 960px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 360px;
    gap: 5rem; align-items: start;
  }

  .find-block { margin-top: 1.8rem; }
  .find-label { font-size: .6rem; letter-spacing: .18em; text-transform: uppercase; color: var(--ink3); font-weight: 500; margin-bottom: .7rem; }
  .find-items { display: flex; flex-direction: column; gap: .35rem; }
  .find-item { display: flex; align-items: center; gap: .65rem; font-size: .88rem; color: var(--ink2); line-height: 1.5; }
  .find-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--sage); flex-shrink: 0; }

  .signup-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 2rem 2.2rem;
    box-shadow: 0 4px 24px rgba(26,29,46,.04);
  }
  .signup-eyebrow { font-size: .6rem; letter-spacing: .18em; text-transform: uppercase; color: var(--terra); font-weight: 500; margin-bottom: .4rem; }
  .signup-hed { font-family: var(--display); font-size: 1.2rem; font-weight: 300; color: var(--ink); margin-bottom: .5rem; line-height: 1.2; }
  .signup-hed em { font-style: italic; color: var(--sage); }
  .signup-desc { font-size: .82rem; color: var(--ink2); line-height: 1.7; margin-bottom: 1.2rem; }

  .archive-section {
    padding: 0 3rem 6rem;
    border-top: 1px solid var(--border);
    position: relative; z-index: 1;
  }
  .archive-inner { max-width: 760px; margin: 0 auto; padding-top: 3rem; }

  .section-label { font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--ink3); font-weight: 500; margin-bottom: 1rem; }
  .archive-intro { font-size: .78rem; color: var(--ink3); font-style: italic; font-family: var(--display); margin-bottom: .9rem; }

  .featured-list { display: flex; flex-direction: column; gap: .7rem; margin-bottom: 3rem; }
  .feat-card {
    display: block; padding: 1.6rem 1.8rem;
    background: var(--surface); border: 1px solid rgba(91,140,122,.22);
    border-radius: 12px; text-decoration: none;
    transition: box-shadow .15s, transform .12s;
  }
  .feat-card:not(.placeholder):hover { box-shadow: 0 4px 20px rgba(26,29,46,.06); transform: translateY(-1px); }
  .feat-card.placeholder { opacity: .55; pointer-events: none; border-style: dashed; }
  .feat-title { font-family: var(--display); font-size: 1rem; font-weight: 400; color: var(--ink); line-height: 1.3; margin-bottom: .4rem; }
  .feat-preview { font-size: .82rem; color: var(--ink2); line-height: 1.7; margin-bottom: .5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .feat-time { font-size: .68rem; color: var(--sage); font-family: var(--display); font-style: italic; }

  .archive-list { display: flex; flex-direction: column; gap: .5rem; }
  .arc-item {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    padding: .95rem 1.3rem; background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; text-decoration: none;
    transition: box-shadow .15s, transform .12s;
  }
  .arc-item:not(.placeholder):hover { box-shadow: 0 2px 12px rgba(26,29,46,.05); transform: translateY(-1px); }
  .arc-item.placeholder { opacity: .55; pointer-events: none; border-style: dashed; }
  .arc-left { flex: 1; min-width: 0; }
  .arc-title { font-family: var(--display); font-size: .9rem; font-weight: 400; color: var(--ink); line-height: 1.3; margin-bottom: .2rem; }
  .arc-preview { font-size: .75rem; color: var(--ink3); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .arc-right { flex-shrink: 0; text-align: right; }
  .arc-date { font-size: .68rem; color: var(--ink3); font-family: var(--display); font-style: italic; white-space: nowrap; }
  .arc-time { font-size: .65rem; color: var(--ink3); }
  .empty-note { text-align: center; padding: 1.5rem 0; font-family: var(--display); font-size: .85rem; font-style: italic; color: var(--ink3); line-height: 1.8; }

  @media (max-width: 860px) {
    .letters-hero-section { padding: 3rem 1.5rem 2.5rem; }
    .letters-hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .archive-section { padding: 0 1.5rem 4rem; }
  }
</style>

<main>

  <div class="letters-hero-section">
    <div class="letters-hero-inner">

      <div>
        <div class="eyebrow">The Velani Letter</div>
        <h1 class="page-title">A Sunday letter<br>for <em>women carrying too much.</em></h1>
        <p class="page-subtitle">
          Not a newsletter about productivity. A quiet weekly letter about making room for yourself again — in your days, your mind, and your life.
        </p>

        <div class="find-block">
          <div class="find-label">What you'll find here</div>
          <div class="find-items">
            <div class="find-item"><span class="find-dot"></span>Permission to carry less</div>
            <div class="find-item"><span class="find-dot"></span>Small practices that actually help</div>
            <div class="find-item"><span class="find-dot"></span>Warm, honest reflections on ordinary life</div>
          </div>
        </div>
      </div>

      <div class="signup-card">
        <div class="signup-eyebrow">Receive the letter</div>
        <h2 class="signup-hed">A quieter <em>Sunday.</em></h2>
        <p class="signup-desc">
          Weekly letters for women who want to feel more like themselves again.
          Warm, practical, and calm — arriving every Sunday morning.
        </p>
        <div id="letters-form">
          <div class="inline-form">
            <input type="email" id="let-email" class="inline-email" placeholder="your@email.com" autocomplete="email">
            <button class="inline-btn" onclick="window.lettersSignup()">Join Velani</button>
          </div>
          <p class="inline-consent">
            By joining, you agree to receive occasional Velani emails.
            <a href="/privacy" target="_blank">Privacy policy</a>.
          </p>
        </div>
        <div class="inline-success" id="let-success">✓ Check your inbox to confirm.</div>
      </div>

    </div>
  </div>

  <div class="archive-section">
    <div class="archive-inner">

      <div class="section-label">Start here</div>
      <div class="featured-list">
        {featured.length > 0
          ? featured.map(l => (
              <a href={l.url} class="feat-card">
                <div class="feat-title">{l.frontmatter.title}</div>
                {l.frontmatter.preview && <div class="feat-preview">{l.frontmatter.preview}</div>}
                <div class="feat-time">{l.frontmatter.readTime || '3 min read'}</div>
              </a>
            ))
          : phFeatured.map(p => (
              <div class="feat-card placeholder">
                <div class="feat-title">{p.title}</div>
                <div class="feat-preview">{p.preview}</div>
                <div class="feat-time">{p.time}</div>
              </div>
            ))
        }
      </div>

      {(archive.length > 0 || phArchive.length > 0) && (
        <div>
          <div class="v-divider"></div>
          <div class="section-label">Archive</div>
          <p class="archive-intro">Read before subscribing.</p>
          <div class="archive-list">
            {archive.length > 0
              ? archive.map(l => (
                  <a href={l.url} class="arc-item">
                    <div class="arc-left">
                      <div class="arc-title">{l.frontmatter.title}</div>
                      {l.frontmatter.preview && <div class="arc-preview">{l.frontmatter.preview}</div>}
                    </div>
                    <div class="arc-right">
                      <div class="arc-date">{new Date(l.frontmatter.date).toLocaleDateString('en-CA', { year:'numeric', month:'short', day:'numeric' })}</div>
                      <div class="arc-time">{l.frontmatter.readTime || '3 min'}</div>
                    </div>
                  </a>
                ))
              : phArchive.map(p => (
                  <div class="arc-item placeholder">
                    <div class="arc-left">
                      <div class="arc-title">{p.title}</div>
                      <div class="arc-preview">{p.preview}</div>
                    </div>
                    <div class="arc-right"><div class="arc-time">{p.time}</div></div>
                  </div>
                ))
            }
          </div>
          {letters.length === 0 && <div class="empty-note">First letter coming soon.<br>Sign up and you'll receive it Sunday.</div>}
        </div>
      )}

    </div>
  </div>

</main>

<script>
  window.lettersSignup = function() {
    const email = document.getElementById('let-email').value.trim();
    if (!email || !email.includes('@')) { document.getElementById('let-email').style.borderColor = '#B86A43'; return; }
    document.getElementById('let-email').style.borderColor = 'rgba(26,29,46,.14)';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email })
    }).then(() => ok()).catch(() => ok());
    function ok() {
      document.getElementById('letters-form').style.display = 'none';
      document.getElementById('let-success').classList.add('visible');
    }
  };
</script>

</Base>
