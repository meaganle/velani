---
import Base from '../../layouts/Base.astro';

const allLetters = await Astro.glob('../../content/letters/*.md');
const letters = allLetters
  .filter(l => !l.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));

const featured = letters.filter(l => l.frontmatter.featured || l.frontmatter.startHere).slice(0, 2);
const archive  = letters.filter(l => !l.frontmatter.featured && !l.frontmatter.startHere);

const phFeatured = [
  {
    title: 'The system nobody builds',
    preview: 'Most of us spend years building careers, families, and homes. Very few of us ever stop to build the structure underneath our daily lives — the thing that quietly shapes how everything feels.',
    time: '4 min read'
  },
  {
    title: 'The invisible load',
    preview: 'You wake up tired. You move through the day feeling slightly behind. By evening you wonder why you\'re so exhausted when you didn\'t really do that much. The answer is usually invisible.',
    time: '4 min read'
  },
];
const phArchive = [
  { title: 'One clear move at a time',         preview: 'A different philosophy on what a good day actually requires of you.', time: '3 min read' },
  { title: 'Why productivity stopped working', preview: 'The framework was never the problem. The weight was.',                 time: '4 min read' },
];
---
<Base
  title="The Velani Letter"
  description="A Sunday letter for women who want to feel more like themselves again."
  currentPath="/letters"
>
<style>
  main { flex: 1; }

  /* ── Hero ── */
  .letters-hero {
    padding: 5rem 3rem 4.5rem;
    position: relative; z-index: 1;
  }
  .letters-hero-inner {
    max-width: 980px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 360px;
    gap: 5rem; align-items: stretch;
  }

  /* Left column */
  .hero-eyebrow {
    font-size: .6rem; letter-spacing: .22em;
    text-transform: uppercase; color: var(--terra);
    font-weight: 600; margin-bottom: 1.4rem;
    display: flex; align-items: center; gap: .75rem;
  }
  .hero-eyebrow::before {
    content: ''; display: block;
    width: 24px; height: 1.5px; background: var(--terra);
    opacity: .6; flex-shrink: 0;
  }
  .hero-title {
    font-family: var(--display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 300; line-height: 1.1;
    letter-spacing: -.02em; color: var(--ink);
    margin-bottom: 1.2rem;
  }
  .hero-title em { font-style: italic; color: var(--sage); }
  .hero-desc {
    font-size: .95rem; color: var(--ink2);
    line-height: 1.85; margin-bottom: 2rem;
    max-width: 460px;
  }

  .find-block { margin-top: .5rem; }
  .find-label {
    font-size: .58rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--ink3);
    font-weight: 600; margin-bottom: .9rem;
  }
  .find-items { display: flex; flex-direction: column; gap: .5rem; }
  .find-item {
    display: flex; align-items: flex-start; gap: .75rem;
    font-size: .88rem; color: var(--ink2); line-height: 1.55;
  }
  .find-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0; margin-top: .45em;
  }

  /* Right column: signup card */
  .signup-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 2.2rem 2.4rem;
    box-shadow: 0 4px 32px rgba(26,29,46,.06);
    display: flex; flex-direction: column; justify-content: center;
  }
  .signup-eyebrow {
    font-size: .58rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--terra);
    font-weight: 600; margin-bottom: .6rem;
  }
  .signup-hed {
    font-family: var(--display); font-size: 1.35rem;
    font-weight: 300; color: var(--ink);
    margin-bottom: .6rem; line-height: 1.2;
  }
  .signup-hed em { font-style: italic; color: var(--sage); }
  .signup-desc {
    font-size: .83rem; color: var(--ink2);
    line-height: 1.75; margin-bottom: 1.4rem;
  }

  /* Signup card form — stacked layout so email isn't squeezed */
  .signup-card .inline-form { flex-direction: column; gap: .5rem; }
  .signup-card .inline-btn {
    width: 100%; padding: .85rem;
    text-align: center; display: block;
  }

  /* Trust badges */
  .signup-trust {
    display: flex; flex-wrap: wrap; align-items: center; gap: .35rem .5rem;
    margin-top: 1rem;
  }
  .trust-badge {
    font-size: .72rem; color: var(--ink3);
    display: flex; align-items: center; gap: .35rem;
  }
  .trust-badge::before {
    content: ''; display: block;
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--sage); opacity: .6; flex-shrink: 0;
  }
  .trust-sep { color: var(--border2); font-size: .65rem; }

  /* Archive section */
  .archive-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 4rem 3rem 6rem;
    position: relative; z-index: 1;
  }
  .archive-inner { max-width: 760px; margin: 0 auto; }

  .section-label {
    font-size: .58rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--ink3);
    font-weight: 600; margin-bottom: 1.2rem;
  }
  .archive-intro {
    font-size: .82rem; color: var(--ink3);
    font-style: italic; font-family: var(--display);
    margin-bottom: 1.2rem; margin-top: -.4rem;
  }

  /* Featured cards */
  .featured-list { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 3rem; }
  .feat-card {
    display: block; padding: 1.8rem 2rem;
    background: var(--bg); border: 1px solid rgba(91,140,122,.18);
    border-radius: 14px; text-decoration: none;
    transition: box-shadow .18s, transform .14s, border-color .18s;
  }
  .feat-card:not(.placeholder):hover {
    box-shadow: 0 6px 28px rgba(26,29,46,.07);
    transform: translateY(-2px);
    border-color: rgba(91,140,122,.35);
  }
  .feat-card.placeholder { opacity: .5; pointer-events: none; border-style: dashed; }
  .feat-eyebrow {
    font-size: .57rem; letter-spacing: .18em; text-transform: uppercase;
    color: var(--sage); font-weight: 600; margin-bottom: .55rem;
  }
  .feat-title {
    font-family: var(--display); font-size: 1.05rem;
    font-weight: 400; color: var(--ink);
    line-height: 1.3; margin-bottom: .5rem;
  }
  .feat-preview {
    font-size: .83rem; color: var(--ink2); line-height: 1.72;
    margin-bottom: .6rem;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .feat-time {
    font-size: .68rem; color: var(--sage);
    font-family: var(--display); font-style: italic;
  }

  /* Archive list */
  .archive-list { display: flex; flex-direction: column; gap: .45rem; }
  .arc-item {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 1.2rem;
    padding: 1rem 1.4rem; background: var(--bg);
    border: 1px solid var(--border); border-radius: 10px;
    text-decoration: none;
    transition: box-shadow .15s, transform .12s, border-color .15s;
  }
  .arc-item:not(.placeholder):hover {
    box-shadow: 0 2px 16px rgba(26,29,46,.05);
    transform: translateY(-1px); border-color: var(--border2);
  }
  .arc-item.placeholder { opacity: .5; pointer-events: none; border-style: dashed; }
  .arc-left { flex: 1; min-width: 0; }
  .arc-title {
    font-family: var(--display); font-size: .9rem;
    font-weight: 400; color: var(--ink);
    line-height: 1.3; margin-bottom: .2rem;
  }
  .arc-preview {
    font-size: .75rem; color: var(--ink3); line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 1;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .arc-right { flex-shrink: 0; text-align: right; }
  .arc-date { font-size: .68rem; color: var(--ink3); font-family: var(--display); font-style: italic; white-space: nowrap; }
  .arc-time { font-size: .65rem; color: var(--ink3); }
  .empty-note {
    text-align: center; padding: 2rem 0;
    font-family: var(--display); font-size: .88rem;
    font-style: italic; color: var(--ink3); line-height: 1.9;
  }

  @media (max-width: 860px) {
    .letters-hero { padding: 3.5rem 1.5rem 3rem; }
    .letters-hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .archive-section { padding: 3rem 1.5rem 4rem; }
  }
</style>

<main>

  <div class="letters-hero">
    <div class="letters-hero-inner">

      <div>
        <p class="hero-eyebrow">The Velani Letter</p>
        <h1 class="hero-title">A thoughtful Sunday letter<br>for women who want to <em>carry less.</em></h1>
        <p class="hero-desc">
          Some weeks you'll find a story.<br>
          Some weeks, an idea.<br>
          Some weeks, simply a reminder that you don't have to carry everything alone.<br>
          That's enough.
        </p>

        <div class="find-block">
          <div class="find-label">What you'll find here</div>
          <div class="find-items">
            <div class="find-item"><span class="find-dot"></span>Permission to carry less</div>
            <div class="find-item"><span class="find-dot"></span>Small practices that actually help</div>
            <div class="find-item"><span class="find-dot"></span>Warm, honest reflections on ordinary life</div>
            <div class="find-item"><span class="find-dot"></span>One idea that makes the week feel lighter</div>
          </div>
        </div>
      </div>

      <div class="signup-card">
        <div class="signup-eyebrow">Receive the letter</div>
        <h2 class="signup-hed">Arrive every <em>Sunday.</em></h2>
        <p class="signup-desc">
          Receive every Sunday. A thoughtful letter for making room for yourself again.
        </p>
        <div id="letters-form">
          <div class="inline-form">
            <input type="email" id="let-email" class="inline-email" placeholder="your@email.com" autocomplete="email">
            <button class="inline-btn" onclick="window.lettersSignup()">I'd love to receive it</button>
          </div>
          <p class="inline-consent">
            By joining, you agree to receive occasional Velani emails.
            <a href="/privacy" target="_blank">Privacy policy</a>.
          </p>
        </div>
        <div class="inline-success" id="let-success">✓ Check your inbox to confirm.</div>
        <div class="signup-trust">
          <span class="trust-badge">Every Sunday</span>
          <span class="trust-sep">·</span>
          <span class="trust-badge">Free</span>
          <span class="trust-sep">·</span>
          <span class="trust-badge">Unsubscribe anytime</span>
        </div>
      </div>

    </div>
  </div>

  <div class="archive-section">
    <div class="archive-inner">

      <div class="section-label">This week</div>
      <div class="featured-list">
        {featured.length > 0
          ? featured.map(l => (
              <a href={`/letters/${l.file.split('/').pop().replace('.md', '')}`} class="feat-card">
                <div class="feat-eyebrow">Featured</div>
                <div class="feat-title">{l.frontmatter.title}</div>
                {l.frontmatter.preview && <div class="feat-preview">{l.frontmatter.preview}</div>}
                <div class="feat-time">{l.frontmatter.readTime || '3 min read'}</div>
              </a>
            ))
          : phFeatured.map(p => (
              <div class="feat-card placeholder">
                <div class="feat-eyebrow">Featured</div>
                <div class="feat-title">{p.title}</div>
                <div class="feat-preview">{p.preview}</div>
                <div class="feat-time">{p.time}</div>
              </div>
            ))
        }
      </div>

      {(archive.length > 0 || phArchive.length > 0) && (
        <div>
          <div class="v-divider"></div>
          <div class="section-label">Earlier letters</div>
          <div class="archive-list">
            {archive.length > 0
              ? archive.map(l => (
                  <a href={`/letters/${l.file.split('/').pop().replace('.md', '')}`} class="arc-item">
                    <div class="arc-left">
                      <div class="arc-title">{l.frontmatter.title}</div>
                      {l.frontmatter.preview && <div class="arc-preview">{l.frontmatter.preview}</div>}
                    </div>
                    <div class="arc-right">
                      <div class="arc-date">{new Date(l.frontmatter.date + 'T12:00:00').toLocaleDateString('en-CA', { year:'numeric', month:'short', day:'numeric' })}</div>
                      <div class="arc-time">{l.frontmatter.readTime || '3 min'}</div>
                    </div>
                  </a>
                ))
              : phArchive.map(p => (
                  <div class="arc-item placeholder">
                    <div class="arc-left">
                      <div class="arc-title">{p.title}</div>
                      <div class="arc-preview">{p.preview}</div>
                    </div>
                    <div class="arc-right"><div class="arc-time">{p.time}</div></div>
                  </div>
                ))
            }
          </div>
          {letters.length === 0 && <div class="empty-note">First letter coming soon.<br>Sign up and you'll receive it Sunday.</div>}
        </div>
      )}

    </div>
  </div>

</main>

<script>
  window.lettersSignup = function() {
    const email = document.getElementById('let-email').value.trim();
    if (!email || !email.includes('@')) { document.getElementById('let-email').style.borderColor = '#B86A43'; return; }
    document.getElementById('let-email').style.borderColor = 'rgba(26,29,46,.14)';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email })
    }).then(() => ok()).catch(() => ok());
    function ok() {
      document.getElementById('letters-form').style.display = 'none';
      document.getElementById('let-success').classList.add('visible');
    }
  };
</script>

</Base>
