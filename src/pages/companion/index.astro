---
// src/pages/companion/index.astro — v4 full fix
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Velani Companion | Velani</title>
<meta name="description" content="A guided workbook built around your Invisible Load Audit result. Five steps to see it, sort it, release it, reclaim it, and move forward. Real change.">
<meta property="og:type" content="website">
<meta property="og:title" content="The Velani Companion | Velani">
<meta property="og:description" content="A guided workbook built around your Invisible Load Audit result. Five steps to see it, sort it, release it, reclaim it, and move forward.">
<meta property="og:url" content="https://velani.app/companion">
<meta property="og:image" content="https://velani.app/og-default.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="Velani">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="The Velani Companion | Velani">
<meta name="twitter:description" content="A guided workbook built around your Invisible Load Audit result. Five steps to see it, sort it, release it, reclaim it, and move forward.">
<meta name="twitter:image" content="https://velani.app/og-default.jpg">
<link rel="canonical" href="https://velani.app/companion">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
:root{
  --cream:#F7F6F3;--ink:#1A1D2E;--sage:#5B8C7A;--terra:#C4785A;
  --warm:#FDFCFA;--mist:#E8E4DC;--mist-d:#D4CFC5;
  --ink2:#3a3d4e;--ink3:#6b6e7d;
  --dc:#5B8C7A;--dc-l:rgba(91,140,122,.1);--dc-m:rgba(91,140,122,.22);
}
body.dom-connection{--dc:#C4785A;--dc-l:rgba(196,120,90,.1);--dc-m:rgba(196,120,90,.22);}
body.dom-material  {--dc:#6B8FB5;--dc-l:rgba(107,143,181,.1);--dc-m:rgba(107,143,181,.22);}
body.dom-liveliness{--dc:#5B8C7A;--dc-l:rgba(91,140,122,.1); --dc-m:rgba(91,140,122,.22);}
body.dom-inner     {--dc:#8E5EA7;--dc-l:rgba(142,94,167,.1); --dc-m:rgba(142,94,167,.22);}

*{box-sizing:border-box;margin:0;padding:0;}
html{-webkit-text-size-adjust:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased;min-height:100vh;}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;}}

/* TOPBAR */
.topbar{position:sticky;top:0;z-index:50;background:rgba(253,252,250,.97);border-bottom:1px solid var(--mist);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);padding:0 22px;}
.topbar-in{max-width:640px;margin:0 auto;display:flex;align-items:center;gap:14px;height:54px;}
.tb-brand{font-family:'Lora',serif;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--ink);text-decoration:none;flex-shrink:0;}
.tb-gauge{flex:1;height:4px;background:var(--mist);border-radius:4px;overflow:hidden;}
.tb-fill{height:100%;background:var(--dc);border-radius:4px;transition:width .6s cubic-bezier(.22,1,.36,1),background .4s;}
.tb-pct{font-size:.7rem;font-weight:600;color:var(--dc);flex-shrink:0;min-width:34px;text-align:right;transition:color .4s;}

/* SCREENS */
.screen{display:none;}
.screen.active{display:block;animation:fadeup .4s ease;}
@keyframes fadeup{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

/* WELCOME */
#sc-welcome{padding:48px 24px 80px;}
.wc-in{max-width:560px;margin:0 auto;}
.wc-label{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);margin-bottom:14px;}
.wc-h{font-family:'Lora',serif;font-size:clamp(1.9rem,6.5vw,2.7rem);font-weight:400;color:var(--ink);line-height:1.18;margin-bottom:16px;}
.wc-h em{font-style:italic;color:var(--terra);}
.wc-sub{font-size:1rem;color:var(--ink2);line-height:1.8;margin-bottom:14px;max-width:460px;}
.wc-promise{background:var(--warm);border:1px solid var(--mist);border-radius:14px;padding:18px 20px;margin-bottom:36px;max-width:460px;}
.wc-promise strong{font-size:.62rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);display:block;margin-bottom:7px;}
.wc-promise p{font-size:.88rem;color:var(--ink2);line-height:1.72;}
.wc-pick-label{font-size:.64rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);margin-bottom:14px;}
.domain-pick{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:380px){.domain-pick{grid-template-columns:1fr;}}

/* DOMAIN CARDS — spans must stack, not inline-flow */
button.dp-card{
  background:var(--warm);border:2px solid var(--mist-d);border-radius:16px;
  padding:22px 18px 18px;text-align:left;cursor:pointer;
  transition:border-color .18s,box-shadow .2s,transform .12s;
  font-family:'DM Sans',sans-serif;color:var(--ink);width:100%;
  -webkit-tap-highlight-color:transparent;
  min-height:130px;display:flex;flex-direction:column;align-items:flex-start;gap:0;
}
button.dp-card:active{transform:scale(.98);}
@media(hover:hover){button.dp-card:hover{border-color:var(--ink2);box-shadow:0 4px 18px rgba(26,29,46,.08);}}
button.dp-card.rec{border-color:var(--terra);background:rgba(196,120,90,.04);}
.dp-emoji{font-size:1.5rem;line-height:1;display:block;margin-bottom:10px;}
.dp-sub{display:block;font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:6px;}
.dp-name{display:block;font-size:1.05rem;font-weight:700;color:var(--ink);letter-spacing:-.01em;margin-bottom:7px;}
.dp-desc{display:block;font-size:.82rem;color:var(--ink3);line-height:1.5;}
.dp-rec-tag{display:block;font-size:.62rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--terra);margin-top:8px;}

/* DOMAIN INTRO */
#sc-dintro{padding-bottom:0;}
.di-hero{padding:60px 28px 44px;text-align:center;}
.di-hero-emoji{font-size:2rem;display:block;margin-bottom:18px;opacity:.9;}
.di-hero-label{font-size:.62rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:10px;}
.di-hero-name{font-family:'Lora',serif;font-size:clamp(2.4rem,9vw,3.4rem);font-weight:400;color:#fff;line-height:1;}
.di-body-wrap{padding:36px 24px 40px;max-width:580px;margin:0 auto;}
.di-callout{border-left:3px solid var(--dc);padding-left:20px;margin-bottom:32px;transition:border-color .4s;}
.di-callout p{font-family:'Lora',serif;font-size:1rem;font-style:italic;color:var(--ink2);line-height:1.84;}
.di-callout p+p{margin-top:.9em;}
.di-nav{display:flex;gap:10px;flex-wrap:wrap;}
button.di-back{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:15px 20px;border-radius:12px;font-size:.92rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.di-back:hover{border-color:var(--ink);color:var(--ink);}}
button.di-start{background:var(--dc);color:#fff;border:none;padding:15px 32px;border-radius:12px;font-size:.96rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s,transform .12s;flex:1;min-height:52px;min-width:160px;-webkit-tap-highlight-color:transparent;}
button.di-start:active{transform:scale(.99);}

/* STEP SCREEN */
#sc-step.active{display:block;}
.step-wrap{padding:24px 24px 110px;max-width:620px;margin:0 auto;width:100%;}

/* Step header — combined "Domain · N of N" */
.step-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;padding-bottom:14px;border-bottom:1px solid var(--mist);gap:16px;}
.step-domain-tag{font-size:.72rem;font-weight:700;color:var(--dc);letter-spacing:.03em;transition:color .4s;}
.step-counter{font-size:.7rem;color:var(--ink3);font-weight:500;}

/* Section label — Lora, not all-caps */
.step-sec-label{
  font-family:'Lora',serif;font-style:italic;font-size:.94rem;font-weight:400;
  color:var(--sage);margin-bottom:7px;letter-spacing:0;
  transition:color .4s;
}
body.dom-connection .step-sec-label{color:var(--dc);}
body.dom-material   .step-sec-label{color:var(--dc);}
body.dom-inner      .step-sec-label{color:var(--dc);}

.step-title{font-family:'Lora',serif;font-size:clamp(1.45rem,5vw,1.85rem);font-weight:500;color:var(--ink);line-height:1.22;margin-bottom:14px;}
.step-body{font-size:.96rem;color:var(--ink2);line-height:1.84;margin-bottom:22px;}
.step-body p+p{margin-top:.8em;}
.step-body em{font-style:italic;}
.step-body strong{color:var(--ink);font-weight:600;}

/* FIXED STEP NAV */
.step-nav{background:rgba(253,252,250,.97);border-top:1px solid var(--mist);padding:12px 22px;position:fixed;bottom:0;left:0;right:0;z-index:40;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);}
.step-nav-in{max-width:620px;margin:0 auto;width:100%;display:flex;gap:8px;align-items:center;}
button.sn-back{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:13px 16px;border-radius:11px;font-size:.88rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;min-height:50px;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.sn-back:hover{border-color:var(--ink);color:var(--ink);}}
button.sn-skip{background:none;border:none;color:var(--ink3);font-size:.82rem;font-family:'DM Sans',sans-serif;cursor:pointer;padding:8px 12px;min-height:50px;transition:color .15s;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.sn-skip:hover{color:var(--ink);}}
button.sn-next{background:var(--ink);color:var(--cream);border:none;padding:13px 22px;border-radius:11px;font-size:.92rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s,transform .12s;flex:1;min-height:50px;-webkit-tap-highlight-color:transparent;}
button.sn-next:active{transform:scale(.99);}
@media(hover:hover){button.sn-next:hover{background:var(--dc);}}

/* SEE (reflect) */
.reflect-prompt{font-size:1rem;font-weight:600;color:var(--ink);line-height:1.6;margin-bottom:14px;}
textarea.reflect-area{
  width:100%;min-height:260px;padding:22px;
  border:2px solid var(--mist-d);border-radius:13px;
  font-family:'DM Sans',sans-serif;font-size:1.05rem;color:var(--ink);
  background:var(--warm);resize:vertical;outline:none;
  transition:border-color .2s;line-height:1.8;
  -webkit-appearance:none;
}
textarea.reflect-area:focus{border-color:var(--dc);}
textarea.reflect-area::placeholder{color:var(--ink3);font-size:.95rem;line-height:1.6;}

/* SORT (tick) — strong visual state */
.sort-list{display:flex;flex-direction:column;gap:9px;margin-top:4px;}
button.sort-item{
  display:flex;align-items:center;gap:14px;
  width:100%;padding:17px 18px;
  background:var(--warm);
  border:2px solid var(--mist-d);
  border-left:4px solid var(--mist-d);
  border-radius:13px;cursor:pointer;text-align:left;
  font-family:'DM Sans',sans-serif;
  transition:border-color .18s,background .18s,border-left-color .18s;
  -webkit-tap-highlight-color:transparent;
  min-height:62px;
}
button.sort-item:active{transform:scale(.995);}
@media(hover:hover){button.sort-item:hover{border-color:var(--dc);border-left-color:var(--dc);}}
button.sort-item.checked{
  border-color:var(--dc);
  border-left-color:var(--dc);
  border-left-width:4px;
  background:var(--dc-l);
}
.s-box{
  width:24px;height:24px;min-width:24px;border-radius:6px;
  border:2px solid var(--mist-d);display:flex;align-items:center;justify-content:center;
  transition:background .18s,border-color .18s;flex-shrink:0;
  background:#fff;
}
button.sort-item.checked .s-box{background:var(--dc);border-color:var(--dc);}
.s-tick{color:#fff;font-size:.8rem;font-weight:700;opacity:0;transition:opacity .15s;line-height:1;}
button.sort-item.checked .s-tick{opacity:1;}
.s-text{font-size:.95rem;color:var(--ink2);line-height:1.45;font-weight:400;transition:color .18s;}
button.sort-item.checked .s-text{color:var(--ink);font-weight:600;}

/* WISDOM */
.wisdom-block{background:var(--ink);border-radius:18px;padding:34px 28px;margin-top:4px;}
.wis-text{font-family:'Lora',serif;font-size:1.08rem;font-style:italic;color:rgba(247,246,243,.88);line-height:1.88;}
.wis-text strong{font-style:normal;color:var(--warm);font-weight:500;}
.wisdom-continue{margin-top:20px;font-size:.82rem;color:rgba(247,246,243,.4);font-style:normal;font-family:'DM Sans',sans-serif;}

/* RELEASE (keep / delegate / simplify / let go) */
.kdsl-list{display:flex;flex-direction:column;gap:0;}
.kdsl-group{padding:20px 0;border-bottom:1px solid var(--mist);}
.kdsl-group:first-child{padding-top:4px;}
.kdsl-group:last-child{border-bottom:none;padding-bottom:0;}
.kdsl-label{font-size:.95rem;color:var(--ink2);line-height:1.5;margin-bottom:12px;}
.kdsl-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
button.kdsl-btn{
  padding:14px 8px;border:2px solid var(--mist-d);border-radius:22px;
  background:var(--warm);color:var(--ink3);
  font-size:.84rem;font-family:'DM Sans',sans-serif;font-weight:500;
  cursor:pointer;transition:all .18s;min-height:52px;text-align:center;
  -webkit-tap-highlight-color:transparent;line-height:1.2;
}
button.kdsl-btn:active{transform:scale(.97);}
@media(hover:hover){button.kdsl-btn:hover{border-color:var(--dc);color:var(--dc);background:var(--dc-l);}}
button.kdsl-btn.chosen{
  background:var(--dc);border-color:var(--dc);
  color:#fff;font-weight:700;
  box-shadow:0 2px 8px rgba(0,0,0,.12);
}
button.kdsl-btn.chosen::after{content:' \2713';font-size:.72rem;}
@media(max-width:360px){.kdsl-row{grid-template-columns:repeat(2,1fr);}}

/* RECLAIM */
.reclaim-q{font-size:1rem;font-weight:600;color:var(--ink);line-height:1.6;margin-bottom:14px;}
.forward-section{margin-top:30px;padding-top:26px;border-top:1px solid var(--mist);}
.forward-label{font-family:'Lora',serif;font-style:italic;font-size:.94rem;color:var(--sage);margin-bottom:9px;transition:color .4s;}
body.dom-connection .forward-label,body.dom-material .forward-label,body.dom-inner .forward-label{color:var(--dc);}
.forward-q{font-size:.96rem;color:var(--ink2);line-height:1.7;margin-bottom:14px;}
.closing-line-card{margin-top:32px;background:var(--dc-l);border:1px solid var(--dc-m);border-radius:18px;padding:34px 26px;text-align:center;}
.cl-glyph{font-size:1rem;color:var(--dc);display:block;margin-bottom:14px;transition:color .4s;}
.cl-quote{font-family:'Lora',serif;font-size:1.08rem;font-style:italic;color:var(--ink);line-height:1.82;white-space:pre-line;}
.cl-attr{display:block;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);margin-top:14px;}

/* CLOSING SCREEN */
#sc-closing{padding:48px 24px 80px;}
.clo-in{max-width:560px;margin:0 auto;}
.clo-label{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);margin-bottom:12px;}
.clo-h{font-family:'Lora',serif;font-size:clamp(1.7rem,6vw,2.2rem);font-weight:400;color:var(--ink);line-height:1.2;margin-bottom:12px;}
.clo-sub{font-size:.95rem;color:var(--ink2);line-height:1.78;margin-bottom:32px;}
.clo-list{display:flex;flex-direction:column;gap:10px;margin-bottom:36px;}
.clo-item{background:var(--warm);border:1px solid var(--mist);border-radius:13px;padding:18px;}
.clo-item-tag{font-size:.58rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--dc);margin-bottom:5px;transition:color .4s;}
.clo-item-text{font-size:.94rem;color:var(--ink);line-height:1.6;}

/* Email to self */
.clo-email-wrap{background:var(--warm);border:1px solid var(--mist);border-radius:16px;padding:24px 22px;margin-bottom:28px;}
.clo-email-h{font-family:'Lora',serif;font-size:1.1rem;font-weight:500;color:var(--ink);margin-bottom:6px;}
.clo-email-sub{font-size:.86rem;color:var(--ink3);line-height:1.6;margin-bottom:16px;}
.clo-email-row{display:flex;gap:8px;flex-wrap:wrap;}
input.clo-email-input{
  flex:1;min-width:0;padding:13px 16px;
  border:2px solid var(--mist-d);border-radius:11px;
  font-family:'DM Sans',sans-serif;font-size:.95rem;color:var(--ink);
  background:var(--cream);outline:none;transition:border-color .2s;
  min-width:200px;
}
input.clo-email-input:focus{border-color:var(--dc);}
input.clo-email-input::placeholder{color:var(--ink3);}
button.clo-email-btn{
  background:var(--ink);color:var(--cream);border:none;
  padding:13px 22px;border-radius:11px;font-size:.9rem;font-weight:600;
  font-family:'DM Sans',sans-serif;cursor:pointer;
  transition:background .18s;min-height:50px;white-space:nowrap;
  -webkit-tap-highlight-color:transparent;
}
@media(hover:hover){button.clo-email-btn:hover{background:var(--dc);}}
.clo-email-ok{display:none;font-size:.88rem;color:var(--sage);margin-top:12px;font-family:'Lora',serif;font-style:italic;}

.clo-actions{display:flex;gap:10px;flex-wrap:wrap;}
button.clo-again{background:var(--ink);color:var(--cream);border:none;padding:15px 26px;border-radius:12px;font-size:.92rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.clo-again:hover{background:var(--dc);}}
button.clo-audit{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:15px 22px;border-radius:12px;font-size:.92rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.clo-audit:hover{border-color:var(--ink);color:var(--ink);}}

@media(min-width:640px){
  .wc-in,.clo-in{padding:0;}
  .step-wrap{padding:32px 32px 110px;}
}
@media(max-width:480px){
  .step-wrap{padding:20px 16px 110px;}
  textarea.reflect-area{min-height:200px;padding:16px;font-size:1rem;}
  .kdsl-row{grid-template-columns:repeat(2,1fr);gap:10px;}
  button.kdsl-btn{padding:16px 10px;font-size:.86rem;min-height:56px;}
  button.sort-item{padding:18px 16px;min-height:64px;}
  .s-text{font-size:1rem;}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-in">
    <a class="tb-brand" href="/">Velani</a>
    <div class="tb-gauge"><div class="tb-fill" id="gauge-fill"></div></div>
    <div class="tb-pct" id="gauge-pct">0%</div>
  </div>
</div>

<!-- WELCOME -->
<div class="screen active" id="sc-welcome">
  <div class="wc-in">
    <div class="wc-label">The Velani Companion</div>
    <h1 class="wc-h">You're not here to do less.<br><em>You're here to bring your best<br>to what's worth it.</em></h1>
    <p class="wc-sub">Choose the domain that's carrying your heaviest load. Five steps. One at a time. Always forward.</p>
    <div class="wc-promise">
      <strong>One promise, before anything</strong>
      <p>Go at your own pace. Take one part at a time. Skip what doesn't fit. Return whenever you like. There's more of you in here than the load has let you see.</p>
    </div>
    <div class="wc-pick-label">Choose your domain</div>
    <div class="domain-pick" id="domain-pick"></div>
  </div>
</div>

<!-- DOMAIN INTRO -->
<div class="screen" id="sc-dintro">
  <div class="di-hero" id="di-hero">
    <span class="di-hero-emoji" id="di-emoji"></span>
    <div class="di-hero-label" id="di-num"></div>
    <div class="di-hero-name" id="di-name"></div>
  </div>
  <div class="di-body-wrap">
    <div class="di-callout" id="di-callout"></div>
    <div class="di-nav">
      <button class="di-back" onclick="goWelcome()">&#8592; Choose another</button>
      <button class="di-start" id="di-start-btn" onclick="startSteps()">Begin &#8594;</button>
    </div>
  </div>
</div>

<!-- STEPS -->
<div class="screen" id="sc-step">
  <div class="step-wrap" id="step-wrap"></div>
</div>

<!-- Fixed bottom nav — only shown during steps -->
<div class="step-nav" id="step-nav" style="display:none;">
  <div class="step-nav-in">
    <button class="sn-back" id="sn-back" onclick="prevStep()">&#8592; Back</button>
    <button class="sn-skip" onclick="skipStep()">Skip</button>
    <button class="sn-next" id="sn-next" onclick="nextStep()">Continue &#8594;</button>
  </div>
</div>

<!-- CLOSING -->
<div class="screen" id="sc-closing">
  <div class="clo-in">
    <div class="clo-label">Your session</div>
    <h2 class="clo-h">What you decided to carry differently.</h2>
    <p class="clo-sub">A record of this session. The weight you named, and the strength you're building in its place.</p>
    <div class="clo-list" id="clo-list"></div>
    <div class="clo-email-wrap">
      <div class="clo-email-h">Save your session</div>
      <p class="clo-email-sub">Enter your email to receive a copy of your choices, plus your personalized next steps.</p>
      <div class="clo-email-row">
        <input type="email" class="clo-email-input" id="clo-email" placeholder="your@email.com" autocomplete="email">
        <button class="clo-email-btn" onclick="emailSession()">Send to me</button>
      </div>
      <button style="margin-top:10px;background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:11px 18px;border-radius:11px;font-size:.84rem;font-family:'DM Sans',sans-serif;cursor:pointer;width:100%;-webkit-tap-highlight-color:transparent;" onclick="copySession()">Copy my session to clipboard</button>
      <p class="clo-email-ok" id="clo-email-ok">Saved. A copy is on its way to your inbox.</p>
    </div>
    <div class="clo-actions">
      <button class="clo-again" onclick="goWelcome()">Start another domain</button>
      <button class="clo-audit" onclick="location.href='/audit'">Retake the audit</button>
    </div>
  </div>
</div>

