var STORE_KEY='velani_companion_v3';
var currentDomain=null,currentStep=0,responses={},gaugeVal=0;

function saveState(){try{localStorage.setItem(STORE_KEY,JSON.stringify({responses:responses,gaugeVal:gaugeVal,savedAt:Date.now()}));}catch(e){}}
function loadState(){try{var raw=localStorage.getItem(STORE_KEY);if(raw){var d=JSON.parse(raw);if(d.responses)responses=d.responses;if(d.gaugeVal)gaugeVal=d.gaugeVal;}}catch(e){}}

function updateGauge(){
  var el=document.getElementById('gauge-fill'),pe=document.getElementById('gauge-pct');
  if(el)el.style.width=gaugeVal+'%';
  if(pe)pe.textContent=Math.round(gaugeVal)+'%';
}

function show(id){
  var ss=document.querySelectorAll('.screen');
  for(var i=0;i<ss.length;i++)ss[i].classList.remove('active');
  document.getElementById(id).classList.add('active');
  var nav=document.getElementById('step-nav');
  if(nav)nav.style.display=(id==='sc-step'?'block':'none');
  window.scrollTo(0,0);
}

function setDomainTheme(d){
  document.body.className=d?d.bodyClass:'';
}

function getRecommendedDomain(){
  var p=new URLSearchParams(window.location.search);
  var dom=p.get('domain');if(dom&&DOMAINS[dom])return dom;
  var pat=p.get('pattern');
  if(!pat){try{pat=localStorage.getItem('velani_audit_pattern')||'';}catch(e){}}
  var dom2;try{dom2=localStorage.getItem('velani_audit_domain')||'';}catch(e){}
  if(dom2&&DOMAINS[dom2])return dom2;
  var map={'success-without-self':'inner','endless-pour':'liveliness','running-on-empty':'liveliness','quiet-disappearance':'inner','holding-it-together':'connection','carrying-well':'inner'};
  if(pat&&map[pat])return map[pat];
  return null;
}

function goWelcome(){
  setDomainTheme(null);
  gaugeVal=0;updateGauge();
  show('sc-welcome');
}

function chooseDomain(key){
  currentDomain=DOMAINS[key];currentStep=0;
  var d=currentDomain;
  setDomainTheme(d);
  document.getElementById('di-emoji').textContent=d.emoji;
  document.getElementById('di-num').textContent=d.num;
  document.getElementById('di-name').textContent=d.name;
  document.getElementById('di-hero').style.background=d.color;
  document.getElementById('di-start-btn').style.background=d.color;
  var callout=document.getElementById('di-callout');
  callout.innerHTML='<p>'+d.intro+'</p>';
  callout.style.borderLeftColor=d.color;
  show('sc-dintro');
}

function startSteps(){currentStep=0;renderStep();show('sc-step');}

function prevStep(){
  if(currentStep>0){currentStep--;renderStep();window.scrollTo(0,0);}
  else{show('sc-dintro');}
}

function skipStep(){advanceStep();}
function nextStep(){advanceStep();}

function advanceStep(){
  if(!currentDomain)return;
  var steps=currentDomain.steps;
  saveCurrentStepResponse();
  if(currentStep<steps.length-1){
    currentStep++;renderStep();window.scrollTo(0,0);
  }else{
    buildClosing();show('sc-closing');
  }
  gaugeVal=Math.min(100,Math.round((currentStep+1)/steps.length*100));
  updateGauge();saveState();
}

function saveCurrentStepResponse(){
  if(!currentDomain)return;
  var s=currentDomain.steps[currentStep];
  if(s.type==='see'||s.type==='reclaim'){
    var ta=document.getElementById('rta-main');
    if(ta){responses[currentDomain.key+'_'+s.type]=ta.value;}
    var ta2=document.getElementById('rta-fwd');
    if(ta2){responses[currentDomain.key+'_fwd']=ta2.value;}
  }
}

function renderStep(){
  if(!currentDomain)return;
  var steps=currentDomain.steps,s=steps[currentStep],total=steps.length;
  var wrap=document.getElementById('step-wrap');
  var html='<div class="step-header">'
    +'<span class="step-domain-tag">'+currentDomain.name+'</span>'
    +'<span class="step-counter">'+( currentStep+1)+' of '+total+'</span>'
    +'</div>';
  html+='<div class="step-sec-label">'+s.label+'</div>';
  html+='<div class="step-title">'+s.title+'</div>';

  if(s.type==='see'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sv=responses[currentDomain.key+'_see']||'';
    html+='<div class="reflect-prompt">'+s.q+'</div>'
      +'<textarea class="reflect-area" id="rta-main" placeholder="Write as little or as much as feels right…" oninput="autoSave(\'see\')">'+esc(sv)+'</textarea>';

  }else if(s.type==='sort'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    html+='<div class="sort-list" id="sort-list">';
    for(var i=0;i<s.items.length;i++){
      var rk=currentDomain.key+'_sort_'+i;
      var ck=responses[rk]?' checked':'';
      html+='<button type="button" class="sort-item'+ck+'" onclick="toggleSort('+i+')">'
        +'<span class="s-box"><span class="s-tick">&#10003;</span></span>'
        +'<span class="s-text">'+s.items[i]+'</span>'
        +'</button>';
    }
    html+='</div>';

  }else if(s.type==='wisdom'){
    html+='<div class="wisdom-block"><div class="wis-tag">The Order of Care, here</div>'
      +'<div class="wis-text">'+s.wisdom+'</div></div>';

  }else if(s.type==='release'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sortItems=steps[1].items;
    var opts=['keep','delegate','simplify','let go'];
    html+='<div class="kdsl-list">';
    for(var j=0;j<sortItems.length;j++){
      var rk2=currentDomain.key+'_rel_'+j;
      var chosen=responses[rk2]||'';
      html+='<div class="kdsl-group"><div class="kdsl-label">'+sortItems[j]+'</div><div class="kdsl-row">';
      for(var oi=0;oi<opts.length;oi++){
        var o=opts[oi];
        var isCh=(chosen===o);
        html+='<button type="button" class="kdsl-btn'+(isCh?' chosen':'')+'" data-k="'+j+'" data-v="'+o+'" onclick="chooseKdsl(this)">'+o+'</button>';
      }
      html+='</div></div>';
    }
    html+='</div>';

  }else if(s.type==='reclaim'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sv2=responses[currentDomain.key+'_reclaim']||'';
    html+='<div class="reclaim-q">'+s.rq+'</div>'
      +'<textarea class="reflect-area" id="rta-main" placeholder="Write as little or as much as feels right…" oninput="autoSave(\'reclaim\')">'+esc(sv2)+'</textarea>';
    html+='<div class="forward-section">'
      +'<div class="forward-label">FORWARD · ONE REAL MOVE</div>'
      +'<div class="forward-q">'+s.fq+'</div>';
    var sv3=responses[currentDomain.key+'_fwd']||'';
    html+='<textarea class="reflect-area" id="rta-fwd" placeholder="One concrete move…" style="min-height:90px;" oninput="autoSaveFwd()">'+esc(sv3)+'</textarea>'
      +'</div>';
    html+='<div class="closing-line-card">'
      +'<span class="cl-glyph">&#10022;</span>'
      +'<div class="cl-quote">'+s.line+'</div>'
      +'<span class="cl-attr">A line to carry with you</span>'
      +'</div>';
  }

  wrap.innerHTML=html;
  var bk=document.getElementById('sn-back');
  if(bk)bk.textContent=(currentStep===0?'← Domain':'← Back');
  var nx=document.getElementById('sn-next');
  if(nx)nx.textContent=(currentStep===steps.length-1?'Finish →':'Continue →');
}

function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function autoSave(type){
  if(!currentDomain)return;
  var ta=document.getElementById('rta-main');
  if(ta)responses[currentDomain.key+'_'+type]=ta.value;
  saveState();
}
function autoSaveFwd(){
  if(!currentDomain)return;
  var ta=document.getElementById('rta-fwd');
  if(ta)responses[currentDomain.key+'_fwd']=ta.value;
  saveState();
}

function toggleSort(i){
  if(!currentDomain)return;
  var rk=currentDomain.key+'_sort_'+i;
  responses[rk]=!responses[rk];
  var items=document.querySelectorAll('.sort-item');
  if(items[i]){
    items[i].classList.toggle('checked',!!responses[rk]);
  }
  saveState();
}

function chooseKdsl(btn){
  var k=btn.getAttribute('data-k');
  var v=btn.getAttribute('data-v');
  responses[currentDomain.key+'_rel_'+k]=v;
  var grp=document.querySelectorAll('[data-k="'+k+'"]');
  for(var i=0;i<grp.length;i++)grp[i].classList.remove('chosen');
  btn.classList.add('chosen');
  saveState();
}

function buildClosing(){
  if(!currentDomain)return;
  var steps=currentDomain.steps,d=currentDomain;
  var list=document.getElementById('clo-list');
  var html='';
  var see=responses[d.key+'_see'];
  if(see&&see.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">What you named</div><div class="clo-item-text">'+esc(see)+'</div></div>';
  }
  var sortItems=steps[1].items;
  var checkedItems=[];
  for(var i=0;i<sortItems.length;i++){if(responses[d.key+'_sort_'+i])checkedItems.push(sortItems[i]);}
  if(checkedItems.length){
    html+='<div class="clo-item"><div class="clo-item-tag">What you recognised</div><div class="clo-item-text">'+checkedItems.join('<br>')+'</div></div>';
  }
  var opts=['keep','delegate','simplify','let go'];
  for(var j=0;j<sortItems.length;j++){
    var v=responses[d.key+'_rel_'+j];
    if(v){html+='<div class="clo-item"><div class="clo-item-tag">'+v.charAt(0).toUpperCase()+v.slice(1)+'</div><div class="clo-item-text">'+sortItems[j]+'</div></div>';}
  }
  var rec=responses[d.key+'_reclaim'];
  if(rec&&rec.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">What you\'re growing toward</div><div class="clo-item-text">'+esc(rec)+'</div></div>';
  }
  var fwd=responses[d.key+'_fwd'];
  if(fwd&&fwd.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">Your one real move</div><div class="clo-item-text">'+esc(fwd)+'</div></div>';
  }
  if(!html){
    html='<div class="clo-item"><div class="clo-item-text" style="color:var(--ink3);font-style:italic;">Your choices and reflections from this session will appear here.</div></div>';
  }
  list.innerHTML=html;
  gaugeVal=100;updateGauge();saveState();
}

// Init
loadState();updateGauge();

(function(){
  var rec=getRecommendedDomain();
  var pick=document.getElementById('domain-pick');
  var order=['inner','connection','material','liveliness'];
  order.forEach(function(k){
    var d=DOMAINS[k];
    var isRec=(k===rec);
    var card=document.createElement('button');
    card.type='button';
    card.className='dp-card'+(isRec?' rec':'');
    card.innerHTML='<span class="dp-emoji">'+d.emoji+'</span>'
      +'<span class="dp-sub">'+d.num+'</span>'
      +'<span class="dp-name">'+d.name+'</span>'
      +'<span class="dp-desc">'+d.desc+'</span>'
      +(isRec?'<span class="dp-rec-tag">&#9733; Your heaviest — start here</span>':'');
    card.onclick=function(){chooseDomain(k);};
    pick.appendChild(card);
  });
})();
</script>
</body>
</html>
