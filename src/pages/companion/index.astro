---
// src/pages/companion/index.astro — The Velani Companion v3
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Velani Companion</title>
<meta name="description" content="A guided workbook for the domain that's carrying your heaviest load. Five steps. Real change.">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#F7F6F3;--ink:#1A1D2E;--sage:#5B8C7A;--terra:#C4785A;
  --warm:#FDFCFA;--mist:#E8E4DC;--mist-d:#D4CFC5;
  --ink2:#3a3d4e;--ink3:#6b6e7d;
  --dc:#5B8C7A;--dc-l:rgba(91,140,122,.09);--dc-m:rgba(91,140,122,.2);
}
body.dom-connection{--dc:#C4785A;--dc-l:rgba(196,120,90,.09);--dc-m:rgba(196,120,90,.2);}
body.dom-material  {--dc:#6B8FB5;--dc-l:rgba(107,143,181,.09);--dc-m:rgba(107,143,181,.2);}
body.dom-liveliness{--dc:#5B8C7A;--dc-l:rgba(91,140,122,.09); --dc-m:rgba(91,140,122,.2);}
body.dom-inner     {--dc:#8E5EA7;--dc-l:rgba(142,94,167,.09); --dc-m:rgba(142,94,167,.2);}

*{box-sizing:border-box;margin:0;padding:0;}
html{-webkit-text-size-adjust:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);line-height:1.65;-webkit-font-smoothing:antialiased;min-height:100vh;}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;}}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:50;background:rgba(253,252,250,.97);border-bottom:1px solid var(--mist);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);padding:0 22px;}
.topbar-in{max-width:640px;margin:0 auto;display:flex;align-items:center;gap:14px;height:54px;}
.tb-brand{font-family:'Lora',serif;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--ink);text-decoration:none;flex-shrink:0;}
.tb-gauge{flex:1;height:4px;background:var(--mist);border-radius:4px;overflow:hidden;}
.tb-fill{height:100%;background:var(--dc);border-radius:4px;transition:width .6s cubic-bezier(.22,1,.36,1),background .4s;}
.tb-pct{font-size:.7rem;font-weight:600;color:var(--dc);flex-shrink:0;min-width:34px;text-align:right;transition:color .4s;}

/* ── SCREENS ── */
.screen{display:none;}
.screen.active{display:block;animation:fadeup .4s ease;}
@keyframes fadeup{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

/* ── WELCOME ── */
#sc-welcome{padding:48px 24px 80px;}
.wc-in{max-width:560px;margin:0 auto;}
.wc-label{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);margin-bottom:14px;}
.wc-h{font-family:'Lora',serif;font-size:clamp(2rem,7vw,2.8rem);font-weight:400;color:var(--ink);line-height:1.14;margin-bottom:16px;}
.wc-h em{font-style:italic;color:var(--terra);}
.wc-sub{font-size:1rem;color:var(--ink2);line-height:1.8;margin-bottom:14px;max-width:460px;}
.wc-promise{background:var(--warm);border:1px solid var(--mist);border-radius:14px;padding:18px 20px;margin-bottom:36px;max-width:460px;}
.wc-promise strong{font-size:.62rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);display:block;margin-bottom:7px;}
.wc-promise p{font-size:.88rem;color:var(--ink2);line-height:1.72;}
.wc-pick-label{font-size:.64rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);margin-bottom:14px;}
.domain-pick{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
button.dp-card{
  background:var(--warm);border:2px solid var(--mist-d);border-radius:16px;
  padding:22px 18px 18px;text-align:left;cursor:pointer;
  transition:border-color .18s,box-shadow .2s,transform .12s;
  font-family:'DM Sans',sans-serif;color:var(--ink);width:100%;
  -webkit-tap-highlight-color:transparent;
  min-height:130px;display:flex;flex-direction:column;gap:4px;
}
button.dp-card:active{transform:scale(.98);}
@media(hover:hover){button.dp-card:hover{border-color:var(--ink2);box-shadow:0 4px 18px rgba(26,29,46,.08);}}
button.dp-card.rec{border-color:var(--terra);background:rgba(196,120,90,.04);}
@media(hover:hover){button.dp-card.rec:hover{border-color:var(--terra);}}
.dp-emoji{font-size:1.6rem;line-height:1;display:block;margin-bottom:8px;}
.dp-sub{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);}
.dp-name{font-size:1.05rem;font-weight:700;color:var(--ink);letter-spacing:-.01em;}
.dp-desc{font-size:.78rem;color:var(--ink3);line-height:1.45;margin-top:2px;}
.dp-rec-tag{font-size:.64rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--terra);margin-top:6px;display:block;}
@media(max-width:380px){.domain-pick{grid-template-columns:1fr;}}

/* ── DOMAIN INTRO ── */
#sc-dintro{padding-bottom:0;}
.di-hero{padding:60px 28px 44px;text-align:center;}
.di-hero-emoji{font-size:2rem;display:block;margin-bottom:18px;opacity:.9;}
.di-hero-label{font-size:.62rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:10px;}
.di-hero-name{font-family:'Lora',serif;font-size:clamp(2.4rem,9vw,3.4rem);font-weight:400;color:#fff;line-height:1;}
.di-body-wrap{padding:36px 24px 40px;max-width:580px;margin:0 auto;}
.di-callout{border-left:3px solid var(--dc);padding-left:20px;margin-bottom:32px;}
.di-callout p{font-family:'Lora',serif;font-size:1rem;font-style:italic;color:var(--ink2);line-height:1.84;}
.di-callout p+p{margin-top:.9em;}
.di-nav{display:flex;gap:10px;flex-wrap:wrap;}
button.di-back{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:15px 20px;border-radius:12px;font-size:.92rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.di-back:hover{border-color:var(--ink);color:var(--ink);}}
button.di-start{background:var(--dc);color:#fff;border:none;padding:15px 32px;border-radius:12px;font-size:.96rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s,transform .12s;flex:1;min-height:52px;min-width:160px;-webkit-tap-highlight-color:transparent;}
button.di-start:active{transform:scale(.99);}

/* ── STEP SCREEN ── */
#sc-step.active{display:block;}
.step-wrap{padding:24px 24px 110px;max-width:620px;margin:0 auto;width:100%;}
.step-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:26px;padding-bottom:16px;border-bottom:1px solid var(--mist);}
.step-domain-tag{font-size:.7rem;font-weight:700;color:var(--dc);letter-spacing:.04em;transition:color .4s;}
.step-counter{font-size:.7rem;color:var(--ink3);font-weight:500;}
.step-sec-label{font-size:.58rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--dc);margin-bottom:9px;transition:color .4s;}
.step-title{font-family:'Lora',serif;font-size:clamp(1.5rem,5vw,1.95rem);font-weight:400;color:var(--ink);line-height:1.2;margin-bottom:12px;}
.step-body{font-size:.96rem;color:var(--ink2);line-height:1.84;margin-bottom:20px;}
.step-body p+p{margin-top:.8em;}
.step-body em{font-style:italic;}
.step-body strong{color:var(--ink);font-weight:600;}

/* ── FIXED STEP NAV ── */
.step-nav{background:rgba(253,252,250,.97);border-top:1px solid var(--mist);padding:12px 22px;position:fixed;bottom:0;left:0;right:0;z-index:40;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);}
.step-nav-in{max-width:620px;margin:0 auto;width:100%;display:flex;gap:8px;align-items:center;}
button.sn-back{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:13px 16px;border-radius:11px;font-size:.88rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;min-height:50px;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.sn-back:hover{border-color:var(--ink);color:var(--ink);}}
button.sn-skip{background:none;border:none;color:var(--ink3);font-size:.82rem;font-family:'DM Sans',sans-serif;cursor:pointer;padding:8px 12px;min-height:50px;transition:color .15s;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.sn-skip:hover{color:var(--ink);}}
button.sn-next{background:var(--ink);color:var(--cream);border:none;padding:13px 22px;border-radius:11px;font-size:.92rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s,transform .12s;flex:1;min-height:50px;-webkit-tap-highlight-color:transparent;}
button.sn-next:active{transform:scale(.99);}
@media(hover:hover){button.sn-next:hover{background:var(--dc);}}

/* ── SEE (reflect) ── */
.reflect-prompt{font-size:1rem;font-weight:600;color:var(--ink);line-height:1.55;margin-bottom:13px;}
textarea.reflect-area{width:100%;min-height:150px;padding:18px;border:1.5px solid var(--mist-d);border-radius:13px;font-family:'DM Sans',sans-serif;font-size:.96rem;color:var(--ink);background:var(--warm);resize:vertical;outline:none;transition:border-color .2s;line-height:1.7;-webkit-appearance:none;}
textarea.reflect-area:focus{border-color:var(--dc);}
textarea.reflect-area::placeholder{color:var(--ink3);}

/* ── SORT (tick) ── */
.sort-list{display:flex;flex-direction:column;gap:8px;margin-top:4px;}
button.sort-item{
  display:flex;align-items:center;gap:14px;
  width:100%;padding:17px 18px;
  background:var(--warm);border:1.5px solid var(--mist-d);
  border-radius:13px;cursor:pointer;text-align:left;
  font-family:'DM Sans',sans-serif;
  transition:border-color .18s,background .18s;
  -webkit-tap-highlight-color:transparent;
  min-height:60px;
}
button.sort-item:active{transform:scale(.995);}
@media(hover:hover){button.sort-item:hover{border-color:var(--dc);}}
button.sort-item.checked{border-color:var(--dc);background:var(--dc-l);}
.s-box{width:24px;height:24px;min-width:24px;border-radius:6px;border:2px solid var(--mist-d);display:flex;align-items:center;justify-content:center;transition:background .18s,border-color .18s;flex-shrink:0;background:var(--cream);}
button.sort-item.checked .s-box{background:var(--dc);border-color:var(--dc);}
.s-tick{color:#fff;font-size:.78rem;font-weight:700;opacity:0;transition:opacity .15s;line-height:1;}
button.sort-item.checked .s-tick{opacity:1;}
.s-text{font-size:.95rem;color:var(--ink2);line-height:1.45;font-weight:400;transition:color .18s;}
button.sort-item.checked .s-text{color:var(--ink);font-weight:500;}

/* ── WISDOM ── */
.wisdom-block{background:var(--ink);border-radius:18px;padding:32px 26px;margin-top:16px;}
.wis-tag{font-size:.58rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--terra);margin-bottom:14px;}
.wis-text{font-family:'Lora',serif;font-size:1.05rem;font-style:italic;color:rgba(247,246,243,.88);line-height:1.85;}
.wis-text strong{font-style:normal;color:var(--warm);font-weight:500;}

/* ── RELEASE (keep / delegate / simplify / let go) ── */
.kdsl-list{display:flex;flex-direction:column;gap:0;}
.kdsl-group{padding:18px 0;border-bottom:1px solid var(--mist);}
.kdsl-group:first-child{padding-top:4px;}
.kdsl-group:last-child{border-bottom:none;padding-bottom:0;}
.kdsl-label{font-size:.95rem;color:var(--ink2);line-height:1.5;margin-bottom:11px;}
.kdsl-row{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}
button.kdsl-btn{
  padding:11px 4px;border:1.5px solid var(--mist-d);border-radius:22px;
  background:var(--warm);color:var(--ink3);
  font-size:.79rem;font-family:'DM Sans',sans-serif;font-weight:500;
  cursor:pointer;transition:all .18s;min-height:44px;text-align:center;
  -webkit-tap-highlight-color:transparent;
}
button.kdsl-btn:active{transform:scale(.97);}
@media(hover:hover){button.kdsl-btn:hover{border-color:var(--dc);color:var(--dc);}}
button.kdsl-btn.chosen{background:var(--dc);border-color:var(--dc);color:#fff;font-weight:600;}
@media(max-width:360px){.kdsl-row{grid-template-columns:repeat(2,1fr);}}

/* ── RECLAIM ── */
.reclaim-q{font-size:1rem;font-weight:600;color:var(--ink);line-height:1.55;margin-bottom:13px;}
.forward-section{margin-top:30px;padding-top:26px;border-top:1px solid var(--mist);}
.forward-label{font-size:.58rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--dc);margin-bottom:9px;transition:color .4s;}
.forward-q{font-size:.96rem;color:var(--ink2);line-height:1.7;margin-bottom:13px;}
.closing-line-card{margin-top:32px;background:var(--dc-l);border:1px solid var(--dc-m);border-radius:18px;padding:32px 24px;text-align:center;}
.cl-glyph{font-size:1rem;color:var(--dc);display:block;margin-bottom:14px;transition:color .4s;}
.cl-quote{font-family:'Lora',serif;font-size:1.06rem;font-style:italic;color:var(--ink);line-height:1.78;white-space:pre-line;}
.cl-attr{display:block;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);margin-top:14px;}

/* ── CLOSING SCREEN ── */
#sc-closing{padding:48px 24px 80px;}
.clo-in{max-width:560px;margin:0 auto;}
.clo-label{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);margin-bottom:12px;}
.clo-h{font-family:'Lora',serif;font-size:clamp(1.7rem,6vw,2.2rem);font-weight:400;color:var(--ink);line-height:1.2;margin-bottom:12px;}
.clo-sub{font-size:.95rem;color:var(--ink2);line-height:1.78;margin-bottom:32px;}
.clo-list{display:flex;flex-direction:column;gap:10px;margin-bottom:40px;}
.clo-item{background:var(--warm);border:1px solid var(--mist);border-radius:13px;padding:18px 18px;}
.clo-item-tag{font-size:.58rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--dc);margin-bottom:5px;transition:color .4s;}
.clo-item-text{font-size:.94rem;color:var(--ink);line-height:1.58;}
.clo-actions{display:flex;gap:10px;flex-wrap:wrap;}
button.clo-again{background:var(--ink);color:var(--cream);border:none;padding:15px 26px;border-radius:12px;font-size:.92rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.clo-again:hover{background:var(--dc);}}
button.clo-audit{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:15px 22px;border-radius:12px;font-size:.92rem;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s;min-height:52px;-webkit-tap-highlight-color:transparent;}
@media(hover:hover){button.clo-audit:hover{border-color:var(--ink);color:var(--ink);}}

@media(min-width:640px){
  .wc-in,.clo-in{padding:0;}
  .step-wrap{padding:32px 32px 110px;}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-in">
    <a class="tb-brand" href="/">Velani</a>
    <div class="tb-gauge"><div class="tb-fill" id="gauge-fill"></div></div>
    <div class="tb-pct" id="gauge-pct">0%</div>
  </div>
</div>

<!-- WELCOME -->
<div class="screen active" id="sc-welcome">
  <div class="wc-in">
    <div class="wc-label">The Velani Companion</div>
    <h1 class="wc-h">You're not here to do less.<br><em>You're here to spend yourself<br>on what's worth it.</em></h1>
    <p class="wc-sub">Choose the domain that's carrying your heaviest load. Four parts. One at a time. Always forward.</p>
    <div class="wc-promise">
      <strong>One promise, before anything</strong>
      <p>Go at your own pace. Take one part at a time. Skip what doesn't fit. Return whenever you like. There's more of you in here than the load has let you see.</p>
    </div>
    <div class="wc-pick-label">Choose your domain</div>
    <div class="domain-pick" id="domain-pick"></div>
  </div>
</div>

<!-- DOMAIN INTRO -->
<div class="screen" id="sc-dintro">
  <div class="di-hero" id="di-hero">
    <span class="di-hero-emoji" id="di-emoji"></span>
    <div class="di-hero-label" id="di-num"></div>
    <div class="di-hero-name" id="di-name"></div>
  </div>
  <div class="di-body-wrap">
    <div class="di-callout" id="di-callout"></div>
    <div class="di-nav">
      <button class="di-back" onclick="goWelcome()">&#8592; Choose another</button>
      <button class="di-start" id="di-start-btn" onclick="startSteps()">Begin &#8594;</button>
    </div>
  </div>
</div>

<!-- STEPS -->
<div class="screen" id="sc-step">
  <div class="step-wrap" id="step-wrap"></div>
</div>

<!-- Fixed nav — visible only during steps -->
<div class="step-nav" id="step-nav" style="display:none;">
  <div class="step-nav-in">
    <button class="sn-back" id="sn-back" onclick="prevStep()">&#8592; Back</button>
    <button class="sn-skip" onclick="skipStep()">Skip</button>
    <button class="sn-next" id="sn-next" onclick="nextStep()">Continue &#8594;</button>
  </div>
</div>

<!-- CLOSING -->
<div class="screen" id="sc-closing">
  <div class="clo-in">
    <div class="clo-label">Your session</div>
    <h2 class="clo-h">What you decided to carry differently.</h2>
    <p class="clo-sub">A record of this session — the weight you named, and the strength you're building in its place. Come back whenever the load feels heavy again.</p>
    <div class="clo-list" id="clo-list"></div>
    <div class="clo-actions">
      <button class="clo-again" onclick="goWelcome()">Start another domain</button>
      <button class="clo-audit" onclick="location.href='/audit'">Retake the audit</button>
    </div>
  </div>
</div>

<script is:inline>
var DOMAINS={
  connection:{
    key:'connection',emoji:'🤝',name:'Connection',bodyClass:'dom-connection',
    color:'#C4785A',num:'Part 2 · Home & Family',desc:'The people you hold, coordinate, and care for',
    intro:"This is the domain of everyone you carry — partner, children, parents, the people who turn to you. You love them; that was never the question. The question is whether carrying so much for them has cost you the energy to be fully present with them — and with yourself.",
    steps:[
      {type:'see',label:'FIRST · SEE IT CLEARLY',title:"What you're carrying here",
       body:"A quick, honest look — not to dwell, but to know what you're working with.",
       q:"What are you holding for the people in your life right now? The appointments, the worrying, the remembering. Empty it out — no need to organise it."},
      {type:'sort',label:'THEN · WHAT EARNS ITS PLACE',title:"What's worth your energy",
       body:"Some of this is genuinely yours and worth carrying. Some is draining you with no return for anyone. Mark what you suspect isn't actually yours to hold.",
       items:["Remembering things other capable adults could remember","Managing emotions that belong to someone else","Coordinating logistics others could own","Anticipating needs no one asked me to anticipate","Carrying worry that changes nothing by being carried"]},
      {type:'wisdom',label:'THE ORDER OF CARE, HERE',
       wisdom:"The order of care isn't about caring less for them. It's about this: the version of you that's depleted and resentful helps no one. When you keep some of your best for yourself, you show up <strong>more</strong> capable for the people you love — not less."},
      {type:'release',label:'RELEASE · FREE YOUR STRENGTH',title:"Put down what drains you",
       body:"For each thing, an honest choice. You're not abandoning anyone. You're freeing your strength for where it actually matters."},
      {type:'reclaim',label:'RECLAIM · FILL THE SPACE',title:"What will you grow toward?",
       body:"Making room is only half of it. The space you just cleared is for something. This is where capacity turns into aliveness.",
       rq:"With that weight redistributed — what kind of presence do you want to bring to the people who matter? What would 'showing up at your best' actually look like here?",
       fq:"One concrete move this week to be more present, not just less burdened:",
       line:"You love people best\nwhen you arrive whole —\nnot depleted."}
    ]
  },
  material:{
    key:'material',emoji:'💼',name:'Material',bodyClass:'dom-material',
    color:'#6B8FB5',num:'Part 3 · Work & Career',desc:'What you build, earn, and sustain in the world',
    intro:"This is the domain of work and ambition — the projects, the open loops, the mental tabs that follow you home. The goal isn't to want less or do less. It's to stop spending your sharpest energy on what doesn't matter, so you have it for the work that actually moves you forward.",
    steps:[
      {type:'see',label:'FIRST · SEE IT CLEARLY',title:"What you're carrying here",
       body:"A quick, honest look — not to dwell, but to know what you're working with.",
       q:"What unfinished work is living in your head right now? Every open loop — the email, the decision, the conversation you keep meaning to have."},
      {type:'sort',label:'THEN · WHAT EARNS ITS PLACE',title:"What's worth your energy",
       body:"Open loops drain the focus you need for your real ambitions. Mark the ones that are taking energy without earning it.",
       items:["Decisions I keep re-making because I never finalised them","Tasks that could be someone else's","Work I'm doing to avoid the work that matters more","Projects I'm carrying alone that were never only mine","Standards I'm holding that no one actually requires"]},
      {type:'wisdom',label:'THE ORDER OF CARE, HERE',
       wisdom:"You bring your sharpest self to everyone else's priorities and leave your own ambitions for 'someday.' But the most capable version of you protects energy for the work that's genuinely yours. That's not selfish — <strong>it's how you build something that lasts.</strong>"},
      {type:'release',label:'RELEASE · FREE YOUR STRENGTH',title:"Put down what drains you",
       body:"Each loop closed — even by deciding 'not now' — returns focus to what you're actually building."},
      {type:'reclaim',label:'RECLAIM · FILL THE SPACE',title:"What will you grow toward?",
       body:"Making room is only half of it. The space you just cleared is for something. This is where capacity turns into aliveness.",
