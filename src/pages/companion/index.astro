var STORE_KEY='velani_companion_v4';
var currentDomain=null,currentStep=0,responses={},gaugeVal=0;

function saveState(){
  try{localStorage.setItem(STORE_KEY,JSON.stringify({responses:responses,gaugeVal:gaugeVal,savedAt:Date.now()}));}catch(e){}
}
function loadState(){
  try{
    var raw=localStorage.getItem(STORE_KEY);
    if(raw){var d=JSON.parse(raw);if(d.responses)responses=d.responses;if(d.gaugeVal)gaugeVal=d.gaugeVal;}
  }catch(e){}
}

function updateGauge(){
  var el=document.getElementById('gauge-fill'),pe=document.getElementById('gauge-pct');
  if(el)el.style.width=gaugeVal+'%';
  if(pe)pe.textContent=Math.round(gaugeVal)+'%';
}

function show(id){
  var ss=document.querySelectorAll('.screen');
  for(var i=0;i<ss.length;i++)ss[i].classList.remove('active');
  document.getElementById(id).classList.add('active');
  var nav=document.getElementById('step-nav');
  if(nav)nav.style.display=(id==='sc-step'?'block':'none');
  window.scrollTo(0,0);
}

function setDomainTheme(d){
  document.body.className=d?d.bodyClass:'';
}

function getRecommendedDomain(){
  var p=new URLSearchParams(window.location.search);
  var dom=p.get('domain');if(dom&&DOMAINS[dom])return dom;
  var pat=p.get('pattern');
  if(!pat){try{pat=localStorage.getItem('velani_audit_pattern')||'';}catch(e){}}
  var dom2='';try{dom2=localStorage.getItem('velani_audit_domain')||'';}catch(e){}
  if(dom2&&DOMAINS[dom2])return dom2;
  var map={'success-without-self':'inner','endless-pour':'liveliness','running-on-empty':'liveliness','quiet-disappearance':'inner','holding-it-together':'connection','carrying-well':'inner'};
  if(pat&&map[pat])return map[pat];
  return null;
}

function goWelcome(){
  setDomainTheme(null);
  gaugeVal=0;updateGauge();
  show('sc-welcome');
}

function chooseDomain(key){
  currentDomain=DOMAINS[key];currentStep=0;
  var d=currentDomain;
  setDomainTheme(d);
  document.getElementById('di-emoji').textContent=d.emoji;
  document.getElementById('di-num').textContent=d.num;
  document.getElementById('di-name').textContent=d.name;
  document.getElementById('di-hero').style.background=d.color;
  document.getElementById('di-start-btn').style.background=d.color;
  var callout=document.getElementById('di-callout');
  callout.innerHTML='<p>'+d.intro+'</p>';
  callout.style.borderLeftColor=d.color;
  show('sc-dintro');
}

function startSteps(){currentStep=0;renderStep();show('sc-step');}

function prevStep(){
  if(currentStep>0){currentStep--;renderStep();window.scrollTo(0,0);}
  else{show('sc-dintro');}
}

function skipStep(){advanceStep();}
function nextStep(){saveCurrentStepResponse();advanceStep();}

function advanceStep(){
  if(!currentDomain)return;
  var steps=currentDomain.steps;
  if(currentStep<steps.length-1){
    currentStep++;
    gaugeVal=Math.round(currentStep/steps.length*100);
    updateGauge();saveState();
    renderStep();window.scrollTo(0,0);
  }else{
    gaugeVal=100;updateGauge();saveState();
    buildClosing();show('sc-closing');
  }
}

function saveCurrentStepResponse(){
  if(!currentDomain)return;
  var s=currentDomain.steps[currentStep];
  if(s.type==='see'){
    var ta=document.getElementById('rta-main');
    if(ta)responses[currentDomain.key+'_see']=ta.value;
  }else if(s.type==='reclaim'){
    var ta2=document.getElementById('rta-main');
    if(ta2)responses[currentDomain.key+'_reclaim']=ta2.value;
    var ta3=document.getElementById('rta-fwd');
    if(ta3)responses[currentDomain.key+'_fwd']=ta3.value;
  }
  saveState();
}

function renderStep(){
  if(!currentDomain)return;
  var steps=currentDomain.steps,s=steps[currentStep],total=steps.length;
  var wrap=document.getElementById('step-wrap');

  /* Header: "Inner  ·  Step 1 of 5" */
  var html='<div class="step-header">'
    +'<span class="step-domain-tag">'+currentDomain.name+'</span>'
    +'<span class="step-counter">Step '+(currentStep+1)+' of '+total+'</span>'
    +'</div>';

  /* Section label — Lora italic (CSS handles styling) */
  html+='<div class="step-sec-label">'+s.label+'</div>';

  /* Title — only render if defined (wisdom step has one now) */
  if(s.title){html+='<div class="step-title">'+s.title+'</div>';}

  /* Type-specific body */
  if(s.type==='see'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sv=responses[currentDomain.key+'_see']||'';
    html+='<div class="reflect-prompt">'+s.q+'</div>'
      +'<textarea class="reflect-area" id="rta-main" placeholder="Write as little or as much as feels right…" oninput="autoSave(\'see\')">'+esc(sv)+'</textarea>';

  }else if(s.type==='sort'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    html+='<div class="sort-list" id="sort-list">';
    for(var i=0;i<s.items.length;i++){
      var rk=currentDomain.key+'_sort_'+i;
      var ck=responses[rk]?' checked':'';
      html+='<button type="button" class="sort-item'+ck+'" onclick="toggleSort('+i+')">'
        +'<span class="s-box"><span class="s-tick">&#10003;</span></span>'
        +'<span class="s-text">'+s.items[i]+'</span>'
        +'</button>';
    }
    html+='</div>';
    var initChecked=0;for(var ci=0;ci<s.items.length;ci++){if(responses[currentDomain.key+'_sort_'+ci])initChecked++;}
    html+='<div style="font-size:.82rem;color:var(--ink3);margin-top:12px;font-style:italic;" id="sort-count">'+(initChecked>0?initChecked+' selected':'')+'</div>';
    html+='<div style="font-size:.84rem;color:var(--ink3);margin-top:18px;padding:16px 18px;background:var(--dc-l);border-radius:12px;line-height:1.7;">Notice what you selected. The next step explores something important: <strong style="color:var(--ink);">the order of care</strong>, and why your best energy often goes to the wrong places first.</div>';

  }else if(s.type==='wisdom'){
    /* No duplicate tag inside — label + title above already identify the step */
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    html+='<div class="wisdom-block">'
      +'<div class="wis-text">'+s.wisdom+'</div>'
      +'<p class="wisdom-continue">Use the Continue button below when you\'re ready.</p>'
      +'</div>'
      +'<div style="margin-top:24px;background:var(--warm);border:1px solid var(--mist);border-radius:14px;padding:22px;">'
        +'<div style="font-size:.88rem;font-weight:600;color:var(--ink);margin-bottom:14px;">Right now, who gets your best energy?</div>'
        +'<div style="display:flex;flex-direction:column;gap:8px;">'
          +'<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--cream);border-radius:10px;">'
            +'<span style="font-size:.9rem;color:var(--ink2);">Acquaintances &amp; obligations</span>'
            +'<span style="font-size:.82rem;font-weight:600;color:var(--terra);">Your best?</span>'
          +'</div>'
          +'<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--cream);border-radius:10px;">'
            +'<span style="font-size:.9rem;color:var(--ink2);">People you love</span>'
            +'<span style="font-size:.82rem;font-weight:600;color:var(--ink3);">The middle?</span>'
          +'</div>'
          +'<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--cream);border-radius:10px;">'
            +'<span style="font-size:.9rem;color:var(--ink2);">You</span>'
            +'<span style="font-size:.82rem;font-weight:600;color:var(--ink3);">The leftovers?</span>'
          +'</div>'
        +'</div>'
        +'<div style="font-size:.84rem;color:var(--sage);font-style:italic;margin-top:14px;font-family:\'Lora\',serif;">What if you reversed the order?</div>'
      +'</div>';

  }else if(s.type==='release'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sortItems=steps[1].items;
    var opts=['keep','delegate','simplify','let go'];
    html+='<div class="kdsl-list">';
    for(var j=0;j<sortItems.length;j++){
      var rk2=currentDomain.key+'_rel_'+j;
      var chosen=responses[rk2]||'';
      html+='<div class="kdsl-group"><div class="kdsl-label">'+sortItems[j]+'</div><div class="kdsl-row">';
      for(var oi=0;oi<opts.length;oi++){
        var o=opts[oi];
        var isCh=(chosen===o);
        html+='<button type="button" class="kdsl-btn'+(isCh?' chosen':'')+'" data-k="'+j+'" data-v="'+o+'" onclick="chooseKdsl(this)">'+o+'</button>';
      }
      html+='</div></div>';
    }
    html+='</div>';

  }else if(s.type==='reclaim'){
    if(s.body)html+='<div class="step-body"><p>'+s.body+'</p></div>';
    var sv2=responses[currentDomain.key+'_reclaim']||'';
    html+='<div class="reclaim-q">'+s.rq+'</div>'
      +'<textarea class="reflect-area" id="rta-main" style="min-height:240px;" placeholder="Write as little or as much as feels right…" oninput="autoSave(\'reclaim\')">'+esc(sv2)+'</textarea>';
    var sv3=responses[currentDomain.key+'_fwd']||'';
    html+='<div class="forward-section">'
      +'<div class="forward-label">Forward: one real move</div>'
      +'<div class="forward-q">'+s.fq+'</div>'
      +'<textarea class="reflect-area" id="rta-fwd" style="min-height:120px;" placeholder="One concrete move…" oninput="autoSaveFwd()">'+esc(sv3)+'</textarea>'
      +'</div>';
    html+='<div class="closing-line-card">'
      +'<span class="cl-glyph">&#10022;</span>'
      +'<div class="cl-quote">'+s.line+'</div>'
      +'<span class="cl-attr">A line to carry with you</span>'
      +'</div>';
  }

  wrap.innerHTML=html;

  /* Nav labels */
  var bk=document.getElementById('sn-back');
  if(bk)bk.textContent=(currentStep===0?'← Domain':'← Back');
  var nx=document.getElementById('sn-next');
  if(nx)nx.textContent=(currentStep===steps.length-1?'Finish →':'Continue →');
}

function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function autoSave(type){
  if(!currentDomain)return;
  var ta=document.getElementById('rta-main');
  if(ta)responses[currentDomain.key+'_'+type]=ta.value;
  saveState();
}
function autoSaveFwd(){
  if(!currentDomain)return;
  var ta=document.getElementById('rta-fwd');
  if(ta)responses[currentDomain.key+'_fwd']=ta.value;
  saveState();
}

function toggleSort(i){
  if(!currentDomain)return;
  var rk=currentDomain.key+'_sort_'+i;
  responses[rk]=responses[rk]?false:true;
  var items=document.querySelectorAll('.sort-item');
  if(items[i])items[i].classList.toggle('checked',responses[rk]===true);
  var checked=document.querySelectorAll('.sort-item.checked').length;
  var counter=document.getElementById('sort-count');
  if(counter)counter.textContent=checked>0?checked+' selected':'';
  saveState();
}

function chooseKdsl(btn){
  if(!currentDomain)return;
  var k=btn.getAttribute('data-k');
  var v=btn.getAttribute('data-v');
  if(k===null||v===null)return;
  responses[currentDomain.key+'_rel_'+k]=v;
  var grp=document.querySelectorAll('button[data-k="'+k+'"]');
  for(var i=0;i<grp.length;i++)grp[i].classList.remove('chosen');
  btn.classList.add('chosen');
  saveState();
}

function buildClosing(){
  if(!currentDomain)return;
  var steps=currentDomain.steps,d=currentDomain;
  var list=document.getElementById('clo-list');
  var html='';

  var see=responses[d.key+'_see'];
  if(see&&see.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">What you named</div><div class="clo-item-text">'+esc(see)+'</div></div>';
  }

  var sortItems=steps[1].items;
  var checkedItems=[];
  for(var i=0;i<sortItems.length;i++){if(responses[d.key+'_sort_'+i])checkedItems.push(sortItems[i]);}
  if(checkedItems.length){
    html+='<div class="clo-item"><div class="clo-item-tag">What you recognised as draining you</div><div class="clo-item-text">'+checkedItems.join('<br>')+'</div></div>';
  }

  var decByGroup={};
  for(var j=0;j<sortItems.length;j++){
    var v=responses[d.key+'_rel_'+j];
    if(v){
      if(!decByGroup[v])decByGroup[v]=[];
      decByGroup[v].push(sortItems[j]);
    }
  }
  var decOrder=['keep','delegate','simplify','let go'];
  for(var di=0;di<decOrder.length;di++){
    var dk=decOrder[di];
    if(decByGroup[dk]&&decByGroup[dk].length){
      var label=dk.charAt(0).toUpperCase()+dk.slice(1);
      html+='<div class="clo-item"><div class="clo-item-tag">'+label+'</div><div class="clo-item-text">'+decByGroup[dk].join('<br>')+'</div></div>';
    }
  }

  var rec=responses[d.key+'_reclaim'];
  if(rec&&rec.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">What you\'re growing toward</div><div class="clo-item-text">'+esc(rec)+'</div></div>';
  }
  var fwd=responses[d.key+'_fwd'];
  if(fwd&&fwd.trim()){
    html+='<div class="clo-item"><div class="clo-item-tag">Your one real move</div><div class="clo-item-text">'+esc(fwd)+'</div></div>';
  }

  if(!html){
    html='<div class="clo-item"><div class="clo-item-text" style="color:var(--ink3);font-style:italic;">Your choices and reflections will appear here as you complete each step.</div></div>';
  }
  list.innerHTML=html;

  /* Mark this domain complete in localStorage */
  try{
    var compKey='velani_companion_done';
    var done=JSON.parse(localStorage.getItem(compKey)||'{}');
    done[d.key]={line:d.steps[4].line||'',completedAt:Date.now()};
    localStorage.setItem(compKey,JSON.stringify(done));
  }catch(e){}
}

function emailSession(){
  var em=document.getElementById('clo-email');
  if(!em||!em.value||em.value.indexOf('@')<0){
    em&&em.focus();return;
  }
  var tags=['companion-session'];
  if(currentDomain){
    tags.push('companion-domain-'+currentDomain.key);
    var steps=currentDomain.steps;
    for(var j=0;j<steps[1].items.length;j++){
      var v=responses[currentDomain.key+'_rel_'+j];
      if(v)tags.push('decision-'+v.replace(/\s/g,'-'));
    }
  }
  fetch('https://velani-subscribe.velani-app.workers.dev',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({email:em.value,tags:tags})
  }).then(function(){
    var ok=document.getElementById('clo-email-ok');
    if(ok)ok.style.display='block';
    em.style.display='none';
    var btn=document.querySelector('.clo-email-btn');
    if(btn)btn.style.display='none';
  }).catch(function(){
    var ok=document.getElementById('clo-email-ok');
    if(ok){ok.textContent='Something went wrong. Please try again.';ok.style.display='block';}
  });
}

function copySession(){
  var items=document.querySelectorAll('.clo-item');
  var text='My Velani Companion Session\n\n';
  for(var i=0;i<items.length;i++){
    var tag=items[i].querySelector('.clo-item-tag');
    var val=items[i].querySelector('.clo-item-text');
    if(tag&&val)text+=tag.textContent+': '+val.innerText+'\n\n';
  }
  if(navigator.clipboard){
    navigator.clipboard.writeText(text).then(function(){alert('Copied to clipboard.');}).catch(function(){alert('Please copy manually.');});
  }else{alert('Clipboard not available in this browser.');}
}

/* Init */
loadState();updateGauge();

(function(){
  try{
    var raw=localStorage.getItem(STORE_KEY);
    if(raw){
      var d=JSON.parse(raw);
      if(d.responses&&Object.keys(d.responses).length>0&&d.savedAt){
        if(Date.now()-d.savedAt<7*24*60*60*1000){
          var bar=document.createElement('div');
          bar.style.cssText='background:var(--dc-l);border:1px solid var(--dc-m);border-radius:12px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;';
          bar.innerHTML='<span style="font-size:.88rem;color:var(--ink2);">You have a saved session.</span>'
            +'<div style="display:flex;gap:8px;">'
            +'<button style="background:var(--ink);color:#fff;border:none;padding:10px 18px;border-radius:10px;font-size:.84rem;font-weight:600;cursor:pointer;font-family:\'DM Sans\',sans-serif;" onclick="this.parentElement.parentElement.remove()">Continue</button>'
            +'<button style="background:none;border:1.5px solid var(--mist-d);color:var(--ink3);padding:10px 14px;border-radius:10px;font-size:.84rem;cursor:pointer;font-family:\'DM Sans\',sans-serif;" onclick="localStorage.removeItem(\''+STORE_KEY+'\');responses={};this.parentElement.parentElement.remove();">Start fresh</button>'
            +'</div>';
          var wc=document.querySelector('.wc-in');
          if(wc)wc.insertBefore(bar,wc.firstChild);
        }
      }
    }
  }catch(e){}
})();

(function(){
  var rec=getRecommendedDomain();
  var pick=document.getElementById('domain-pick');
  var order=['inner','connection','material','liveliness'];
  var done={};
  try{done=JSON.parse(localStorage.getItem('velani_companion_done')||'{}');}catch(e){}
  order.forEach(function(k){
    var d=DOMAINS[k];
    var isRec=(k===rec);
    var isDone=!!done[k];
    var card=document.createElement('button');
    card.type='button';
    card.className='dp-card'+(isRec&&!isDone?' rec':'');
    if(isDone){card.style.cssText='opacity:.75;border-color:var(--sage);background:rgba(91,140,122,.06);';}
    card.innerHTML=
      '<span class="dp-emoji">'+d.emoji+'</span>'
      +'<span class="dp-sub">'+d.num+'</span>'
      +'<span class="dp-name">'+d.desc+'</span>'
      +'<span class="dp-desc">'+d.subdesc+'</span>'
      +(isDone?'<span class="dp-rec-tag" style="color:var(--sage);">&#10003; Completed. Return anytime</span>'
        :isRec?'<span class="dp-rec-tag">&#9733; Your heaviest. Start here</span>':'');
    card.onclick=function(){chooseDomain(k);};
    pick.appendChild(card);
  });
})();
</script>
</body>
</html>
