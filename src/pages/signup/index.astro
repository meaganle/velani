---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Join Velani"
  description="A little more clarity each week. Weekly thoughtful letters, practical tools, and gentle systems for clearer days."
  currentPath="/signup"
>
<style>
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem 5rem;
    position: relative;
    z-index: 1;
  }
  .wrap {
    width: 100%;
    max-width: 440px;
    animation: rise .75s cubic-bezier(.22,1,.36,1) forwards;
  }
  @keyframes rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eyebrow {
    font-size: .62rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 500;
    margin-bottom: .8rem;
  }
  .headline {
    font-family: var(--display);
    font-size: clamp(1.85rem, 4vw, 2.3rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: .7rem;
    letter-spacing: -.015em;
  }
  .headline em { font-style: italic; color: var(--sage); }
  .subhead {
    font-size: .9rem;
    color: var(--ink2);
    line-height: 1.75;
    margin-bottom: 2rem;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2.2rem;
    box-shadow: 0 4px 24px rgba(26,29,46,.05);
  }
  .field-row {
    display: flex;
    gap: .6rem;
    margin-bottom: .5rem;
  }
  .field-email {
    flex: 1;
    min-width: 0;
    background: var(--bg);
    border: 1.5px solid var(--border2);
    border-radius: 10px;
    padding: .85rem 1rem;
    font-family: var(--body);
    font-size: .88rem;
    color: var(--ink);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .field-email:focus {
    border-color: var(--sage);
    box-shadow: 0 0 0 3px var(--sage-gl);
  }
  .field-email::placeholder { color: var(--ink3); }
  .btn-submit {
    background: var(--ink);
    color: var(--bg);
    font-family: var(--body);
    font-size: .78rem;
    font-weight: 500;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: .85rem 1.3rem;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background .2s, transform .15s;
  }
  .btn-submit:hover { background: var(--sage2, #3D6B59); transform: translateY(-1px); }
  .btn-submit:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .field-error {
    font-size: .7rem;
    color: var(--terra);
    min-height: .9rem;
    margin-bottom: .4rem;
    display: block;
  }
  .consent-note {
    font-size: .67rem;
    color: var(--ink3);
    line-height: 1.6;
  }
  .consent-note a { color: var(--sage); text-decoration: none; }

  /* What you'll receive */
  .what {
    border-top: 1px solid var(--border);
    margin-top: 1.4rem;
    padding-top: 1.2rem;
  }
  .what-label {
    font-size: .6rem;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--ink3);
    font-weight: 500;
    margin-bottom: .65rem;
  }
  .what-item {
    display: flex;
    align-items: flex-start;
    gap: .55rem;
    font-size: .82rem;
    color: var(--ink2);
    line-height: 1.65;
    margin-bottom: .4rem;
  }
  .what-item:last-child { margin-bottom: 0; }
  .check { color: var(--sage); flex-shrink: 0; margin-top: .1em; font-size: .8rem; }

  /* Success */
  .success { display: none; text-align: center; padding: .5rem 0; }
  .success.visible { display: block; }
  .success-mark {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--sage-gl);
    border: 1.5px solid rgba(91,140,122,.25);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .success-title {
    font-family: var(--display);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--ink);
    margin-bottom: .4rem;
  }
  .success-title em { font-style: italic; color: var(--sage); }
  .success-sub { font-size: .83rem; color: var(--ink3); line-height: 1.75; }

  .field-message {
    display: block;
    font-size: .75rem;
    color: var(--sage);
    margin-top: .5rem;
    min-height: 1rem;
  }

  @media (max-width: 480px) {
    main { padding: 2.5rem 1.2rem 4rem; }
    .card { padding: 1.6rem 1.4rem; }
    .field-row { flex-direction: column; }
    .btn-submit { width: 100%; padding: .9rem; }
  }
</style>

<main>
  <div class="wrap">

    <div class="eyebrow">Join Velani</div>
    <h1 class="headline">A little more<br><em>clarity each week.</em></h1>
    <p class="subhead">
      Weekly thoughtful letters, practical tools, and gentle systems for clearer days.
    </p>

    <!-- Form -->
    <div class="card" id="form-state">
      <div class="field-row">
        <input type="email" id="su-email" class="field-email" placeholder="your@email.com" autocomplete="email">
        <button class="btn-submit" id="su-btn" onclick="window.handleSignup()">Join now</button>
      </div>
      <span class="field-error" id="su-error"></span>
      <p class="consent-note">
        By joining, you agree to receive occasional Velani emails.
        <a href="/privacy" target="_blank">Privacy policy</a>.
      </p>
      <span class="field-message" id="su-message"></span>

      <div class="what">
        <div class="what-label">What you'll receive</div>
        <div class="what-item"><span class="check">✓</span><span><strong>Every Sunday</strong> — a thoughtful letter to reset, reflect, and move into the week with more clarity.</span></div>
        <div class="what-item"><span class="check">✓</span><span><strong>Occasionally</strong> — simple tools, templates, and quiet encouragement.</span></div>
        <div class="what-item"><span class="check">✓</span><span><strong>Always</strong> — calm support, no pressure, no noise.</span></div>
      </div>
    </div>

    <!-- Success -->
    <div class="card success" id="success-state">
      <div class="success-mark">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M5 12.5L10 17.5L19 7" stroke="#5B8C7A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="success-title">You're in.<br><em>Check your inbox.</em></div>
      <p class="success-sub">Confirm your email to complete signup.<br>Your first letter arrives Sunday.</p>
    </div>

  </div>
</main>

<script>
  window.handleSignup = function() {
    const email   = document.getElementById('su-email').value.trim();
    const errorEl = document.getElementById('su-error');
    const btn     = document.getElementById('su-btn');
    errorEl.textContent = '';
    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.';
      document.getElementById('su-email').style.borderColor = '#B86A43';
      return;
    }
    document.getElementById('su-email').style.borderColor = 'rgba(26,29,46,.14)';
    btn.disabled    = true;
    btn.textContent = 'Sending…';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    })
    .then(() => ok()).catch(() => ok());
    function ok() {
      document.getElementById('form-state').style.display = 'none';
      document.getElementById('success-state').classList.add('visible');
    }
  };
</script>

</Base>
