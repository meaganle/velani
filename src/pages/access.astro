---
import Base from '../layouts/Base.astro';
---
<Base
  title="Welcome — Velani"
  description="Open Velani. Choose your format and begin."
  currentPath="/access"
>
  <span slot="nav-right" class="nav-help">
    Need help? <a href="mailto:hello@velani.app">hello@velani.app</a>
  </span>

<style>
.nav-help { font-size: .72rem; color: var(--ink3); }
.nav-help a { color: var(--sage); text-decoration: none; }

main {
  flex: 1;
  display: flex; align-items: flex-start; justify-content: center;
  padding: 4rem 1.5rem 5rem;
  position: relative; z-index: 1;
}

.container {
  width: 100%; max-width: 580px;
  animation: rise .75s cubic-bezier(.22,1,.36,1) forwards;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.welcome-mark {
  width: 50px; height: 50px; border-radius: 50%;
  background: var(--sage-gl);
  border: 1.5px solid rgba(91,140,122,.22);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.6rem;
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(91,140,122,.15); }
  50%      { box-shadow: 0 0 0 10px rgba(91,140,122,0); }
}
.eyebrow {
  font-size: .62rem; letter-spacing: .2em; text-transform: uppercase;
  color: var(--terra); font-weight: 500; margin-bottom: .8rem;
}
.page-title {
  font-family: var(--display);
  font-size: 2rem; font-weight: 300;
  line-height: 1.1; color: var(--ink);
  margin-bottom: .7rem; letter-spacing: -.015em;
}
.page-title em { font-style: italic; color: var(--sage); }
.page-sub {
  font-size: .9rem; color: var(--ink3); line-height: 1.75;
  margin-bottom: 2.2rem;
}

.notion-primary {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--ink); color: var(--bg);
  border-radius: 14px; padding: 1.4rem 1.8rem;
  text-decoration: none; margin-bottom: .6rem;
  transition: background .2s, transform .15s;
  border: none; cursor: pointer; width: 100%;
}
.notion-primary:hover { background: var(--sage2); transform: translateY(-1px); }
.notion-left { display: flex; align-items: center; gap: 1rem; }
.notion-icon {
  width: 38px; height: 38px; border-radius: 9px;
  background: rgba(247,246,243,.12);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.notion-label { font-size: .7rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: rgba(247,246,243,.6); margin-bottom: .15rem; }
.notion-name { font-family: var(--display); font-size: 1.05rem; font-weight: 300; color: var(--bg); }
.notion-badge {
  font-size: .6rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  color: var(--sage); background: rgba(91,140,122,.2);
  border: 1px solid rgba(91,140,122,.3);
  padding: .25rem .7rem; border-radius: 100px;
}

.alt-label {
  font-size: .68rem; color: var(--ink3);
  text-align: center; margin: .5rem 0 .8rem;
  letter-spacing: .04em;
}
.alt-formats {
  display: grid; grid-template-columns: 1fr 1fr; gap: .7rem;
  margin-bottom: 2rem;
}
.alt-card {
  display: flex; align-items: center; gap: .8rem;
  background: var(--surface);
  border: 1.5px solid var(--border2);
  border-radius: 12px; padding: .9rem 1.1rem;
  text-decoration: none; color: var(--ink2);
  font-size: .85rem; font-weight: 400;
  transition: border-color .2s, color .2s;
}
.alt-card:hover { border-color: var(--sage); color: var(--ink); }
.alt-icon {
  width: 30px; height: 30px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.alt-icon.gdoc { background: rgba(66,133,244,.1); }
.alt-icon.pdf  { background: rgba(184,106,67,.1); }
.alt-card-name { font-size: .82rem; font-weight: 500; color: var(--ink); display: block; }
.alt-card-desc { font-size: .7rem; color: var(--ink3); display: block; }

.section-divider { height: 1px; background: var(--border); margin: 1.8rem 0; }

.next-label {
  font-size: .62rem; letter-spacing: .18em; text-transform: uppercase;
  color: var(--ink3); font-weight: 500; margin-bottom: 1rem;
}
.steps {
  display: flex; flex-direction: column; gap: .75rem;
  margin-bottom: 1.8rem;
}
.step {
  display: flex; align-items: flex-start; gap: .9rem;
  font-size: .85rem; color: var(--ink2); line-height: 1.6;
}
.step-num {
  font-family: var(--display);
  font-size: .95rem; font-weight: 300; font-style: italic;
  color: var(--sage); flex-shrink: 0;
  min-width: 1.2rem; line-height: 1.6;
}
.step strong { font-weight: 500; color: var(--ink); }

.closing {
  font-family: var(--display);
  font-size: .92rem; font-style: italic; font-weight: 300;
  color: var(--ink3); line-height: 1.8; text-align: center;
}

@media (max-width: 540px) {
  main { padding: 2.5rem 1.2rem 4rem; }
  .alt-formats { grid-template-columns: 1fr; }
  .page-title { font-size: 1.75rem; }
}
</style>

<main>
  <div class="container">

    <div class="welcome-mark">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 12.5L10 17.5L19 7" stroke="#5B8C7A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <div class="eyebrow">You're in</div>
    <h1 class="page-title">Velani is <em>ready.</em></h1>
    <p class="page-sub">Notion gives you the best experience — duplicate everything to your own workspace in one click. Or choose another format below.</p>

    <a class="notion-primary" href="https://velani.notion.site/velanilite" target="_blank" rel="noopener">
      <div class="notion-left">
        <div class="notion-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="3" width="18" height="18" rx="3" fill="rgba(247,246,243,.15)"/>
            <path d="M7 7h3.5l6.5 8.5V17h-3.5L7 8.5V7z" fill="#F7F6F3"/>
            <path d="M7 7v10M17 7v10" stroke="#F7F6F3" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <div class="notion-label">Recommended</div>
          <div class="notion-name">Open in Notion</div>
        </div>
      </div>
      <div class="notion-badge">Best experience</div>
    </a>

    <p class="alt-label">Prefer another format?</p>

    <div class="alt-formats">
      <a class="alt-card" href="https://drive.google.com/drive/folders/1MDvYyN_4fQOKDjnXI8wpwUluicc8MwjS?usp=drive_link" target="_blank" rel="noopener">
        <div class="alt-icon gdoc">
          <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
            <rect x=".5" y=".5" width="15" height="19" rx="1.5" stroke="#4285F4" stroke-width="1" fill="rgba(66,133,244,.06)"/>
            <path d="M3 7h10M3 10h10M3 13h6" stroke="#4285F4" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <span class="alt-card-name">Google Doc</span>
          <span class="alt-card-desc">Works everywhere</span>
        </div>
      </a>
      <a class="alt-card" href="https://drive.google.com/drive/folders/1nQEnpV6xb3mFndp9OzwliQEyW-8mPkN2?usp=drive_link" target="_blank" rel="noopener">
        <div class="alt-icon pdf">
          <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
            <rect x=".5" y=".5" width="15" height="19" rx="1.5" stroke="#B86A43" stroke-width="1" fill="rgba(184,106,67,.06)"/>
            <text x="2.5" y="13" font-family="DM Sans, sans-serif" font-size="6" font-weight="600" fill="#B86A43">PDF</text>
          </svg>
        </div>
        <div>
          <span class="alt-card-name">PDF</span>
          <span class="alt-card-desc">Print &amp; keep beside you</span>
        </div>
      </a>
    </div>

    <div class="section-divider"></div>

    <div class="next-label">Once you're inside Notion</div>
    <div class="steps">
      <div class="step">
        <span class="step-num">1.</span>
        <span><strong>Hit Duplicate</strong> in the top right — all pages copy to your Notion in one click.</span>
      </div>
      <div class="step">
        <span class="step-num">2.</span>
        <span><strong>Open Today.</strong> That's where everything starts.</span>
      </div>
      <div class="step">
        <span class="step-num">3.</span>
        <span><strong>Choose one move</strong> and log one Quiet Win. That's the whole system working.</span>
      </div>
      <div class="step">
        <span class="step-num">4.</span>
        <span><strong>Set tomorrow's move.</strong> One sentence tonight means a clearer morning.</span>
      </div>
    </div>

    <div class="section-divider"></div>

    <p class="closing">One clear move at a time.<br>A different life over time.</p>

  </div>
</main>

<script is:inline>
function trackEvent(eventName, eventData) {
  if (window.plausible) {
    window.plausible(eventName, { props: eventData || {} });
  }
}
document.addEventListener('DOMContentLoaded', function() {
  trackEvent('access_page_viewed');
  const notionLink = document.querySelector('a[href*="notion.site"]');
  if (notionLink) {
    notionLink.addEventListener('click', function() {
      trackEvent('notion_opened');
    });
  }
});
</script>

</Base>
