---
import Base from '../../layouts/Base.astro';

const allReads = await Astro.glob('../../content/library/*.md');
const sorted = allReads
  .filter(r => !r.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));

function live(slug) {
  return sorted.filter(r => r.frontmatter.category === slug);
}

const categories = [
  { slug: 'start-here',    label: 'Start Here',      featured: true,  desc: 'New? Begin here.' },
  { slug: 'calmer-days',   label: 'Calmer Days',      featured: true,  desc: 'When life feels heavy.' },
  { slug: 'carrying-less', label: 'Carrying Less',    featured: false, desc: 'The invisible load.' },
  { slug: 'rhythm',        label: 'Gentle Rhythms',   featured: false, desc: 'Morning, evening, weekly.' },
  { slug: 'quiet-wins',    label: 'Quiet Wins',       featured: false, desc: 'Small progress matters.' },
  { slug: 'making-room',   label: 'Making Room',      featured: false, desc: 'Space for yourself.' },
  { slug: 'wisdom-cards',  label: 'One Idea',         featured: false, desc: 'Short and memorable.' },
  { slug: 'velani-letter', label: 'From the Letter',  featured: false, desc: 'Longer reads.' },
];

const placeholders = {
  'start-here': [
    { title: 'What matters today?',           desc: 'The one question that cuts through everything else.',        time: '2 min' },
    { title: 'One meaningful move',           desc: 'Why one clear thing beats a full list every time.',         time: '3 min' },
    { title: 'Weekly reset',                  desc: 'A slow Sunday ritual that actually works.',                  time: '5 min' },
    { title: 'The invisible load',            desc: 'What\'s making you tired — it\'s not on your list.',        time: '4 min' },
  ],
  'calmer-days': [
    { title: 'When life feels heavy',         desc: 'You don\'t need a system right now. You need this first.',  time: '3 min' },
    { title: 'Make tomorrow easier',          desc: 'Small things tonight that change how the morning feels.',   time: '2 min' },
    { title: 'What would 10% lighter feel like?', desc: 'A gentler question for hard days.',                    time: '2 min' },
  ],
  'carrying-less': [
    { title: 'Why you\'re exhausted before noon', desc: 'It\'s not laziness. It\'s the invisible decisions.',   time: '4 min' },
    { title: 'The mental load nobody talks about', desc: 'Naming the weight is the first step to setting it down.', time: '4 min' },
    { title: 'Simplifying what you carry',    desc: 'Not everything deserves equal space in your mind.',         time: '3 min' },
  ],
  'rhythm': [
    { title: 'A morning that actually works', desc: 'Not a 5am routine. A gentle rhythm that fits real life.',   time: '4 min' },
    { title: 'The evening reset',             desc: 'How to close the day without carrying it into tomorrow.',   time: '3 min' },
    { title: 'Sustainable over optimal',      desc: 'Consistency built gently lasts longer than systems built fast.', time: '3 min' },
  ],
  'quiet-wins': [
    { title: 'The things nobody clapped for', desc: 'A space to notice what you did well this week.',            time: '2 min' },
    { title: 'Small progress counts',         desc: 'Why the quiet moves matter more than you\'re giving them credit for.', time: '3 min' },
  ],
  'making-room': [
    { title: 'When did you stop being on your own list?', desc: 'A gentle question worth sitting with.',         time: '3 min' },
    { title: 'Rest is not a reward',          desc: 'On giving yourself permission before you\'ve earned it.',   time: '3 min' },
    { title: 'Possibility and the daily reset', desc: 'How small space creates unexpected room.',                time: '4 min' },
  ],
  'wisdom-cards': [
    { title: 'On doing less, better',         desc: 'Greg McKeown on essentialism.',                             time: '2 min' },
    { title: 'On building identity slowly',   desc: 'James Clear on why small habits compound quietly.',         time: '2 min' },
  ],
  'velani-letter': [
    { title: 'The system nobody builds',      desc: 'On why the most important architecture in your life goes undesigned.', time: '4 min' },
    { title: 'One clear move at a time',      desc: 'A different philosophy on what a good day actually requires.', time: '3 min' },
  ],
};
---
<Base
  title="Library"
  description="Short reads for women who want to carry less and feel more like themselves."
  currentPath="/library"
>
<style>
  main { flex: 1; }

  /* ── Controls ── */
  .lib-controls {
    display: flex; align-items: center;
    gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap;
  }

  .search-box { position: relative; flex-shrink: 0; }
  .search-icon {
    position: absolute; left: .9rem; top: 50%;
    transform: translateY(-50%); color: var(--ink3); pointer-events: none;
  }
  .search-input {
    width: 260px; background: var(--surface);
    border: 1.5px solid var(--border2); border-radius: 10px;
    padding: .65rem 2.2rem .65rem 2.4rem;
    font-family: var(--body); font-size: .83rem; color: var(--ink);
    outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .search-input:focus { border-color: var(--sage); box-shadow: 0 0 0 3px var(--sage-gl); }
  .search-input::placeholder { color: var(--ink3); }
  .search-clear {
    position: absolute; right: .7rem; top: 50%;
    transform: translateY(-50%); background: none; border: none;
    color: var(--ink3); cursor: pointer; font-size: .65rem;
    display: none; width: 16px; height: 16px;
    display: none; align-items: center; justify-content: center;
  }
  .search-clear.visible { display: flex; }

  .cat-pills { display: flex; flex-wrap: wrap; gap: .35rem; flex: 1; }
  .cat-pill {
    font-size: .68rem; color: var(--ink3);
    background: var(--surface); border: 1.5px solid var(--border2);
    border-radius: 100px; padding: .3rem .9rem;
    cursor: pointer; transition: all .15s; white-space: nowrap;
    font-family: var(--body); display: inline-flex; align-items: center; gap: .35rem;
    letter-spacing: .02em;
  }
  .cat-pill:hover { border-color: var(--sage); color: var(--ink); }
  .cat-pill.active { background: var(--ink); border-color: var(--ink); color: var(--bg); }
  .cat-pill.coming { opacity: .4; cursor: default; }
  .cat-pill .pill-featured {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0;
  }
  .cat-pill.active .pill-featured { background: var(--bg); }
  .pill-soon {
    font-size: .54rem; border: 1px solid currentColor;
    border-radius: 3px; padding: .05rem .28rem; opacity: .7;
    letter-spacing: .06em; text-transform: uppercase;
  }

  .cat-mobile { display: none; }
  .cat-toggle-btn {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; background: var(--surface);
    border: 1.5px solid var(--border2); border-radius: 10px;
    padding: .65rem 1rem; font-family: var(--body);
    font-size: .8rem; color: var(--ink2); cursor: pointer; margin-bottom: .5rem;
  }
  .cat-caret { font-size: .6rem; color: var(--ink3); transition: transform .2s; }
  .cat-mobile.open .cat-caret { transform: rotate(180deg); }
  .cat-mobile-pills { display: none; flex-wrap: wrap; gap: .35rem; }
  .cat-mobile.open .cat-mobile-pills { display: flex; }

  .results-note { font-size: .72rem; color: var(--ink3); margin-bottom: 1rem; min-height: 1rem; }
  .no-results { display: none; padding: 3rem 0; }
  .no-results.visible { display: block; }
  .no-results p { font-family: var(--display); font-size: .9rem; font-style: italic; color: var(--ink3); line-height: 1.8; }

  /* ── Content ── */
  .lib-content { padding-bottom: 6rem; position: relative; z-index: 1; }
  .lib-inner { max-width: 760px; }

  .cat-section { margin-bottom: 3rem; }
  .cat-head {
    display: flex; align-items: center;
    justify-content: space-between; gap: 1rem;
    padding-bottom: .7rem; margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cat-head-left { display: flex; align-items: baseline; gap: .7rem; }
  .cat-name {
    font-family: var(--display); font-size: .95rem;
    font-weight: 400; color: var(--ink);
  }
  .cat-desc {
    font-size: .7rem; color: var(--ink3);
    font-style: italic; font-family: var(--display);
  }
  .cat-featured-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0;
    margin-bottom: .1rem;
  }
  .cat-meta {
    font-size: .65rem; color: var(--ink3);
    font-style: italic; font-family: var(--display);
    white-space: nowrap; margin-left: auto;
  }
  .cat-meta.soon {
    font-style: normal; font-family: var(--body);
    font-size: .58rem; letter-spacing: .08em;
    text-transform: uppercase; color: var(--terra);
  }

  .reads { display: flex; flex-direction: column; gap: .45rem; }
  .read-row {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 1.5rem;
    padding: 1rem 1.3rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; text-decoration: none;
    transition: box-shadow .15s, transform .12s, border-color .15s; cursor: pointer;
  }
  .read-row:not(.placeholder):hover {
    box-shadow: 0 2px 20px rgba(26,29,46,.06);
    transform: translateY(-1px); border-color: var(--border2);
  }
  .read-row.placeholder { opacity: .45; pointer-events: none; }
  .read-body { flex: 1; min-width: 0; }
  .read-title {
    font-family: var(--display); font-size: .92rem;
    font-weight: 400; color: var(--ink);
    line-height: 1.3; margin-bottom: .2rem;
  }
  .read-desc { font-size: .77rem; color: var(--ink3); line-height: 1.55; }
  .read-time {
    font-size: .68rem; color: var(--ink3);
    font-family: var(--display); font-style: italic;
    white-space: nowrap; flex-shrink: 0;
  }

  /* ── Nudge / signup ── */
  .lib-nudge {
    background: var(--surface);
    border: 1px solid rgba(91,140,122,.2);
    border-radius: 16px; padding: 2.2rem 2.4rem;
    margin-top: 1rem; max-width: 760px;
    display: grid; grid-template-columns: 1fr auto;
    gap: 2.5rem; align-items: center;
  }
  .lib-nudge-left {}
  .lib-nudge-eyebrow {
    font-size: .58rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--terra); font-weight: 600; margin-bottom: .5rem;
  }
  .lib-nudge-title {
    font-family: var(--display); font-size: 1.05rem;
    font-weight: 300; color: var(--ink); margin-bottom: .3rem;
    line-height: 1.3;
  }
  .lib-nudge-title em { font-style: italic; color: var(--sage); }
  .lib-nudge p { font-size: .82rem; color: var(--ink3); line-height: 1.65; }
  .lib-nudge-form { min-width: 280px; }

  @media (max-width: 900px) {
    .cat-pills { display: none; }
    .cat-mobile { display: block; width: 100%; }
    .search-input { width: 100%; }
    .lib-controls { flex-direction: column; align-items: stretch; }
    .search-box { width: 100%; }
    .lib-nudge { grid-template-columns: 1fr; gap: 1.5rem; }
    .lib-nudge-form { min-width: unset; }
  }
</style>

<main>
<div class="page-wrap">

  <div class="page-hero">
    <div class="eyebrow">Library</div>
    <h1 class="page-title">Reads for women<br>who want to <em>carry less.</em></h1>
    <p class="page-subtitle">
      Short, practical pieces on making space for yourself — in your day, your mind, and your life.
      Return whenever you need it.
    </p>
  </div>

  <!-- Controls -->
  <div class="lib-controls">
    <div class="search-box">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
        <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input type="text" id="lib-search" class="search-input" placeholder="What do you need today?" autocomplete="off">
      <button class="search-clear" id="search-clear" aria-label="Clear">✕</button>
    </div>
    <div class="cat-pills" id="cat-pills-desktop">
      <button class="cat-pill active" data-cat="all">All</button>
      {categories.map(cat => {
        const has = live(cat.slug).length > 0;
        return (
          <button class={`cat-pill${!has ? ' coming' : ''}`} data-cat={cat.slug}>
            {cat.featured && <span class="pill-featured"></span>}
            {cat.label}
            {!has && <span class="pill-soon">soon</span>}
          </button>
        );
      })}
    </div>
    <div class="cat-mobile" id="cat-mobile">
      <button class="cat-toggle-btn" onclick="window.toggleMobileCat()">
        <span>Browse by topic</span><span class="cat-caret">▾</span>
      </button>
      <div class="cat-mobile-pills">
        <button class="cat-pill active" data-cat="all">All</button>
        {categories.map(cat => {
          const has = live(cat.slug).length > 0;
          return (
            <button class={`cat-pill${!has ? ' coming' : ''}`} data-cat={cat.slug}>
              {cat.featured && <span class="pill-featured"></span>}
              {cat.label}
              {!has && <span class="pill-soon">soon</span>}
            </button>
          );
        })}
      </div>
    </div>
  </div>

  <div class="results-note" id="results-note"></div>
  <div class="no-results" id="no-results">
    <p>Nothing found. Try "heavy", "morning", or "rest".</p>
  </div>

  <div class="lib-content">
    <div class="lib-inner">
      {categories.map(cat => {
        const liveItems = live(cat.slug);
        const phItems   = placeholders[cat.slug] || [];
        const items     = liveItems.length > 0 ? liveItems : phItems;
        return (
          <div class="cat-section" data-section={cat.slug}>
            <div class="cat-head">
              <div class="cat-head-left">
                {cat.featured && <span class="cat-featured-dot"></span>}
                <span class="cat-name">{cat.label}</span>
                {cat.desc && <span class="cat-desc">{cat.desc}</span>}
              </div>
              <span class={`cat-meta${!liveItems.length ? ' soon' : ''}`}>
                {liveItems.length ? `${liveItems.length} read${liveItems.length !== 1 ? 's' : ''}` : 'Coming soon'}
              </span>
            </div>
            <div class="reads">
              {items.map(item => {
                const isLive = liveItems.length > 0;
                const title = isLive ? item.frontmatter.title : item.title;
                const desc  = isLive ? item.frontmatter.description : item.desc;
                const time  = isLive ? (item.frontmatter.readTime || '3 min') : item.time;
                const slug  = isLive ? item.file.split('/').pop().replace('.md', '') : null;
                const href  = isLive ? `/library/${slug}` : null;
                const Tag   = isLive ? 'a' : 'div';
                return (
                  <Tag
                    {...(isLive ? { href } : {})}
                    class={`read-row${!isLive ? ' placeholder' : ''}`}
                    data-title={title.toLowerCase()}
                    data-desc={(desc||'').toLowerCase()}
                    data-cat={cat.slug}
                  >
                    <div class="read-body">
                      <div class="read-title">{title}</div>
                      {desc && <div class="read-desc">{desc}</div>}
                    </div>
                    <div class="read-time">{time}</div>
                  </Tag>
                );
              })}
            </div>
          </div>
        );
      })}

      <!-- Signup nudge -->
      <div class="lib-nudge">
        <div class="lib-nudge-left">
          <div class="lib-nudge-eyebrow">The Velani Letter</div>
          <div class="lib-nudge-title">A quieter <em>inbox.</em></div>
          <p>Weekly letters for women who want to carry less and feel more like themselves. Every Sunday, free.</p>
        </div>
        <div class="lib-nudge-form" id="nudge-form">
          <div class="inline-form">
            <input type="email" id="nudge-email" class="inline-email" placeholder="your@email.com" autocomplete="email">
            <button class="inline-btn" onclick="window.nudgeSignup()">Join</button>
          </div>
          <p class="inline-consent">By joining, you agree to occasional Velani emails. <a href="/privacy" target="_blank">Privacy policy</a>.</p>
        </div>
        <div class="inline-success" id="nudge-success">✓ Check your inbox to confirm.</div>
      </div>

    </div>
  </div>
</div>
</main>

<script>
  window.toggleMobileCat = function() {
    document.getElementById('cat-mobile').classList.toggle('open');
  };

  const searchEl    = document.getElementById('lib-search');
  const clearBtn    = document.getElementById('search-clear');
  const allPills    = document.querySelectorAll('.cat-pill');
  const sections    = document.querySelectorAll('[data-section]');
  const noResults   = document.getElementById('no-results');
  const resultsNote = document.getElementById('results-note');
  let activeCat = 'all', query = '';

  function update() {
    let count = 0;
    sections.forEach(sec => {
      const cat = sec.dataset.section;
      const show = activeCat === 'all' || activeCat === cat;
      let vis = false;
      sec.querySelectorAll('[data-title]').forEach(card => {
        const match = !query || (card.dataset.title||'').includes(query) || (card.dataset.desc||'').includes(query);
        const ok = show && match;
        card.style.display = ok ? '' : 'none';
        if (ok) { vis = true; count++; }
      });
      sec.style.display = vis ? '' : 'none';
    });
    noResults.classList.toggle('visible', count === 0);
    resultsNote.textContent = query ? `${count} result${count !== 1 ? 's' : ''} for "${query}"` : '';
  }

  searchEl.addEventListener('input', () => {
    query = searchEl.value.trim().toLowerCase();
    clearBtn.classList.toggle('visible', !!query);
    update();
  });
  clearBtn.addEventListener('click', () => {
    searchEl.value = ''; query = '';
    clearBtn.classList.remove('visible');
    searchEl.focus(); update();
  });
  allPills.forEach(pill => {
    pill.addEventListener('click', () => {
      if (pill.classList.contains('coming')) return;
      allPills.forEach(p => p.classList.remove('active'));
      document.querySelectorAll(`[data-cat="${pill.dataset.cat}"]`).forEach(p => {
        if (p.classList.contains('cat-pill')) p.classList.add('active');
      });
      activeCat = pill.dataset.cat; update();
    });
  });

  window.nudgeSignup = function() {
    const email = document.getElementById('nudge-email').value.trim();
    if (!email || !email.includes('@')) { document.getElementById('nudge-email').style.borderColor = '#B86A43'; return; }
    document.getElementById('nudge-email').style.borderColor = 'rgba(26,29,46,.14)';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email })
    }).then(() => done()).catch(() => done());
    function done() {
      document.getElementById('nudge-form').style.display = 'none';
      document.getElementById('nudge-success').classList.add('visible');
    }
  };
</script>

</Base>
