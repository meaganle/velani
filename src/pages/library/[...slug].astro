---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const pages = await Astro.glob('../../content/library/*.md');
  return pages
    .filter(p => !p.frontmatter.draft)
    .map(page => {
      const slug = page.file.split('/').pop().replace('.md', '');
      return {
        params: { slug },
        props: { frontmatter: page.frontmatter, compiledContent: page.compiledContent() }
      };
    });
}

const { frontmatter, compiledContent } = Astro.props;

const categoryLabels = {
  'start-here':    'Start Here',
  'calmer-days':   'Calmer Days',
  'carrying-less': 'Carrying Less',
  'rhythm':        'Gentle Rhythms',
  'quiet-wins':    'Quiet Wins',
  'making-room':   'Making Room',
  'wisdom-cards':  'One Idea',
  'velani-letter': 'From the Letter',
};
const categoryLabel = frontmatter.category
  ? (categoryLabels[frontmatter.category] || frontmatter.category)
  : null;

const formattedDate = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---
<Base
  title={frontmatter.title}
  description={frontmatter.description || ''}
  currentPath={`/library`}
>
<style>
  main { flex: 1; }

  /* Reading progress bar */
  .reading-bar {
    position: fixed; top: 0; left: 0; z-index: 100;
    height: 2px; width: 0%; background: var(--sage);
    transition: width .1s linear;
    pointer-events: none;
  }

  .article-wrap {
    max-width: 660px;
    margin: 0 auto;
    padding: 4rem 3rem 8rem;
    position: relative; z-index: 1;
  }

  /* Back link */
  .article-back {
    display: inline-flex; align-items: center; gap: .45rem;
    font-size: .72rem; color: var(--ink3); text-decoration: none;
    letter-spacing: .05em; text-transform: uppercase; font-weight: 500;
    margin-bottom: 3.5rem; transition: color .2s;
  }
  .article-back:hover { color: var(--sage); }
  .article-back svg { transition: transform .2s; }
  .article-back:hover svg { transform: translateX(-2px); }

  /* Header */
  .article-header { margin-bottom: 2.5rem; }
  .article-meta {
    display: flex; align-items: center; gap: .6rem;
    margin-bottom: 1.4rem; flex-wrap: wrap;
  }
  .meta-category {
    font-size: .58rem; letter-spacing: .18em;
    text-transform: uppercase; color: var(--terra);
    font-weight: 600; background: rgba(184,106,67,.08);
    padding: .25rem .65rem; border-radius: 100px;
  }
  .meta-sep { color: var(--border2); font-size: .75rem; }
  .meta-date {
    font-size: .72rem; color: var(--ink3);
    font-family: var(--display); font-style: italic;
  }
  .meta-time {
    font-size: .72rem; color: var(--ink3);
    font-family: var(--display); font-style: italic;
  }

  .article-title {
    font-family: var(--display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 300; line-height: 1.1;
    color: var(--ink); margin-bottom: 1.2rem;
    letter-spacing: -.025em;
  }

  .article-lede {
    font-family: var(--display);
    font-size: 1.08rem; font-weight: 300;
    font-style: italic; color: var(--ink2);
    line-height: 1.8; margin-bottom: 0;
  }

  .article-rule {
    display: flex; align-items: center; gap: .75rem;
    margin: 2.5rem 0;
  }
  .article-rule::before, .article-rule::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
  .article-rule-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0; opacity: .6;
  }

  /* Prose body */
  .article-body {
    font-size: 1rem; color: var(--ink2);
    line-height: 1.95;
  }
  .article-body p { margin-bottom: 1.6rem; }
  .article-body p:last-child { margin-bottom: 0; }
  .article-body em { font-style: italic; color: var(--ink); }
  .article-body strong { font-weight: 500; color: var(--ink); }
  .article-body hr {
    border: none;
    display: flex; align-items: center; gap: .75rem;
    margin: 3rem 0;
  }
  .article-body hr::before, .article-body hr::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
    display: block;
  }
  .article-body h2 {
    font-family: var(--display); font-size: 1.25rem;
    font-weight: 400; color: var(--ink);
    margin: 3rem 0 1rem; line-height: 1.25;
    letter-spacing: -.01em;
  }
  .article-body h3 {
    font-family: var(--display); font-size: 1rem;
    font-weight: 400; color: var(--ink);
    margin: 2.5rem 0 .8rem;
  }
  .article-body ul, .article-body ol {
    padding-left: 1.4rem; margin-bottom: 1.6rem;
  }
  .article-body li {
    margin-bottom: .5rem; color: var(--ink2);
    line-height: 1.75;
  }
  .article-body blockquote {
    font-family: var(--display); font-style: italic;
    font-size: 1.08rem; color: var(--ink);
    border-left: 2.5px solid var(--sage);
    padding: .8rem 0 .8rem 1.6rem;
    margin: 2.5rem 0; line-height: 1.75;
    background: var(--sage-gl);
    border-radius: 0 8px 8px 0;
    padding-right: 1.6rem;
  }

  /* Audit CTA */
  .audit-cta {
    margin-top: 3.5rem;
    background: var(--surface);
    border: 1px solid rgba(91,140,122,.2);
    border-left: 3px solid var(--sage);
    border-radius: 0 14px 14px 0;
    padding: 1.6rem 2rem;
    display: flex; align-items: center;
    justify-content: space-between; gap: 1.5rem;
    flex-wrap: wrap;
  }
  .audit-cta-left {}
  .audit-cta-q {
    font-size: .72rem; color: var(--ink3);
    margin-bottom: .35rem; line-height: 1.5;
  }
  .audit-cta-hed {
    font-family: var(--display); font-size: 1rem;
    font-weight: 400; color: var(--ink); line-height: 1.3;
  }
  .audit-cta-hed em { font-style: italic; color: var(--sage); }
  .audit-cta-link {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--ink); color: var(--bg);
    font-family: var(--body); font-size: .72rem; font-weight: 500;
    letter-spacing: .07em; text-transform: uppercase;
    padding: .75rem 1.4rem; border-radius: 100px;
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
    transition: background .2s, transform .15s;
  }
  .audit-cta-link:hover { background: var(--sage2); transform: translateY(-1px); }
  .audit-cta-time {
    font-size: .62rem; color: var(--ink3);
    font-style: italic; font-family: var(--display);
    margin-top: .4rem;
  }

  /* Footer */
  .article-footer {
    margin-top: 5rem; padding-top: 3rem;
    border-top: 1px solid var(--border);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 3rem; align-items: start;
  }
  .footer-nav {}
  .footer-nav-label {
    font-size: .58rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--ink3); font-weight: 600; margin-bottom: .6rem;
  }
  .footer-back {
    display: inline-flex; align-items: center; gap: .4rem;
    font-family: var(--display); font-size: .88rem; font-style: italic;
    color: var(--sage); text-decoration: none;
    transition: gap .2s;
  }
  .footer-back:hover { gap: .6rem; }

  .footer-signup {}
  .footer-signup-label {
    font-size: .58rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--terra); font-weight: 600; margin-bottom: .5rem;
  }
  .footer-signup-hed {
    font-family: var(--display); font-size: .95rem;
    font-weight: 300; color: var(--ink); margin-bottom: .3rem;
  }
  .footer-signup-hed em { font-style: italic; color: var(--sage); }
  .footer-signup p { font-size: .78rem; color: var(--ink3); margin-bottom: .8rem; line-height: 1.65; }

  @media (max-width: 700px) {
    .article-wrap { padding: 3rem 1.5rem 6rem; }
    .article-footer { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<div class="reading-bar" id="reading-bar"></div>

<main>
  <div class="article-wrap">

    <a class="article-back" href="/library">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
        <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Library
    </a>

    <div class="article-header">
      <div class="article-meta">
        {categoryLabel && <span class="meta-category">{categoryLabel}</span>}
        {categoryLabel && formattedDate && <span class="meta-sep">·</span>}
        {formattedDate && <span class="meta-date">{formattedDate}</span>}
        {frontmatter.readTime && <><span class="meta-sep">·</span><span class="meta-time">{frontmatter.readTime}</span></>}
      </div>
      <h1 class="article-title">{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="article-lede">{frontmatter.description}</p>
      )}
    </div>

    <div class="article-rule"><span class="article-rule-dot"></span></div>

    <div class="article-body">
      <Fragment set:html={compiledContent} />
    </div>

    <!-- Invisible Load Audit CTA -->
    <div class="audit-cta">
      <div class="audit-cta-left">
        <p class="audit-cta-q">Want to know exactly where your load is heaviest?</p>
        <div class="audit-cta-hed">Take the <em>Invisible Load Audit</em></div>
        <div class="audit-cta-time">4 minutes · Free</div>
      </div>
      <a class="audit-cta-link" href="/audit">
        Start the audit
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="article-footer">
      <div class="footer-nav">
        <div class="footer-nav-label">More to read</div>
        <a class="footer-back" href="/library">← Back to Library</a>
      </div>
      <div class="footer-signup">
        <div class="footer-signup-label">The Velani Letter</div>
        <div class="footer-signup-hed">A quieter <em>Sunday inbox.</em></div>
        <p>Weekly letters for women who want to carry less.</p>
        <div id="art-form">
          <div class="inline-form">
            <input type="email" id="art-email" class="inline-email" placeholder="your@email.com" autocomplete="email">
            <button class="inline-btn" onclick="window.artSignup()">Join</button>
          </div>
          <p class="inline-consent">By joining, you agree to occasional Velani emails. <a href="/privacy" target="_blank">Privacy policy</a>.</p>
        </div>
        <div class="inline-success" id="art-success">✓ Check your inbox to confirm.</div>
      </div>
    </div>

  </div>
</main>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-bar');
  function updateBar() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.width = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
  }
  window.addEventListener('scroll', updateBar, { passive: true });

  // Signup
  window.artSignup = function() {
    const email = document.getElementById('art-email').value.trim();
    if (!email || !email.includes('@')) { document.getElementById('art-email').style.borderColor = '#B86A43'; return; }
    document.getElementById('art-email').style.borderColor = 'rgba(26,29,46,.14)';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email })
    }).then(() => ok()).catch(() => ok());
    function ok() {
      document.getElementById('art-form').style.display = 'none';
      document.getElementById('art-success').classList.add('visible');
    }
  };
</script>

</Base>
