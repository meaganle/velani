---
// Standalone full-screen page — no Base layout
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Invisible Load Audit — Velani</title>
<meta name="description" content="Discover your Capacity Score. Find out exactly where your energy is going and what's quietly consuming your capacity to feel like yourself.">
<meta property="og:title" content="The Invisible Load Audit — Velani">
<meta property="og:description" content="10 questions. 4 minutes. Instant Capacity Score across your 4 life domains.">
<meta property="og:url" content="https://velani.app/audit">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ── Tokens (mirrors Velani site) ── */
:root {
  --cream:  #F7F6F3;
  --ink:    #1A1D2E;
  --ink2:   #3a3d4e;
  --ink3:   #6E7191;
  --sage:   #5B8C7A;
  --sage2:  #3D6B59;
  --sage-l: #EBF2EF;
  --terra:  #C4785A;
  --warm:   #FDFCFA;
  --mist:   #E8E4DC;
  --mist-d: #D4CFC5;
  --material: #6B8FB5;
  --material-l: #EEF3FA;
  --inner:  #8E5EA7;
  --inner-l:#F5EEF8;
  --connect:#C4785A;
  --connect-l:#FAF0EB;
  --display:'Lora', Georgia, serif;
  --body:   'DM Sans', system-ui, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body {
  font-family: var(--body);
  background: var(--cream);
  color: var(--ink);
  line-height: 1.7;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── Screens ── */
.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; flex-direction: column; }

/* ════════════════════════════════
   INTRO SCREEN
════════════════════════════════ */
#si {
  background: var(--ink);
  align-items: center;
  justify-content: center;
  padding: 64px 24px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
#si::before {
  content: '';
  position: absolute;
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(91,140,122,.12) 0%, transparent 65%);
  top: -160px; left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
}
.ii { max-width: 520px; position: relative; z-index: 1; }

.i-brand {
  font-family: var(--display);
  font-size: .78rem; letter-spacing: .22em;
  text-transform: uppercase; color: var(--sage);
  margin-bottom: 40px;
  display: flex; align-items: center; justify-content: center; gap: .7rem;
}
.i-brand::before, .i-brand::after {
  content: ''; display: block;
  width: 20px; height: 1px;
  background: var(--sage); opacity: .5;
}

.i-h1 {
  font-family: var(--display);
  font-size: clamp(2.2rem, 5.5vw, 3.2rem);
  font-weight: 400; color: #FDFCFA;
  line-height: 1.14; margin-bottom: 24px;
}
.i-h1 em { font-style: italic; color: var(--terra); }

.i-sub {
  font-size: .95rem;
  color: rgba(247,246,243,.58);
  line-height: 1.9; margin-bottom: 36px;
  max-width: 400px; margin-left: auto; margin-right: auto;
}

.i-domains {
  display: flex; justify-content: center;
  gap: 8px; flex-wrap: wrap; margin-bottom: 40px;
}
.i-domain {
  font-size: .68rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: rgba(247,246,243,.42);
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  padding: 7px 15px; border-radius: 100px;
}

.i-cta {
  display: inline-block;
  background: var(--terra); color: #fff;
  padding: 17px 40px; border-radius: 12px;
  font-size: .95rem; font-weight: 600;
  cursor: pointer; border: none;
  font-family: var(--body);
  transition: transform .15s, opacity .15s;
  letter-spacing: .02em;
}
.i-cta:hover { transform: translateY(-2px); opacity: .92; }

.i-time {
  font-size: .72rem;
  color: rgba(247,246,243,.28);
  margin-top: 16px;
  font-family: var(--display);
  font-style: italic;
}

/* ════════════════════════════════
   QUESTION SCREEN
════════════════════════════════ */
#sq { background: var(--cream); }

.qh {
  padding: 16px 32px;
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--mist);
  background: rgba(253,252,250,.97);
  backdrop-filter: blur(8px);
  position: sticky; top: 0; z-index: 10;
}
.qh-brand {
  font-family: var(--display);
  font-size: .8rem; color: var(--sage);
  letter-spacing: .1em; font-style: italic;
}
.qh-right { display: flex; align-items: center; gap: 14px; }
.pb-bg {
  width: 120px; height: 3px;
  background: var(--mist); border-radius: 3px; overflow: hidden;
}
.pb-fill {
  height: 100%; background: var(--sage);
  border-radius: 3px; transition: width .4s ease; width: 0%;
}
.pb-txt {
  font-size: .68rem; font-weight: 600;
  color: var(--ink3); white-space: nowrap;
}

.qbody {
  flex: 1; display: flex;
  align-items: center; justify-content: center;
  padding: 48px 24px;
}
.qcard { max-width: 580px; width: 100%; }

/* Domain tag */
.dtag {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: .65rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  padding: 6px 14px; border-radius: 100px;
  margin-bottom: 24px;
}
.dtag.home     { background: var(--material-l); color: var(--material); }
.dtag.work     { background: var(--sage-l);      color: var(--sage);     }
.dtag.self-e   { background: var(--connect-l);   color: var(--connect);  }
.dtag.self-i   { background: var(--inner-l);     color: var(--inner);    }

.qtxt {
  font-family: var(--display);
  font-size: clamp(1.2rem, 3vw, 1.55rem);
  font-weight: 400; color: var(--ink);
  line-height: 1.42; margin-bottom: 32px;
}

.qopts { display: flex; flex-direction: column; gap: 10px; }

.qopt {
  background: var(--warm);
  border: 1.5px solid var(--mist);
  border-radius: 14px;
  padding: 16px 20px;
  cursor: pointer;
  transition: border-color .15s, background .15s, transform .1s;
  display: flex; gap: 14px;
  align-items: flex-start; text-align: left;
  font-family: var(--body); width: 100%;
  min-height: 56px; /* touch-friendly */
}
.qopt:hover {
  border-color: var(--sage);
  background: var(--sage-l);
  transform: translateX(3px);
}
.qopt.sel {
  border-color: var(--sage);
  background: var(--sage-l);
}
.qopt.sel .radio { background: var(--sage); border-color: var(--sage); }
.qopt.sel .radio::after { opacity: 1; }

.radio {
  width: 22px; height: 22px; border-radius: 50%;
  border: 2px solid var(--mist-d);
  flex-shrink: 0; margin-top: 1px;
  transition: all .15s; position: relative;
}
.radio::after {
  content: '';
  position: absolute;
  width: 9px; height: 9px;
  background: #fff; border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0; transition: opacity .15s;
}
.opt-lbl {
  font-size: .9rem; color: var(--ink2);
  line-height: 1.55; font-weight: 400;
  padding-top: 2px;
}

.qnav {
  padding: 16px 32px;
  display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid var(--mist);
  background: rgba(253,252,250,.97);
}
.btn-back {
  background: none;
  border: 1.5px solid var(--mist);
  color: var(--ink3);
  padding: 11px 22px; border-radius: 100px;
  font-family: var(--body); font-size: .82rem;
  cursor: pointer; min-height: 44px;
  transition: border-color .15s, color .15s;
}
.btn-back:hover:not(:disabled) { border-color: var(--mist-d); color: var(--ink2); }
.btn-back:disabled { opacity: .3; cursor: default; }

.btn-next {
  background: var(--ink); color: var(--cream);
  padding: 12px 28px; border-radius: 100px;
  font-family: var(--body); font-size: .84rem; font-weight: 500;
  cursor: pointer; border: none;
  opacity: .32; pointer-events: none;
  transition: background .15s, opacity .15s, transform .1s;
  min-height: 44px; letter-spacing: .03em;
}
.btn-next.rdy { opacity: 1; pointer-events: all; }
.btn-next.rdy:hover { background: var(--sage2); transform: translateY(-1px); }

/* ════════════════════════════════
   LOADING SCREEN
════════════════════════════════ */
#sl {
  background: var(--ink);
  align-items: center; justify-content: center;
  text-align: center; padding: 64px 24px;
}
.sl-inner { max-width: 360px; margin: auto; }

.spin {
  width: 52px; height: 52px; border-radius: 50%;
  border: 2.5px solid rgba(91,140,122,.22);
  border-top-color: var(--sage);
  margin: 0 auto 32px;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.l-title {
  font-family: var(--display);
  font-size: 1.3rem; font-weight: 400;
  color: var(--warm); margin-bottom: 10px;
  font-style: italic;
}
.l-sub {
  font-size: .82rem; color: rgba(247,246,243,.42);
  line-height: 1.75; max-width: 320px; margin: 0 auto 32px;
}

.l-steps { display: flex; flex-direction: column; gap: 10px; }
.l-step {
  display: flex; align-items: center; gap: 12px;
  font-size: .79rem; color: rgba(247,246,243,.3);
  transition: color .4s; text-align: left;
}
.l-step.done { color: var(--sage); }
.l-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,.1); flex-shrink: 0;
  transition: background .4s;
}
.l-step.done .l-dot { background: var(--sage); }

/* ════════════════════════════════
   RESULTS SCREEN
════════════════════════════════ */
#sr { background: var(--cream); }

/* Results hero — dark */
.rh {
  background: var(--ink);
  padding: 56px 40px 48px;
  text-align: center;
}
.rh-inner { max-width: 560px; margin: 0 auto; }

.r-eye {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 12px;
}
.r-profile {
  font-family: var(--display);
  font-size: clamp(1.6rem, 4.5vw, 2.4rem);
  font-weight: 500; color: var(--warm);
  margin-bottom: 10px; line-height: 1.18;
}
.r-tag {
  font-size: .9rem; color: rgba(247,246,243,.54);
  line-height: 1.78; max-width: 400px;
  margin: 0 auto 32px;
  font-family: var(--display); font-style: italic;
}

/* Score ring */
.score-wrap {
  display: flex; align-items: center;
  justify-content: center; gap: 28px;
  margin: 0 0 28px;
}
.score-ring { position: relative; width: 108px; height: 108px; flex-shrink: 0; }
.score-ring svg { transform: rotate(-90deg); }
.ring-bg   { fill: none; stroke: rgba(255,255,255,.08); stroke-width: 7; }
.ring-fill { fill: none; stroke-width: 7; stroke-linecap: round; transition: stroke-dashoffset 1.6s cubic-bezier(.22,1,.36,1); }
.score-num {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--display);
  font-size: 1.65rem; font-weight: 500; color: var(--warm);
}
.score-side { text-align: left; }
.score-label {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: rgba(247,246,243,.35); margin-bottom: 8px;
}
.score-desc {
  font-size: .84rem; color: rgba(247,246,243,.65);
  line-height: 1.65; max-width: 200px;
  font-family: var(--display); font-style: italic;
}

/* Domain mini-bars */
.domain-bars {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; margin-top: 8px;
  max-width: 480px; margin-left: auto; margin-right: auto;
  text-align: left;
}
.dbar-top {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 6px;
}
.dbar-name {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
  color: rgba(247,246,243,.48);
}
.dbar-pct { font-size: .68rem; font-weight: 700; color: rgba(247,246,243,.65); }
.dbar-bg  { height: 4px; background: rgba(255,255,255,.08); border-radius: 4px; overflow: hidden; }
.dbar-fill { height: 100%; border-radius: 4px; transition: width 1.2s cubic-bezier(.22,1,.36,1) .3s; }
.fill-material   { background: var(--material); }
.fill-inner      { background: var(--inner); }
.fill-liveliness { background: var(--sage); }
.fill-connection { background: var(--connect); }

/* Results body */
.rb {
  max-width: 640px; margin: 0 auto;
  padding: 48px 24px 72px;
}

.rs-title {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 18px;
}

/* Domain cards */
.d-cards { display: flex; flex-direction: column; gap: 10px; margin-bottom: 40px; }

.d-card {
  background: var(--warm);
  border: 1px solid var(--mist);
  border-radius: 16px; padding: 20px 24px;
  transition: box-shadow .2s;
}
.d-card:hover { box-shadow: 0 4px 20px rgba(26,29,46,.07); }

.d-card-top {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 12px;
}
.d-card-name {
  font-weight: 600; font-size: .9rem;
  color: var(--ink); display: flex; align-items: center; gap: 8px;
}
.d-badge {
  font-size: .62rem; font-weight: 700;
  padding: 4px 11px; border-radius: 100px;
  letter-spacing: .06em; text-transform: uppercase;
}
.badge-critical { background: #FDECEA; color: #C0392B; }
.badge-high     { background: #FEF3E0; color: #D4820A; }
.badge-mod      { background: var(--sage-l); color: var(--sage2); }
.badge-low      { background: #EBF5EB; color: #2E7D32; }

.d-card-bar-bg {
  height: 4px; background: var(--mist);
  border-radius: 4px; overflow: hidden; margin-bottom: 14px;
}
.d-card-bar-fill { height: 100%; border-radius: 4px; transition: width 1.2s cubic-bezier(.22,1,.36,1) .2s; }

.d-card-insight { font-size: .85rem; color: var(--ink2); line-height: 1.72; }

/* Pattern insight box */
.insight-box {
  background: var(--ink);
  border-radius: 18px; padding: 28px 32px;
  margin-bottom: 16px;
}
.insight-label {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--terra); margin-bottom: 14px;
}
.insight-txt {
  font-family: var(--display);
  font-size: 1.02rem; color: rgba(247,246,243,.82);
  line-height: 1.82; font-weight: 400;
}

/* Wisdom box */
.wisdom-box {
  background: var(--sage-l);
  border: 1px solid rgba(91,140,122,.22);
  border-left: 3px solid var(--sage);
  border-radius: 0 14px 14px 0;
  padding: 20px 24px; margin-bottom: 40px;
}
.wisdom-label {
  font-size: .6rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: var(--sage2); margin-bottom: 10px;
}
.wisdom-txt {
  font-family: var(--display);
  font-size: .92rem; font-style: italic;
  color: var(--ink2); line-height: 1.8;
}
.wisdom-txt strong { font-style: normal; font-weight: 500; color: var(--ink); }

/* One clear move box */
.next-box {
  border-radius: 18px; padding: 32px;
  margin-bottom: 32px; border: 1.5px solid transparent;
}
.next-box.material   { background: var(--material-l); border-color: #BDD0E8; }
.next-box.inner      { background: var(--inner-l);    border-color: #D4B8E4; }
.next-box.liveliness { background: var(--sage-l);     border-color: rgba(91,140,122,.3); }
.next-box.connection { background: var(--connect-l);  border-color: #E8C4A8; }

.next-eye {
  font-size: .62rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  margin-bottom: 10px;
}
.next-box.material   .next-eye { color: var(--material); }
.next-box.inner      .next-eye { color: var(--inner); }
.next-box.liveliness .next-eye { color: var(--sage2); }
.next-box.connection .next-eye { color: var(--connect); }

.next-title {
  font-family: var(--display);
  font-size: 1.18rem; font-weight: 500;
  color: var(--ink); margin-bottom: 12px; line-height: 1.32;
}
.next-body {
  font-size: .88rem; color: var(--ink2);
  line-height: 1.82; margin-bottom: 24px;
}

/* Email capture within next-step */
.next-form { display: flex; gap: 8px; margin-bottom: 10px; }
.next-in {
  flex: 1; min-width: 0;
  padding: 13px 16px;
  border: 1.5px solid var(--mist-d);
  border-radius: 10px;
  font-family: var(--body); font-size: .88rem;
  background: var(--warm); color: var(--ink);
  outline: none; transition: border-color .2s;
  min-height: 48px;
}
.next-in:focus { border-color: var(--sage); }
.next-in::placeholder { color: var(--ink3); }
.next-btn {
  background: var(--ink); color: var(--cream);
  border: none; padding: 13px 22px;
  border-radius: 10px;
  font-family: var(--body); font-size: .84rem; font-weight: 500;
  cursor: pointer; white-space: nowrap;
  transition: background .15s, transform .1s;
  min-height: 48px; letter-spacing: .03em;
}
.next-btn:hover { background: var(--sage2); transform: translateY(-1px); }
.next-note {
  font-size: .72rem; color: var(--ink3);
  line-height: 1.5; font-style: italic;
}

/* Share row */
.share-row { text-align: center; padding-top: 4px; }
.share-row p { font-size: .78rem; color: var(--ink3); margin-bottom: 12px; }
.share-btn {
  background: none;
  border: 1.5px solid var(--mist-d);
  color: var(--ink3); padding: 10px 20px;
  border-radius: 100px; font-size: .78rem; font-weight: 500;
  cursor: pointer; font-family: var(--body);
  margin: 0 4px; transition: all .15s;
  min-height: 44px;
}
.share-btn:hover { border-color: var(--ink); color: var(--ink); }

.rfooter {
  text-align: center; padding: 0 24px 40px;
  font-size: .72rem; color: var(--mist-d);
  font-family: var(--display); font-style: italic;
}
.rfooter a { color: var(--sage); text-decoration: none; }

/* ── Responsive ── */
@media (max-width: 640px) {
  #si { padding: 56px 20px; }
  .i-h1 { font-size: clamp(1.9rem, 8vw, 2.4rem); }
  .i-cta { padding: 16px 36px; font-size: .9rem; }

  .qh { padding: 13px 16px; }
  .qbody { padding: 32px 16px; }
  .qnav { padding: 13px 16px; }
  .qopt { padding: 14px 16px; }
  .qtxt { font-size: clamp(1.1rem, 4.5vw, 1.35rem); margin-bottom: 24px; }

  .rh { padding: 40px 20px 36px; }
  .score-wrap { flex-direction: column; gap: 16px; }
  .score-side { text-align: center; }
  .score-desc { max-width: 100%; }
  .domain-bars { grid-template-columns: 1fr; gap: 10px; }

  .rb { padding: 36px 16px 60px; }
  .insight-box { padding: 22px 20px; }
  .next-box { padding: 24px 20px; }
  .next-form { flex-direction: column; }
  .next-btn { width: 100%; padding: 14px; }
}
</style>
</head>
<body>

<!-- ── INTRO ── -->
<div class="screen active" id="si">
  <div class="ii">
    <div class="i-brand">Velani</div>
    <h1 class="i-h1">The <em>Invisible Load</em><br>Audit</h1>
    <p class="i-sub">There's a kind of exhaustion that sleep doesn't fix. This audit shows you exactly where your energy is going — and what's quietly consuming your capacity to feel like yourself.</p>
    <div class="i-domains">
      <span class="i-domain">🏠 Home &amp; Family</span>
      <span class="i-domain">💼 Work &amp; Career</span>
      <span class="i-domain">⚡ Energy &amp; Body</span>
      <span class="i-domain">✦ Identity &amp; Joy</span>
    </div>
    <button class="i-cta" onclick="start()">Begin the audit</button>
    <p class="i-time">10 questions · 4 minutes · instant Capacity Score</p>
  </div>
</div>

<!-- ── QUESTIONS ── -->
<div class="screen" id="sq">
  <div class="qh">
    <div class="qh-brand">Velani Audit</div>
    <div class="qh-right">
      <div class="pb-bg"><div class="pb-fill" id="pb"></div></div>
      <div class="pb-txt" id="pb-txt">1 of 10</div>
    </div>
  </div>
  <div class="qbody">
    <div class="qcard">
      <div class="dtag" id="dtag"></div>
      <div class="qtxt" id="qtxt"></div>
      <div class="qopts" id="qopts"></div>
    </div>
  </div>
  <div class="qnav">
    <button class="btn-back" id="bbk" onclick="prev()" disabled>← Back</button>
    <button class="btn-next" id="bnx" onclick="next()">Continue →</button>
  </div>
</div>

<!-- ── LOADING ── -->
<div class="screen" id="sl">
  <div class="sl-inner">
    <div class="spin"></div>
    <div class="l-title">Reading your load…</div>
