---
// src/pages/audit/index.astro. The Invisible Load Audit v4
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Invisible Load Audit | Velani</title>
<meta name="description" content="Discover your Capacity Score in 4 minutes. See exactly where your energy is going and what's quietly consuming your capacity to feel like yourself.">
<meta property="og:title" content="The Invisible Load Audit | Velani">
<meta property="og:description" content="4 minutes. Instant Capacity Score across the four domains of your life.">
<meta property="og:url" content="https://velani.app/audit">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
:root{
  --cream:#F7F6F3; --ink:#1A1D2E; --ink-deep:#14161F; --sage:#5B8C7A; --terra:#C4785A;
  --warm:#FDFCFA; --mist:#E8E4DC; --mist-d:#D4CFC5; --ink2:#3a3d4e; --ink3:#6b6e7d;
  --sage-l:#EBF2EF; --terra-l:#FAF0EB;
  --material:#6B8FB5; --inner:#8E5EA7; --live:#5B8C7A; --connect:#C4785A;
  --cream-soft:rgba(247,246,243,.7);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{-webkit-text-size-adjust:100%;}
body{font-family:'DM Sans',sans-serif;background:var(--ink);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased;}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;}}

.screen{display:none;min-height:100vh;min-height:100dvh;}
.screen.active{display:flex;flex-direction:column;animation:fadeup .45s ease;}
@keyframes fadeup{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

/* ── SHARED DARK ATMOSPHERE ── */
.atmos{position:relative;overflow:hidden;background:var(--ink);}
.atmos::before{content:'';position:absolute;width:140vw;height:140vw;max-width:900px;max-height:900px;border-radius:50%;background:radial-gradient(circle,rgba(91,140,122,.14) 0%,transparent 65%);top:-40vh;left:50%;transform:translateX(-50%);pointer-events:none;}

/* ── INTRO ── */
#si{align-items:center;justify-content:center;padding:48px 24px;text-align:center;}
.ii{max-width:460px;position:relative;z-index:1;width:100%;}
.i-brand{font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:14px;opacity:.85;}
.i-h1{font-family:'Lora',serif;font-size:clamp(2.1rem,7vw,2.9rem);font-weight:400;color:var(--warm);line-height:1.16;margin-bottom:20px;}
.i-h1 em{font-style:italic;color:var(--terra);}
.i-sub{font-size:1rem;color:var(--cream-soft);line-height:1.75;margin-bottom:36px;}
.i-domains{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:32px;}
.i-domain{font-size:.72rem;font-weight:600;letter-spacing:.06em;color:rgba(247,246,243,.55);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);padding:8px 14px;border-radius:24px;}
.i-checks{display:flex;flex-direction:column;gap:9px;margin-bottom:28px;text-align:left;max-width:260px;margin-left:auto;margin-right:auto;}
.i-check{display:flex;align-items:center;gap:11px;font-size:.88rem;color:rgba(247,246,243,.72);}
.i-check-icon{width:18px;height:18px;min-width:18px;border-radius:50%;background:rgba(91,140,122,.28);display:flex;align-items:center;justify-content:center;font-size:.6rem;color:var(--sage);}
.i-cta{display:block;width:100%;max-width:340px;margin:0 auto;background:var(--terra);color:#fff;padding:18px 32px;border-radius:14px;font-size:1.05rem;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 20px rgba(196,120,90,.25);}
.i-cta:active{transform:scale(.98);}
@media(hover:hover){.i-cta:hover{transform:translateY(-2px);box-shadow:0 6px 26px rgba(196,120,90,.35);}}
.i-receive{margin-top:22px;max-width:300px;margin-left:auto;margin-right:auto;}
.i-receive-label{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(247,246,243,.35);margin-bottom:10px;}
.i-receive-list{list-style:none;display:flex;flex-direction:column;gap:7px;}
.i-receive-list li{font-size:.84rem;color:rgba(247,246,243,.55);display:flex;align-items:center;gap:9px;}
.i-receive-list li::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--terra);flex-shrink:0;opacity:.7;}
.i-time{display:none;}

/* ── QUESTIONS ── */
#sq{background:var(--ink);}
.qh{padding:16px 20px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:10;background:var(--ink-deep);border-bottom:1px solid rgba(255,255,255,.06);}
.qh-back{background:none;border:none;color:rgba(247,246,243,.5);font-size:1.4rem;cursor:pointer;padding:4px 8px;line-height:1;flex-shrink:0;min-width:36px;min-height:44px;display:flex;align-items:center;justify-content:center;border-radius:8px;}
.qh-back:disabled{opacity:.25;}
.qh-back:active:not(:disabled){background:rgba(255,255,255,.08);}
.dots{display:flex;gap:5px;flex:1;align-items:center;}
.dot{height:4px;flex:1;background:rgba(255,255,255,.12);border-radius:4px;overflow:hidden;}
.dot.done{background:var(--sage);}
.dot.cur{background:rgba(255,255,255,.35);}
.qh-count{font-size:.78rem;font-weight:600;color:rgba(247,246,243,.5);flex-shrink:0;min-width:40px;text-align:right;}

.qbody{flex:1;display:flex;flex-direction:column;justify-content:center;padding:36px 22px 32px;max-width:560px;margin:0 auto;width:100%;}
.q-domain{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:20px;display:inline-flex;align-items:center;gap:7px;align-self:flex-start;padding:7px 14px;border-radius:20px;}
.q-domain.home{background:rgba(107,143,181,.16);color:#9DBBDA;}
.q-domain.work{background:rgba(91,140,122,.16);color:#86C4AE;}
.q-domain.self-e{background:rgba(196,120,90,.16);color:#E0A183;}
.q-domain.self-i{background:rgba(142,94,167,.18);color:#C295D8;}
.qtxt{font-family:'Lora',serif;font-size:clamp(1.35rem,5vw,1.65rem);font-weight:400;color:var(--warm);line-height:1.36;margin-bottom:28px;}
.qopts{display:flex;flex-direction:column;gap:10px;}
.qopt{background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.12);border-radius:14px;padding:18px 20px;cursor:pointer;transition:all .15s;text-align:left;font-family:'DM Sans',sans-serif;width:100%;color:rgba(247,246,243,.82);font-size:.98rem;line-height:1.5;min-height:60px;display:flex;align-items:center;-webkit-tap-highlight-color:transparent;}
.qopt:active{transform:scale(.99);background:rgba(255,255,255,.08);}
@media(hover:hover){.qopt:hover{border-color:var(--sage);background:rgba(91,140,122,.12);color:var(--warm);}}
.qopt.sel{border-color:var(--sage);background:rgba(91,140,122,.18);color:var(--warm);}

/* ── LOADING ── */
#sl{align-items:center;justify-content:center;text-align:center;padding:40px 28px;}
.li{max-width:380px;position:relative;z-index:1;}
.spin{width:54px;height:54px;border-radius:50%;border:3px solid rgba(91,140,122,.2);border-top-color:var(--sage);margin:0 auto 30px;animation:spin 1s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.l-title{font-family:'Lora',serif;font-size:1.5rem;color:var(--warm);margin-bottom:12px;}
.l-sub{font-size:.92rem;color:rgba(247,246,243,.5);line-height:1.7;}
.l-steps{margin-top:32px;display:flex;flex-direction:column;gap:12px;text-align:left;max-width:280px;margin-left:auto;margin-right:auto;}
.l-step{display:flex;align-items:center;gap:12px;font-size:.88rem;color:rgba(247,246,243,.35);transition:color .4s;}
.l-step.done{color:var(--sage);}
.l-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.15);flex-shrink:0;transition:background .4s;}
.l-step.done .l-dot{background:var(--sage);}

/* ── RESULTS ── */
#sr{background:var(--cream);}
.rhero{background:var(--ink);padding:44px 24px 52px;text-align:center;position:relative;overflow:hidden;}
.rhero::before{content:'';position:absolute;width:130vw;height:130vw;max-width:700px;max-height:700px;border-radius:50%;background:radial-gradient(circle,rgba(196,120,90,.13) 0%,transparent 62%);top:-30vh;left:50%;transform:translateX(-50%);pointer-events:none;}
.rh-in{max-width:520px;margin:0 auto;position:relative;z-index:1;}
.rh-eye{font-size:.68rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--sage);margin-bottom:14px;}
.rh-pattern{font-family:'Lora',serif;font-size:clamp(1.9rem,6vw,2.5rem);font-weight:500;color:var(--warm);margin-bottom:12px;line-height:1.18;}
.rh-tag{font-size:.96rem;color:rgba(247,246,243,.65);line-height:1.7;margin-bottom:30px;}
.score-block{display:flex;align-items:center;justify-content:center;gap:22px;}
.ring{position:relative;width:104px;height:104px;flex-shrink:0;}
.ring svg{transform:rotate(-90deg);}
.ring-bg{fill:none;stroke:rgba(255,255,255,.1);stroke-width:7;}
.ring-fl{fill:none;stroke-width:7;stroke-linecap:round;transition:stroke-dashoffset 1.3s cubic-bezier(.22,1,.36,1);}
.ring-num{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Lora',serif;font-size:1.7rem;font-weight:500;color:var(--warm);}
.score-side{text-align:left;}
.score-lbl{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(247,246,243,.45);margin-bottom:5px;}
.score-desc{font-size:.86rem;color:rgba(247,246,243,.7);line-height:1.5;max-width:170px;}

.rbody{max-width:600px;margin:0 auto;padding:0 22px;}

/* bars card. overlaps hero */
.bars-card{background:var(--warm);border:1px solid var(--mist);border-radius:18px;padding:24px 22px;margin-top:-26px;position:relative;z-index:2;box-shadow:0 8px 30px rgba(26,29,46,.08);}
.bars-title{font-size:.66rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);margin-bottom:16px;}
.bar-row{margin-bottom:14px;}
.bar-row:last-child{margin-bottom:0;}
.bar-top{display:grid;grid-template-columns:1fr auto;align-items:center;margin-bottom:6px;gap:12px;}
.bar-name{font-size:.86rem;font-weight:600;color:var(--ink);min-width:0;}
.bar-pct{font-size:.8rem;font-weight:700;color:var(--ink3);}
.bar-track{height:7px;background:var(--mist);border-radius:7px;overflow:hidden;}
.bar-fl{height:100%;border-radius:7px;width:0;transition:width 1s cubic-bezier(.22,1,.36,1) .3s;}
.fl-connection{background:var(--connect);}
.fl-material{background:var(--material);}
.fl-liveliness{background:var(--live);}
.fl-inner{background:var(--inner);}

.sec-title{font-size:.66rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);margin:34px 0 14px;}
.pattern-read{background:var(--ink);border-radius:18px;padding:26px 24px;}
.pr-label{font-size:.64rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--terra);margin-bottom:12px;}
.pr-text{font-family:'Lora',serif;font-size:1.05rem;font-style:italic;color:var(--warm);line-height:1.72;}

.wisdom-box{background:var(--sage-l);border:1px solid #C5DDD7;border-radius:16px;padding:22px 24px;margin-top:16px;}
.wis-l{font-size:.62rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--sage);margin-bottom:9px;}
.wis-t{font-size:.92rem;color:var(--ink2);line-height:1.75;}
.wis-t strong{color:var(--ink);}

/* save result card */
.save-card{background:var(--warm);border:2px solid var(--sage);border-radius:18px;padding:28px 24px;margin-top:34px;text-align:center;}
.save-icon{font-size:1.4rem;margin-bottom:10px;}
.save-h{font-family:'Lora',serif;font-size:1.22rem;font-weight:500;color:var(--ink);margin-bottom:8px;line-height:1.32;}
.save-sub{font-size:.9rem;color:var(--ink2);line-height:1.65;margin-bottom:20px;}
.save-form{display:flex;flex-direction:column;gap:10px;}
.save-input{width:100%;padding:16px 18px;border:1.5px solid var(--mist-d);border-radius:12px;font-family:'DM Sans',sans-serif;font-size:1rem;background:var(--cream);color:var(--ink);text-align:center;outline:none;transition:border-color .2s;}
.save-input:focus{border-color:var(--sage);}
.save-btn{width:100%;background:var(--ink);color:var(--cream);border:none;padding:16px 24px;border-radius:12px;font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:background .15s;min-height:52px;}
.save-btn:active{transform:scale(.99);}
@media(hover:hover){.save-btn:hover{background:var(--sage);}}
.save-fine{font-size:.74rem;color:var(--ink3);margin-top:12px;line-height:1.5;}

/* companion offer */
.offer{background:var(--ink);border-radius:20px;padding:30px 26px;margin-top:20px;position:relative;overflow:hidden;}
.offer::before{content:'';position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(196,120,90,.16) 0%,transparent 65%);top:-120px;right:-80px;pointer-events:none;}
.offer-in{position:relative;z-index:1;}
.offer-eye{font-size:.64rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--terra);margin-bottom:12px;}
.offer-h{font-family:'Lora',serif;font-size:1.45rem;font-weight:500;color:var(--warm);line-height:1.28;margin-bottom:14px;}
.offer-h em{font-style:italic;color:var(--terra);}
.offer-body{font-size:.92rem;color:rgba(247,246,243,.72);line-height:1.75;margin-bottom:18px;}
.offer-list{list-style:none;margin-bottom:22px;}
.offer-list li{display:flex;gap:11px;align-items:flex-start;font-size:.9rem;color:rgba(247,246,243,.82);line-height:1.55;margin-bottom:11px;}
.offer-list li::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--terra);flex-shrink:0;margin-top:8px;}
.offer-price-row{display:flex;align-items:baseline;gap:10px;margin-bottom:20px;}
.offer-price{font-family:'Lora',serif;font-size:2rem;font-weight:500;color:var(--warm);}
.offer-price-note{font-size:.82rem;color:rgba(247,246,243,.5);}
.offer-cta{display:block;width:100%;background:var(--terra);color:#fff;padding:17px 28px;border-radius:13px;font-size:1rem;font-weight:600;text-align:center;text-decoration:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:transform .15s,box-shadow .15s;box-shadow:0 4px 18px rgba(196,120,90,.3);min-height:54px;display:flex;align-items:center;justify-content:center;}
.offer-cta:active{transform:scale(.99);}
@media(hover:hover){.offer-cta:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(196,120,90,.42);}}
.offer-guarantee{font-size:.8rem;color:rgba(247,246,243,.5);text-align:center;margin-top:14px;line-height:1.55;}
.offer-founder{display:flex;gap:12px;align-items:flex-start;margin-top:22px;padding-top:20px;border-top:1px solid rgba(255,255,255,.1);}
.founder-quote{font-size:.86rem;color:rgba(247,246,243,.65);line-height:1.6;font-style:italic;}
.founder-quote .name{display:block;font-style:normal;font-weight:600;color:rgba(247,246,243,.82);margin-top:6px;font-size:.82rem;}

.share-row{text-align:center;padding:34px 0 50px;}
.share-row p{font-size:.86rem;color:var(--ink3);margin-bottom:14px;}
.share-btn{background:none;border:1.5px solid var(--mist-d);color:var(--ink2);padding:12px 22px;border-radius:10px;font-size:.86rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;margin:4px;transition:all .15s;min-height:48px;}
.share-btn:active{transform:scale(.98);}
@media(hover:hover){.share-btn:hover{border-color:var(--ink);color:var(--ink);}}
.rfoot{text-align:center;padding:0 24px 48px;font-size:.76rem;color:var(--mist-d);}
.rfoot a{color:var(--sage);text-decoration:none;}

@media(min-width:560px){
  .save-form{flex-direction:row;}
  .save-input{text-align:left;flex:1;}
  .save-btn{width:auto;white-space:nowrap;flex-shrink:0;}
}
@media(max-width:420px){
  .qopt{font-size:.92rem;padding:16px 16px;}
  .qtxt{font-size:1.28rem;}
}
</style>
</head>
<body>

<!-- INTRO -->
<div class="screen active atmos" id="si">
  <div class="ii">
    <div class="i-brand">The Invisible Load Audit</div>
    <h1 class="i-h1">What are you carrying that's<br><em>quietly exhausting you?</em></h1>
    <p class="i-sub">There's a kind of tiredness that sleep doesn't fix.<br><br>In four minutes, discover where your energy is going, and what's quietly draining your capacity to feel like yourself.</p>
    <div class="i-domains">
      <span class="i-domain">Home &amp; Family</span>
      <span class="i-domain">Work &amp; Career</span>
      <span class="i-domain">Health &amp; Energy</span>
      <span class="i-domain">Identity &amp; Self</span>
    </div>
    <div class="i-checks">
      <div class="i-check"><span class="i-check-icon">&#10003;</span>10 questions</div>
      <div class="i-check"><span class="i-check-icon">&#10003;</span>4 minutes</div>
      <div class="i-check"><span class="i-check-icon">&#10003;</span>Personalized results</div>
      <div class="i-check"><span class="i-check-icon">&#10003;</span>Free</div>
    </div>
    <button class="i-cta" onclick="start()">See My Capacity Profile</button>
    <div class="i-receive">
      <div class="i-receive-label">You'll receive</div>
      <ul class="i-receive-list">
        <li>Your Capacity Score</li>
        <li>Your Invisible Load Profile</li>
        <li>Personalized next steps</li>
      </ul>
    </div>
  </div>
</div>

<!-- QUESTIONS -->
<div class="screen atmos" id="sq">
  <div class="qh">
    <button class="qh-back" id="bbk" onclick="prev()" disabled>&#8249;</button>
    <div class="dots" id="dots"></div>
    <div class="qh-count" id="qcount">1/10</div>
  </div>
  <div class="qbody">
    <div class="q-domain" id="qdom"></div>
    <div class="qtxt" id="qtxt"></div>
    <div class="qopts" id="qopts"></div>
  </div>
</div>

<!-- LOADING -->
<div class="screen atmos" id="sl">
  <div class="li">
    <div class="spin"></div>
    <div class="l-title">Reading your load&hellip;</div>
    <p class="l-sub">Finding where responsibility has gathered, and where your capacity has quietly slipped away.</p>
    <div class="l-steps">
      <div class="l-step" id="ls1"><div class="l-dot"></div>Home &amp; Family</div>
      <div class="l-step" id="ls2"><div class="l-dot"></div>Work &amp; Career</div>
      <div class="l-step" id="ls3"><div class="l-dot"></div>Health &amp; Energy</div>
      <div class="l-step" id="ls4"><div class="l-dot"></div>Identity &amp; Self</div>
      <div class="l-step" id="ls5"><div class="l-dot"></div>Finding your pattern</div>
    </div>
  </div>
</div>

<!-- RESULTS -->
<div class="screen" id="sr">
  <div class="rhero">
    <div class="rh-in">
      <div class="rh-eye">Your result</div>
      <div class="rh-pattern" id="r-pattern"></div>
      <div class="rh-tag" id="r-tag"></div>
      <div class="score-block">
        <div class="ring">
          <svg width="104" height="104" viewBox="0 0 104 104">
            <circle class="ring-bg" cx="52" cy="52" r="44"/>
            <circle class="ring-fl" id="ring-fl" cx="52" cy="52" r="44" stroke-dasharray="276" stroke-dashoffset="276"/>
          </svg>
          <div class="ring-num" id="ring-num">--</div>
        </div>
        <div class="score-side">
          <div class="score-lbl">Capacity Score</div>
          <div class="score-desc" id="score-desc"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="rbody">
    <div class="bars-card">
      <div class="bars-title">Where your load sits</div>
      <div id="bars"></div>
    </div>

    <div class="sec-title">What your result means</div>
    <div class="pattern-read">
      <div class="pr-label">Your pattern</div>
      <div class="pr-text" id="pr-text"></div>
    </div>

    <div class="wisdom-box" id="wisdom-box" style="display:none;">
      <div class="wis-l">A truth worth sitting with</div>
      <div class="wis-t" id="wis-t"></div>
    </div>

    <!-- SAVE RESULT -->
    <div class="save-card" id="save-card">
      <div class="save-icon">&#9830;</div>
      <div class="save-h">Save your result &amp; get your free starting guide</div>
      <div class="save-sub">We'll send your Capacity Score and Velani Lite, a simple daily practice to start carrying less, free. Plus a weekly letter for women making room for themselves again.</div>
      <div class="save-form" id="save-form">
        <input class="save-input" type="email" id="email" placeholder="your@email.com" autocomplete="email" inputmode="email">
        <button class="save-btn" onclick="saveResult()">Send it to me</button>
      </div>
      <div class="save-fine">No spam, ever. Unsubscribe anytime.</div>
    </div>

    <!-- COMPANION OFFER -->
    <div class="sec-title">Your one clear next step</div>
    <div class="offer">
      <div class="offer-in">
        <div class="offer-eye">The Velani Companion&trade;</div>
        <div class="offer-h" id="offer-h">Turn your result into <em>real change.</em></div>
        <div class="offer-body" id="offer-body">A guided experience built around your result, starting exactly where your load is heaviest. Not another thing to manage. A quiet, beautiful space to decide what you're finally allowed to put down, and what you'll grow toward instead.</div>
        <ul class="offer-list">
          <li>Built around your result: starts where your load is heaviest</li>
          <li>Five steps: see it, sort it, release it, reclaim it, move forward</li>
          <li>Discover the Order of Care, the one idea that changes everything</li>
          <li>Return each season as your capacity grows</li>
          <li>PDF workbook + interactive web version included</li>
        </ul>
        <div class="offer-price-row">
          <div class="offer-price">$39</div>
          <div class="offer-price-note">one-time &middot; instant access</div>
        </div>
        <a class="offer-cta" id="offer-cta" href="https://buy.stripe.com/9B69AM3pRcSC8MJ4OR8N202" onclick="trackCompanion()">Begin the Companion&trade; &rarr;</a>
        <div class="offer-guarantee">If it doesn't help you make room, reply to any email and I'll refund you. No forms, no questions.</div>
        <div class="offer-founder">
          <div class="founder-quote">"I built this because I needed it myself. A senior role, a new baby, carrying everything. This is the tool I wish I'd had."<span class="name">, Meagan, founder of Velani</span></div>
        </div>
      </div>
    </div>

    <div class="share-row">
      <p>Know someone carrying too much?</p>
      <button class="share-btn" onclick="doShare()">Share the audit</button>
      <button class="share-btn" onclick="start()">Retake</button>
    </div>
  </div>
  <div class="rfoot"><a href="https://velani.app">velani.app</a> &middot; Making room for yourself again</div>
</div>

<script is:inline>
var Qs=[
  {tag:'Home &amp; Family',cls:'home',velani:'connection',
   q:'How often are you mentally tracking household and family logistics, even when you’re trying to rest?',
   opts:['Rarely. Home runs without much mental effort from me','Sometimes. I notice it but it stays manageable','Often. It’s there even when I’m at work or with friends','Almost always. It’s one of the loudest things in my head']},
  {tag:'Home &amp; Family',cls:'home',velani:'connection',
   q:'How many people’s emotional or practical needs filter through you on a regular basis?',
   opts:['Mostly my own. I’m in an independent season','One or two people. Manageable','Three or four: children, partner, parents, others','Five or more. I’m the one everyone comes to']},
  {tag:'Home &amp; Family',cls:'home',velani:'connection',
   q:'When you think about your relationships and family responsibilities, how do they feel?',
   opts:['Nourishing. They give me energy','Meaningful but tiring. I love them, it’s just a lot','Heavy. I feel like I keep everyone afloat','Depleting. There’s nothing left after everyone else']},
  {tag:'Work &amp; Career',cls:'work',velani:'material',
   q:'How much of your mind is on work outside work hours: open projects, emails, unfinished things?',
   opts:['Very little. I switch off well','Some. It surfaces occasionally','A lot. It follows me into evenings and weekends','Constantly. I can’t remember not thinking about it']},
  {tag:'Work &amp; Career',cls:'work',velani:'material',
   q:'How many unfinished work loops are you carrying right now: decisions, conversations, tasks left open?',
   opts:['A few. Nothing that keeps me up','A moderate amount. I know what they are','A lot. More than I can clearly name','So many I’ve stopped counting']},
  {tag:’Health &amp; Energy’,cls:’self-e’,velani:’liveliness’,
   q:’How would you describe your physical and emotional energy most days?’,
   opts:[‘Generally good. I feel like myself’,’Variable. Some good days, some empty ones’,’Often low. I’m running on less than I need’,’Persistently depleted. I forget what full feels like’]},
  {tag:’Health &amp; Energy’,cls:’self-e’,velani:’liveliness’,
   q:’How well are you protecting the basics that restore you: sleep, movement, real rest?’,
   opts:[‘Well. These are non-negotiables I protect’,’Okay. I get most of them most of the time’,’Poorly. They’re the first thing I cut’,’Not at all. I’ve been running on empty a long time’]},
  {tag:’Identity &amp; Self’,cls:’self-i’,velani:’inner’,
   q:’When did you last do something entirely for you, not productive, just yours?’,
   opts:[‘Recently. I make time for this’,’A few weeks ago. Not as often as I’d like’,’A while ago. I can’t quite remember’,’I honestly can’t remember. it’s rare now’]},
  {tag:’Identity &amp; Self’,cls:’self-i’,velani:’inner’,
   q:’How connected do you feel to the version of yourself from before all the responsibility?’,
   opts:[‘Connected. She’s still here’,’Somewhat. I catch glimpses of her’,’Barely. She’s in there but quiet’,’Disconnected. I’m not sure I know her anymore’]},
  {tag:’Identity &amp; Self’,cls:’self-i’,velani:’inner’,
   q:’Beauty, curiosity, creativity, the things that feel alive rather than useful. How present are they?’,
   opts:[‘Present and protected. Part of how I live’,’Occasional. In small moments’,’Rare. Luxuries I’ll get back to someday’,’Almost absent. Life is mostly maintenance’]}
];

var cur=0,ans=new Array(Qs.length).fill(null),lastResult=null;

function show(id){var s=document.querySelectorAll('.screen');for(var i=0;i<s.length;i++)s[i].classList.remove('active');document.getElementById(id).classList.add('active');window.scrollTo(0,0);}
function start(){cur=0;ans=new Array(Qs.length).fill(null);buildDots();render();show('sq');}

function buildDots(){
  var d=document.getElementById('dots');d.innerHTML='';
  for(var i=0;i<Qs.length;i++)d.innerHTML+='<div class="dot" id="dot'+i+'"></div>';
}

function render(){
  var q=Qs[cur];
  for(var i=0;i<Qs.length;i++){
    var el=document.getElementById('dot'+i);
    el.className='dot'+(i<cur?' done':i===cur?' cur':'');
  }
  document.getElementById('qcount').textContent=(cur+1)+'/'+Qs.length;
  var dom=document.getElementById('qdom');
  dom.innerHTML=q.tag;dom.className='q-domain '+q.cls;
  document.getElementById('qtxt').textContent=q.q;
  var c=document.getElementById('qopts');c.innerHTML='';
  for(var i=0;i<q.opts.length;i++){
    (function(i){
      var b=document.createElement('button');
      b.className='qopt'+(ans[cur]===i?' sel':'');
      b.textContent=q.opts[i];
      b.onclick=function(){pick(i);};
      c.appendChild(b);
    })(i);
  }
  document.getElementById('bbk').disabled=cur===0;
}

function pick(i){
  ans[cur]=i;
  var els=document.querySelectorAll('.qopt');
  for(var j=0;j<els.length;j++)els[j].classList.toggle('sel',j===i);
  setTimeout(function(){if(cur<Qs.length-1){cur++;render();}else loading();},280);
}

function prev(){if(cur>0){cur--;render();}}

function loading(){
  show('sl');
  var ids=['ls1','ls2','ls3','ls4','ls5'];
  for(var k=0;k<ids.length;k++)document.getElementById(ids[k]).classList.remove('done');
  var i=0;
  var t=setInterval(function(){
    if(i<ids.length){document.getElementById(ids[i]).classList.add('done');i++;}
    else{clearInterval(t);setTimeout(function(){buildResults();show('sr');},420);}
  },360);
}

function buildResults(){
  var vm={
    connection:{label:'Home & Family',score:0,max:0},
    material:{label:'Work & Career',score:0,max:0},
    liveliness:{label:'Health & Energy',score:0,max:0},
    inner:{label:'Identity & Self',score:0,max:0}
  };
  for(var i=0;i<Qs.length;i++){
    var s=ans[i]==null?0:ans[i];
    vm[Qs[i].velani].score+=(s+1);
    vm[Qs[i].velani].max+=4;
  }
  var tS=0,tM=0;
  for(var k in vm){tS+=vm[k].score;tM+=vm[k].max;}
  var cap=100-Math.round(tS/tM*100);
  var dp={};for(var k in vm)dp[k]=Math.round(vm[k].score/vm[k].max*100);
  var pat=detectPattern(dp,cap);
  lastResult={cap:cap,pattern:pat.id,name:pat.name};

  document.getElementById('r-pattern').textContent=pat.name;
  document.getElementById('r-tag').textContent=pat.tag;
  document.getElementById('ring-num').textContent=cap;
  document.getElementById('score-desc').textContent=pat.scoreDesc;
  var fl=document.getElementById('ring-fl');
  fl.style.stroke=pat.ring;
  setTimeout(function(){fl.style.strokeDashoffset=276-(276*cap/100);},150);

  var order=['connection','material','liveliness','inner'];
  var bars=document.getElementById('bars');bars.innerHTML='';
  for(var b=0;b<order.length;b++){
    var key=order[b],d=vm[key];
    bars.innerHTML+='<div class="bar-row"><div class="bar-top"><span class="bar-name">'+d.label+'</span><span class="bar-pct">'+dp[key]+'%</span></div><div class="bar-track"><div class="bar-fl fl-'+key+'" data-w="'+dp[key]+'%"></div></div></div>';
  }
  setTimeout(function(){var f=document.querySelectorAll('.bar-fl');for(var i=0;i<f.length;i++)f[i].style.width=f[i].dataset.w;},250);

  document.getElementById('pr-text').textContent=pat.insight;
  if(pat.wisdom){
    document.getElementById('wisdom-box').style.display='block';
    document.getElementById('wis-t').innerHTML=pat.wisdom;
  }

  if(pat.id==='carrying-well'){
    document.getElementById('offer-h').innerHTML='Protect the space <em>you’ve made.</em>';
    document.getElementById('offer-body').textContent='You’re carrying well right now, and that’s worth keeping. The Companion helps you protect your capacity before the next season fills it, and grow into the room you have.';
  }
}

function detectPattern(dp,cap){
  var m=dp.material,c=dp.connection,l=dp.liveliness,n=dp.inner,H=60;
  if(cap>=70)return P.carryingWell;
  if(m>=H&&c>=H&&(l>=H||n>=H))return P.runningEmpty;
  if(m>=H&&n>=H)return P.successWithoutSelf;
  if(c>=H&&l>=H)return P.endlessPour;
  if(c>=H&&c>=m&&c>=n)return P.endlessPour;
  if(n>=H&&m<H&&c<H)return P.quietDisappearance;
  if(n>=H&&n>=m&&n>=c)return P.quietDisappearance;
  return P.holdingTogether;
}

var P={
  successWithoutSelf:{id:'success-without-self',name:'Success Without Self',ring:'#FFB74D',
    tag:'You’re succeeding at everything, except being yourself.',
    scoreDesc:'Capacity is going to performance.',
    insight:'You’re carrying your career and responsibilities at a high level, and from the outside it looks like you’re doing well. But the person underneath the achievement has gone quiet. You’ve been succeeding at everything except being yourself, and that’s the most invisible load of all.',
    wisdom:'Most of us give our sharpest selves to work and to people we barely know, and bring home what’s left. <strong>The people closest to you. and you yourself. deserve more than your leftovers.</strong>'},
  endlessPour:{id:'endless-pour',name:'The Endless Pour',ring:'#E57373',
    tag:'You’re pouring into everyone, with little left for you.',
    scoreDesc:'You give and give. Your reserves run low.',
    insight:'You’re holding a great deal for the people in your life, and it’s drawing down the energy you need for yourself. You’re the one who keeps everyone afloat, and your own body and spirit are running on whatever’s left at the end of the day.',
    wisdom:'There’s an order to care most of us have upside down. We pour our best outward and give our closest people, and ourselves, what remains. <strong>You belong on your own list. Not last. On it.</strong>'},
  runningEmpty:{id:'running-on-empty',name:'Running on Empty',ring:'#E57373',
    tag:'You’re holding up everyone’s life. and you’re exhausted.',
    scoreDesc:'Very little capacity remains.',
    insight:'You’re carrying work and family at full capacity while your own body and inner life get almost nothing. You’re the load-bearing wall holding everyone up, and walls don’t get to rest. This has been the case for a while. The first move isn’t to carry it better. It’s to put something down.',
    wisdom:'You cannot be the wall that holds everyone up if no one, including you, is holding you. <strong>Putting yourself back into the order of care is how you stay standing.</strong>'},
  quietDisappearance:{id:'quiet-disappearance',name:'The Quiet Disappearance',ring:'#FFB74D',
    tag:'On paper, everything’s fine. So why don’t you feel like yourself?',
    scoreDesc:'Your life works. Your inner life is quiet.',
    insight:'Your practical life is actually manageable, work isn’t crushing you, your responsibilities are under control. And yet you’ve quietly lost touch with yourself. There’s no crisis to point to, just a slow fade. You haven’t broken down. You’ve disappeared a little. and that deserves attention precisely because nothing is forcing it.',
    wisdom:'Sometimes the most important thing missing isn’t time or energy. it’s <strong>you</strong>. Not the version that performs and provides, but the one underneath. She’s still there, waiting to be made room for.'},
  holdingTogether:{id:'holding-it-together',name:'Holding It Together',ring:'#5B8C7A',
    tag:'You’re managing, but managing has become the ceiling.',
    scoreDesc:'Moderate load. More is possible.',
    insight:'No single domain is in crisis, but the cumulative weight is real. You’re holding it together, and you’re good at it. The risk isn’t collapse. it’s that holding it together quietly becomes the ceiling of your life, and the room for possibility and for yourself slowly shrinks. You have the capacity to change that, deliberately, before the load grows.',
    wisdom:'The load rarely announces itself. It accumulates quietly until “fine but tired” becomes normal. <strong>Noticing it now, while you still have room, is the whole advantage.</strong>'},
  carryingWell:{id:'carrying-well',name:'Carrying Well',ring:'#81C784',
    tag:'You have room right now. and that’s worth protecting.',
    scoreDesc:'Good capacity remaining.',
    insight:'You’re carrying well right now. You have real capacity, your load is relatively light, and your structures are working. This is rarer than you might think, and you don’t need rescuing. What’s true is that capacity erodes quietly. so the work now is protecting the space you have, deliberately, before the next busy season fills it.',
    wisdom:null}
};

function saveResult(){
  var e=document.getElementById('email');
  if(!e.value||e.value.indexOf('@')<0){e.style.borderColor='var(--terra)';e.focus();return;}
  e.style.borderColor='';
  var tags=['audit-complete'];
  if(lastResult&&lastResult.pattern)tags.push('pattern-'+lastResult.pattern);
  var fields={};
  if(lastResult){fields.capacity_score=lastResult.cap;fields.pattern_name=lastResult.name;}
  fetch('https://velani-subscribe.velani-app.workers.dev',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:e.value,tags:tags,fields:fields})}).catch(function(){});
  document.getElementById('save-card').innerHTML='<div class="save-icon">✓</div><div class="save-h">Saved. Check your inbox.</div><div class="save-sub">Your Capacity Score and personalized results are on their way, along with Velani Lite.</div>';
}

function trackCompanion(){
  var tags=['companion-interest'];
  if(lastResult&&lastResult.pattern)tags.push('pattern-'+lastResult.pattern);
  var em=document.getElementById('email');
  if(em&&em.value&&em.value.indexOf('@')>0){
    fetch('https://velani-subscribe.velani-app.workers.dev',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em.value,tags:tags})}).catch(function(){});
  }
  try{
    if(lastResult){
      localStorage.setItem('velani_audit_pattern',lastResult.pattern||'');
      var map={'success-without-self':'inner','endless-pour':'liveliness','running-on-empty':'liveliness','quiet-disappearance':'inner','holding-it-together':'connection','carrying-well':'inner'};
      localStorage.setItem('velani_audit_domain',map[lastResult.pattern]||'inner');
    }
  }catch(e){}
}

function doShare(){
  var cap=document.getElementById('ring-num').textContent;
  var name=document.getElementById('r-pattern').textContent;
  var txt='I just took the Invisible Load Audit, my Capacity Score is '+cap+'/100 ('+name+'). Find yours:';
  if(navigator.share){navigator.share({title:'The Invisible Load Audit. Velani',text:txt,url:'https://velani.app/audit'});}
  else{navigator.clipboard.writeText(txt+' https://velani.app/audit').then(function(){alert('Copied. ready to share.');});}
}
</script>
</body>
</html>
