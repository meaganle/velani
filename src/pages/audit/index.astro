    insight:'Your answers reveal the most demanding pattern of all: you’re carrying work and family at full capacity, while your own body and inner life get almost nothing. You are the load-bearing wall holding up everyone around you — and load-bearing walls don’t get to rest. This isn’t a discipline problem or a time-management problem. You’re carrying more than any one person should, and it has been this way for a while. The first move is not to carry it better. It’s to put something down.',
    wisdom:'Here’s a truth worth sitting with: we tend to give our best energy outward — to work, to others, to everyone who needs us — and leave ourselves for last. <strong>You cannot be the wall that holds everyone up if no one, including you, is holding you.</strong>',
    domain:'liveliness'
  },
  quietDisappearance: {
    id:'quiet-disappearance', name:'The Quiet Disappearance',
    ringColor:'#FFB74D',
    tag:'On paper, everything is manageable. So why does it feel like you’ve lost yourself?',
    scoreDesc:'Your practical life works. Your inner life has gone quiet.',
    insight:'Your answers reveal something subtle and important: your practical life is actually fairly manageable — work isn’t crushing you, your responsibilities are under control. And yet you’ve quietly lost touch with yourself. This is the pattern that’s hardest to explain to anyone, because nothing is visibly wrong. There’s no crisis to point to. Just a slow fade — the curiosity, the spontaneity, the sense of being fully yourself, all gone quiet. You haven’t broken down. You’ve disappeared a little. And that deserves attention precisely because nothing is forcing it to.',
    wisdom:'Sometimes the most important thing missing isn’t time or energy — it’s <strong>you</strong>. Not the version that performs and provides, but the one underneath. She’s still there. She’s just been waiting to be made room for.',
    domain:'inner'
  },
  holdingTogether: {
    id:'holding-it-together', name:'Holding It Together',
    ringColor:'#5B8C7A',
    tag:'You’re managing — but managing has quietly become the ceiling.',
    scoreDesc:'Moderate load across the board. More is possible than you’re living.',
    insight:'Your answers show a fairly even load — no single domain is in crisis, but the cumulative weight is real. You’re holding it together, and you’re good at it. The risk in your pattern isn’t collapse. It’s that “holding it together” quietly becomes the ceiling of your life — that managing replaces living, and the space for possibility, beauty, and yourself slowly shrinks without anything dramatic ever happening. You have enough capacity to change this. The question is whether you’ll use it deliberately, before the load grows.',
    wisdom:'The load rarely announces itself. It accumulates quietly — a yes here, a responsibility there — until “fine but tired” becomes normal. <strong>Noticing it now, while you still have room, is the whole advantage.</strong>',
    domain:null
  },
  carryingWell: {
    id:'carrying-well', name:'Carrying Well',
    ringColor:'#81C784',
    tag:'You have room right now. That’s rare — and worth protecting.',
    scoreDesc:'Good capacity remaining. The work now is keeping it.',
    insight:'Your answers show something genuinely good: you’re carrying well right now. You have real capacity, your load is relatively light, and the structures in your life are working. This is rarer than you might think, and it’s worth naming honestly — you don’t need rescuing. What’s true, though, is that capacity erodes quietly. Responsibility accumulates when we’re not watching, and the women who stay spacious are the ones who protect it deliberately, before the next busy season fills the room. You’re in a strong place. The work now is simply keeping it that way.',
    wisdom:null,
    domain:null
  }
};

function level(pct) {
  if (pct >= 70) return {label:'Critical',   cls:'badge-critical'};
  if (pct >= 55) return {label:'Heavy',      cls:'badge-high'};
  if (pct >= 40) return {label:'Moderate',   cls:'badge-mod'};
  return              {label:'Manageable', cls:'badge-low'};
}

function domainInsight(key, pct) {
  var ins = {
    connection: {
      h:'You’re holding significant emotional and logistical responsibility for others. The mental overhead of coordinating everyone else’s lives is consuming energy you need for your own.',
      m:'Connection responsibility is present. The invisible coordination work is there, even if it’s not yet overwhelming.',
      l:'Connection feels relatively balanced. You’re caring for people without losing yourself in it.'
    },
    material: {
      h:'Work is following you home. The open loops and career responsibility are draining attention even when you’re not at your desk.',
      m:'Career load is real but contained. There are likely specific loops worth closing.',
      l:'Work isn’t your primary source of invisible load right now.'
    },
    liveliness: {
      h:'The basics that restore you — sleep, movement, rest — have been consistently deprioritised. This is about what gets cut when everything else fills up.',
      m:'Energy and body care are present but not well protected. Worth noticing before they erode further.',
      l:'You’re protecting your physical energy reasonably well.'
    },
    inner: {
      h:'The version of you that exists beyond responsibility has gone quiet. This is often the last thing women notice — and the first thing that needs attention.',
      m:'Your inner life is present but not consistently nourished. The things that feel like you are occasional rather than woven in.',
      l:'You have reasonable connection to your own identity and what brings you alive.'
    }
  };
  var d = ins[key];
  return pct >= 55 ? d.h : pct >= 40 ? d.m : d.l;
}

function nextStep(heaviestKey, pat) {
  var domClass = pat.domain || heaviestKey;
  var copy;
  if (pat.id === 'carrying-well') {
    copy = {
      cls: domClass,
      eye: 'For where you are right now',
      title: 'Protect the space you have.',
      body: 'You don’t need rescuing — and we won’t pretend you do. The Velani Companion isn’t urgent for you. But it’s being built to help women protect their capacity before the next season fills it. If you’d like to be first to know when it’s ready, leave your email.',
      note: 'We’ll only email you about the Companion. Nothing else.'
    };
  } else {
    var titles = {
      'success-without-self': 'Find your way back to yourself — without giving up what you’ve built.',
      'endless-pour':         'Put yourself back on your own list.',
      'running-on-empty':     'Start putting things down — before you have to.',
      'quiet-disappearance':  'Make room for the version of you that’s gone quiet.',
      'holding-it-together':  'Use your capacity deliberately — before the load grows.'
    };
    copy = {
      cls: domClass,
      eye: 'Your one clear move: the Velani Companion',
      title: titles[pat.id],
      body: 'The Velani Companion is a guided experience built around your result — starting exactly where your load is heaviest. It doesn’t add another thing to manage. It helps you decide what you’re finally allowed to put down. It’s launching soon, and your audit shows you’re exactly who it’s for. Leave your email to be first to know when it’s ready.',
      note: 'We’ll only email you about the Companion. Nothing else.'
    };
  }
  return '<div class="next-box ' + copy.cls + '">'
    + '<div class="next-eye">' + copy.eye + '</div>'
    + '<div class="next-title">' + copy.title + '</div>'
    + '<div class="next-body">' + copy.body + '</div>'
    + '<div class="next-form">'
    +   '<input class="next-in" type="email" id="ne" placeholder="your@email.com" autocomplete="email">'
    +   '<button class="next-btn" onclick="companionOptin()">Notify me</button>'
    + '</div>'
    + '<div class="next-note">' + copy.note + '</div>'
    + '</div>';
}

function companionOptin() {
  var e = document.getElementById('ne');
  if (!e.value || e.value.indexOf('@') < 0) { e.style.borderColor = 'var(--terra)'; return; }
  var tags = ['audit-complete', 'companion-interest'];
  if (lastResult && lastResult.pattern) tags.push('pattern-' + lastResult.pattern);
  fetch('https://velani-subscribe.velani-app.workers.dev', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({email: e.value, tags: tags})
  }).catch(function() {});
  var domClass = (lastResult && lastResult.pattern === 'carrying-well') ? 'liveliness' : 'connection';
  document.getElementById('next-step-box').innerHTML =
    '<div class="next-box ' + domClass + '">'
    + '<div class="next-eye">You’re on the list</div>'
    + '<div class="next-title">Thank you. You’ll be first to know.</div>'
    + '<div class="next-body">The Velani Companion is being built right now — shaped around exactly the kind of result you just received. When it’s ready, you’ll be among the first to hear. In the meantime, your Velani Letter will arrive each Sunday.</div>'
    + '</div>';
}

function doShare() {
  var cap  = document.getElementById('score-num').textContent;
  var name = document.getElementById('r-profile').textContent;
  var txt  = 'I just took the Invisible Load Audit at velani.app — my Capacity Score is ' + cap + '/100 (' + name + '). Find out yours:';
  if (navigator.share) {
    navigator.share({title: 'My Invisible Load Audit — Velani', text: txt, url: 'https://velani.app/audit'});
  } else {
    navigator.clipboard.writeText(txt + ' https://velani.app/audit').then(function() {
      alert('Copied — ready to share.');
    });
  }
}
</script>
</body>
</html>
