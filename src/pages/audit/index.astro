var cur = 0, ans = new Array(Qs.length).fill(null), lastResult = null;

function show(id) {
  var ss = document.querySelectorAll('.screen');
  for (var i = 0; i < ss.length; i++) ss[i].classList.remove('active');
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function start() {
  cur = 0;
  ans = new Array(Qs.length).fill(null);
  render();
  show('sq');
}

function render() {
  var q = Qs[cur], tot = Qs.length;
  document.getElementById('pb').style.width = (cur / tot * 100) + '%';
  document.getElementById('pb-txt').textContent = (cur + 1) + ' of ' + tot;
  var tag = document.getElementById('dtag');
  tag.textContent = q.tag;
  tag.className = 'dtag ' + q.cls;
  document.getElementById('qtxt').textContent = q.q;
  var c = document.getElementById('qopts');
  c.innerHTML = '';
  for (var i = 0; i < q.opts.length; i++) {
    (function(i) {
      var b = document.createElement('button');
      b.className = 'qopt' + (ans[cur] === i ? ' sel' : '');
      b.innerHTML = '<div class="radio"></div><div class="opt-lbl">' + q.opts[i].l + '</div>';
      b.onclick = function() { pick(i); };
      c.appendChild(b);
    })(i);
  }
  document.getElementById('bbk').disabled = cur === 0;
  updNext();
}

function pick(i) {
  ans[cur] = i;
  var els = document.querySelectorAll('.qopt');
  for (var j = 0; j < els.length; j++) {
    var on = j === i;
    els[j].classList.toggle('sel', on);
    var r = els[j].querySelector('.radio');
    r.style.background   = on ? 'var(--sage)' : '';
    r.style.borderColor  = on ? 'var(--sage)' : '';
  }
  updNext();
  setTimeout(function() {
    if (ans[cur] !== null && document.getElementById('bnx').classList.contains('rdy')) next();
  }, 500);
}

function updNext() {
  var b = document.getElementById('bnx');
  b.textContent = cur === Qs.length - 1 ? 'See my Capacity Score →' : 'Continue →';
  if (ans[cur] !== null) b.classList.add('rdy');
  else b.classList.remove('rdy');
}

function next() {
  if (ans[cur] === null) return;
  if (cur < Qs.length - 1) { cur++; render(); }
  else loading();
}
function prev() { if (cur > 0) { cur--; render(); } }

function loading() {
  show('sl');
  var ids = ['ls1','ls2','ls3','ls4','ls5'];
  for (var k = 0; k < ids.length; k++) document.getElementById(ids[k]).classList.remove('done');
  var i = 0;
  var t = setInterval(function() {
    if (i < ids.length) { document.getElementById(ids[i]).classList.add('done'); i++; }
    else { clearInterval(t); setTimeout(function() { buildResults(); show('sr'); }, 350); }
  }, 400);
}

function buildResults() {
  var vm = {
    connection: {label:'Connection', emoji:'🤝', score:0, max:0},
    material:   {label:'Material',   emoji:'💼', score:0, max:0},
    liveliness: {label:'Liveliness', emoji:'⚡', score:0, max:0},
    inner:      {label:'Inner',      emoji:'✦',  score:0, max:0}
  };
  for (var i = 0; i < Qs.length; i++) {
    var s = ans[i] == null ? 0 : ans[i];
    vm[Qs[i].velani].score += Qs[i].opts[s].s;
    vm[Qs[i].velani].max   += 4;
  }
  var tS = 0, tM = 0;
  for (var k in vm) { tS += vm[k].score; tM += vm[k].max; }
  var capScore = 100 - Math.round(tS / tM * 100);

  var dp = {};
  for (var k in vm) dp[k] = Math.round(vm[k].score / vm[k].max * 100);

  var pat = detectPattern(dp, capScore);
  lastResult = {cap: capScore, pattern: pat.id, name: pat.name};

  document.getElementById('r-profile').textContent  = pat.name;
  document.getElementById('r-tag').textContent       = pat.tag;
  document.getElementById('score-num').textContent   = capScore;
  document.getElementById('score-desc').textContent  = pat.scoreDesc;

  var fill = document.getElementById('ring-fill');
  fill.style.stroke = pat.ringColor;
  setTimeout(function() { fill.style.strokeDashoffset = 283 - (283 * capScore / 100); }, 150);

  // Domain mini-bars
  var barsEl = document.getElementById('domain-bars');
  barsEl.innerHTML = '';
  var order = ['connection','material','liveliness','inner'];
  for (var b = 0; b < order.length; b++) {
    var key = order[b], d = vm[key];
    barsEl.innerHTML += '<div><div class="dbar-top"><span class="dbar-name">' + d.emoji + ' ' + d.label + '</span><span class="dbar-pct">' + dp[key] + '%</span></div><div class="dbar-bg"><div class="dbar-fill fill-' + key + '" style="width:0%" data-w="' + dp[key] + '%"></div></div></div>';
  }
  setTimeout(function() {
    var fs = document.querySelectorAll('.dbar-fill');
    for (var f = 0; f < fs.length; f++) fs[f].style.width = fs[f].dataset.w;
  }, 200);

  // Sorted domain cards
  var sorted = [];
  for (var k in vm) sorted.push({key:k, label:vm[k].label, emoji:vm[k].emoji, pct:dp[k]});
  sorted.sort(function(a, b) { return b.pct - a.pct; });

  var dc = document.getElementById('d-cards');
  dc.innerHTML = '';
  for (var c = 0; c < sorted.length; c++) {
    var d = sorted[c], lv = level(d.pct);
    dc.innerHTML += '<div class="d-card"><div class="d-card-top"><div class="d-card-name">' + d.emoji + ' ' + d.label + '</div><div class="d-badge ' + lv.cls + '">' + lv.label + '</div></div><div class="d-card-bar-bg"><div class="d-card-bar-fill fill-' + d.key + '" style="width:0%" data-w="' + d.pct + '%"></div></div><div class="d-card-insight">' + domainInsight(d.key, d.pct) + '</div></div>';
  }
  setTimeout(function() {
    var fs = document.querySelectorAll('.d-card-bar-fill');
    for (var f = 0; f < fs.length; f++) fs[f].style.width = fs[f].dataset.w;
  }, 300);

  document.getElementById('insight-txt').textContent = pat.insight;

  if (pat.wisdom) {
    document.getElementById('wisdom-box').style.display = 'block';
    document.getElementById('wisdom-txt').innerHTML = pat.wisdom;
  } else {
    document.getElementById('wisdom-box').style.display = 'none';
  }

  document.getElementById('next-step-box').innerHTML = nextStep(sorted[0].key, pat);
}

/* ── Pattern detection ── */
function detectPattern(dp, cap) {
  var m = dp.material, c = dp.connection, l = dp.liveliness, n = dp.inner;
  var HIGH = 60;
  if (cap >= 70) return PATTERNS.carryingWell;
  if (m >= HIGH && c >= HIGH && (l >= HIGH || n >= HIGH)) return PATTERNS.runningEmpty;
  if (m >= HIGH && n >= HIGH && c < HIGH) return PATTERNS.successWithoutSelf;
  if (m >= HIGH && n >= HIGH) return PATTERNS.successWithoutSelf;
  if (c >= HIGH && l >= HIGH) return PATTERNS.endlessPour;
  if (c >= HIGH && c >= m && c >= n) return PATTERNS.endlessPour;
  if (n >= HIGH && m < HIGH && c < HIGH) return PATTERNS.quietDisappearance;
  if (n >= HIGH && n >= m && n >= c) return PATTERNS.quietDisappearance;
  return PATTERNS.holdingTogether;
}

var PATTERNS = {
  successWithoutSelf: {
    id:'success-without-self', name:'Success Without Self',
    ringColor:'#FFB74D',
    tag:'You’re succeeding at everything — except being yourself.',
    scoreDesc:'Capacity is going to performance. Little is left for you.',
