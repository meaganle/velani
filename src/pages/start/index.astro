---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Velani — Your First Move"
  description="One clear move. One clearer day."
  currentPath="/start"
>
<style>
/* ── MAIN ── */
main {
  flex: 1;
  display: flex; align-items: flex-start; justify-content: center;
  padding: 3.5rem 1.5rem 5rem;
  position: relative; z-index: 1;
}

/* ── SCREENS ── */
.screen {
  width: 100%; max-width: 500px;
  display: none;
  animation: screenIn .48s cubic-bezier(.22,1,.36,1) forwards;
}
.screen.active { display: block; }
@keyframes screenIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── PROGRESS ── */
.progress-wrap { margin-bottom: 2.8rem; }
.progress-track {
  height: 2px; background: var(--border2);
  border-radius: 100px; overflow: hidden; margin-bottom: .7rem;
}
.progress-fill {
  height: 100%; background: var(--sage);
  border-radius: 100px; transition: width .5s cubic-bezier(.22,1,.36,1);
}
.progress-row { display: flex; align-items: center; justify-content: space-between; }
.progress-label { font-size: .62rem; color: var(--ink3); letter-spacing: .12em; text-transform: uppercase; }
.back-link { font-size: .62rem; color: var(--ink3); cursor: pointer; transition: color .2s; letter-spacing: .02em; }
.back-link:hover { color: var(--ink); }

/* ── TYPOGRAPHY ── */
h1, h2 {
  font-family: var(--display);
  font-size: 1.9rem; font-weight: 300;
  line-height: 1.13; color: var(--ink);
  margin-bottom: .6rem; letter-spacing: -.015em;
}
h1 em, h2 em { font-style: italic; color: var(--sage); }
.subheading { font-size: .88rem; color: var(--ink3); margin-bottom: 1.8rem; line-height: 1.72; }

/* ── INPUTS ── */
.field-label {
  display: block; font-size: .65rem; font-weight: 500;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--ink2); margin-bottom: .55rem;
}
textarea, .field-email {
  width: 100%; background: var(--surface);
  border: 1.5px solid var(--border2); border-radius: 12px;
  padding: 1rem 1.15rem; font-family: var(--body);
  font-size: .92rem; color: var(--ink);
  line-height: 1.7; resize: none; outline: none;
  transition: border-color .2s;
}
textarea { min-height: 90px; }
textarea:focus, .field-email:focus { border-color: var(--sage); }
textarea::placeholder, .field-email::placeholder { color: var(--ink3); font-style: italic; }
.field-email { background: var(--bg); border-radius: 10px; }

/* ── BUTTONS ── */
.btn-row { display: flex; align-items: center; gap: 1.4rem; margin-top: 1.8rem; }
.btn-primary {
  display: inline-flex; align-items: center; gap: .55rem;
  background: var(--ink); color: var(--bg);
  font-family: var(--body); font-size: .8rem; font-weight: 500;
  letter-spacing: .07em; text-transform: uppercase;
  padding: .88rem 2rem; border-radius: 100px; border: none; cursor: pointer;
  transition: background .2s, transform .15s; text-decoration: none;
}
.btn-primary:hover { background: var(--sage2); transform: translateY(-1px); }
.btn-primary svg { transition: transform .2s; }
.btn-primary:hover svg { transform: translateX(3px); }
.btn-ghost {
  display: inline-flex; align-items: center;
  background: transparent; color: var(--ink3);
  font-family: var(--body); font-size: .78rem;
  padding: .5rem 0; border: none; cursor: pointer;
  letter-spacing: .03em; transition: color .2s;
}
.btn-ghost:hover { color: var(--ink); }

/* ── TIMER ── */
.timer-block {
  background: var(--surface); border: 1.5px solid var(--border2);
  border-radius: 16px; padding: 2.4rem 1.8rem; margin-bottom: .4rem; text-align: center;
}
.timer-display {
  font-family: var(--display); font-size: 3.4rem; font-weight: 300;
  color: var(--ink); letter-spacing: -.04em; line-height: 1;
  margin-bottom: .5rem; transition: color .4s;
}
.timer-display.done { color: var(--sage); }
.timer-sub { font-size: .7rem; color: var(--ink3); margin-bottom: 1.5rem; letter-spacing: .02em; }
.timer-btn-row { display: flex; gap: .6rem; justify-content: center; }
.timer-btn {
  font-size: .72rem; font-weight: 500; letter-spacing: .07em; text-transform: uppercase;
  padding: .5rem 1.2rem; border-radius: 100px; border: 1.5px solid var(--border2);
  background: transparent; color: var(--ink2); cursor: pointer; transition: all .2s;
}
.timer-btn:hover { border-color: var(--sage); color: var(--sage); }
.timer-btn.running { border-color: var(--terra); color: var(--terra); }

/* ── QUIET WIN CARD ── */
.win-card {
  background: var(--sage-gl2); border: 1px solid rgba(91,140,122,.2);
  border-radius: 16px; padding: 1.6rem 1.8rem; margin-bottom: 2rem;
}
.win-icon-row { display: flex; align-items: center; gap: .75rem; margin-bottom: .55rem; }
.win-icon {
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(91,140,122,.12); border: 1px solid rgba(91,140,122,.25);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.win-headline { font-family: var(--display); font-size: 1.1rem; font-weight: 400; color: var(--sage2); }
.win-body { font-size: .85rem; color: var(--ink2); line-height: 1.7; }

/* ── SCREEN 5 ── */
.field-error { display: block; font-size: .7rem; color: var(--terra); min-height: 1.1rem; margin-bottom: .4rem; }
.field-message { display: block; font-size: .72rem; min-height: 1rem; margin-top: .5rem; }

/* ── SCREEN 6 SUCCESS ── */
.success-card {
  background: var(--sage-gl2); border: 1px solid rgba(91,140,122,.2);
  border-radius: 16px; padding: 2rem 2.2rem; margin-bottom: 2rem; text-align: center;
}
.success-icon {
  width: 44px; height: 44px; border-radius: 50%;
  background: rgba(91,140,122,.12); border: 1px solid rgba(91,140,122,.25);
  display: flex; align-items: center; justify-content: center; margin: 0 auto 1.1rem;
}
.success-headline { font-family: var(--display); font-size: 1.4rem; font-weight: 300; color: var(--sage2); margin-bottom: .4rem; letter-spacing: -.01em; }
.success-body { font-size: .85rem; color: var(--ink2); line-height: 1.7; }
.format-links { font-size: .75rem; color: var(--ink3); text-align: center; margin-top: 1.3rem; }
.format-links a { color: var(--sage); text-decoration: none; margin: 0 .5rem; }
.format-links a:hover { text-decoration: underline; }
.closing-line { font-family: var(--display); font-size: .88rem; font-style: italic; font-weight: 300; color: var(--ink3); text-align: center; margin-top: 2.2rem; }

@media (max-width: 540px) {
  main { padding: 2.5rem 1.2rem 4rem; }
  h1, h2 { font-size: 1.65rem; }
  .btn-row { flex-direction: column; align-items: flex-start; gap: .9rem; }
}
</style>

<main>

  <!-- SCREEN 1: TODAY -->
  <div class="screen active" id="s1">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:16.66%"></div></div>
      <div class="progress-row">
        <span class="progress-label">One clear move</span>
      </div>
    </div>
    <h2>What's your one <em>move</em> today?</h2>
    <p class="subheading">Not a list. Just one thing — the thing that would make today feel meaningful.</p>
    <label class="field-label" for="today">Today's move</label>
    <textarea id="today" rows="3" placeholder="e.g. Send the proposal that's been sitting in drafts"></textarea>
    <div class="btn-row">
      <button class="btn-primary" onclick="nextScreen(1)">
        That's my move
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- SCREEN 2: TIMER -->
  <div class="screen" id="s2">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:33.33%"></div></div>
      <div class="progress-row">
        <span class="progress-label">Now do it</span>
        <span class="back-link" onclick="prevScreen(2)">← Back</span>
      </div>
    </div>
    <h2>Two minutes. <em>Start now.</em></h2>
    <p class="subheading">You don't need to finish it. You just need to start. Two minutes of real attention changes everything.</p>
    <div class="timer-block">
      <div class="timer-display" id="timer-display">2:00</div>
      <div class="timer-sub" id="timer-sub">Press start — then focus</div>
      <div class="timer-btn-row">
        <button class="timer-btn" id="timer-btn" onclick="toggleTimer()">Start</button>
        <button class="timer-btn" onclick="resetTimer()">Reset</button>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="nextScreen(2)">
        Done — or close enough
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- SCREEN 3: NOTICE -->
  <div class="screen" id="s3">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:50%"></div></div>
      <div class="progress-row">
        <span class="progress-label">A step forward</span>
        <span class="back-link" onclick="prevScreen(3)">← Back</span>
      </div>
    </div>
    <h2>What moved <em>forward?</em></h2>
    <p class="subheading">Even a small step counts.</p>
    <label class="field-label" for="win">What moved</label>
    <textarea id="win" rows="3" placeholder="e.g. Proposal sent — first draft out the door"></textarea>
    <div class="btn-row">
      <button class="btn-primary" onclick="nextScreen(3)">
        Continue
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="btn-ghost" onclick="nextScreen(3)">Skip</button>
    </div>
  </div>

  <!-- SCREEN 4: TOMORROW -->
  <div class="screen" id="s4">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:66.66%"></div></div>
      <div class="progress-row">
        <span class="progress-label">Nice</span>
        <span class="back-link" onclick="prevScreen(4)">← Back</span>
      </div>
    </div>
    <div class="win-card">
      <div class="win-icon-row">
        <div class="win-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
            <path d="M5 12.5L10 17.5L19 7" stroke="#5B8C7A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="win-headline">That's a Quiet Win.</div>
      </div>
      <p class="win-body">You moved something forward today. That's how meaningful days begin — one clear move at a time.</p>
    </div>
    <label class="field-label" for="tomorrow">Tomorrow's move</label>
    <p class="subheading" style="margin-top:-.6rem;">What would make tomorrow feel lighter?</p>
    <textarea id="tomorrow" rows="3" placeholder="e.g. Get sunlight within 30 minutes of waking"></textarea>
    <div class="btn-row">
      <button class="btn-primary" onclick="nextScreen(4)">
        Continue
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="btn-ghost" onclick="nextScreen(4)">Skip</button>
    </div>
  </div>

  <!-- SCREEN 5: SIGNUP — one click -->
  <div class="screen" id="s5">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:83.33%"></div></div>
      <div class="progress-row">
        <span class="progress-label">Optional</span>
        <span class="back-link" onclick="prevScreen(5)">← Back</span>
      </div>
    </div>
    <h2>Keep the momentum <em>going.</em></h2>
    <p class="subheading">Weekly letters for clearer days and meaningful progress. Quiet, practical emails accompanying you through the week.</p>

    <div style="display:flex;gap:.55rem;margin-bottom:.5rem;">
      <input type="email" id="s5-email" class="field-email" placeholder="your@email.com" autocomplete="email" style="margin-bottom:0;flex:1;min-width:0;">
      <button class="btn-primary" onclick="subscribeAndContinue()" style="flex-shrink:0;white-space:nowrap;padding:.85rem 1.3rem;border-radius:10px;">
        Stay in touch
      </button>
    </div>

    <span class="field-error" id="s5-error"></span>

    <p style="font-size:.64rem;color:var(--ink3);line-height:1.55;margin-bottom:1.2rem;">
      By joining, you agree to occasional Velani emails.
      <a href="/privacy" target="_blank" style="color:var(--sage);text-decoration:none;">Privacy policy</a>.
    </p>

    <div class="btn-row" style="margin-top:.5rem;">
      <button class="btn-ghost" onclick="nextScreen(5)">Skip</button>
    </div>

    <span class="field-message" id="s5-message"></span>
  </div>

  <!-- SCREEN 6: REWARD -->
  <div class="screen" id="s6">
    <div class="progress-wrap">
      <div class="progress-track"><div class="progress-fill" style="width:100%"></div></div>
      <div class="progress-row">
        <span class="progress-label">You're ready</span>
        <span class="back-link" onclick="prevScreen(6)">← Back</span>
      </div>
    </div>
    <div class="success-card">
      <div class="success-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M5 12.5L10 17.5L19 7" stroke="#5B8C7A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="success-headline">Velani Lite is ready.</div>
      <p class="success-body">Free forever. No setup required.</p>
    </div>
    <div class="btn-row">
      <a class="btn-primary" href="https://velani.notion.site/velanilite" target="_blank" rel="noopener">
        Open Velani Lite in Notion
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <p class="format-links">
      <a href="https://drive.google.com/drive/folders/1MDvYyN_4fQOKDjnXI8wpwUluicc8MwjS?usp=drive_link" target="_blank" rel="noopener">Google Docs</a>
      ·
      <a href="https://drive.google.com/drive/folders/1nQEnpV6xb3mFndp9OzwliQEyW-8mPkN2?usp=drive_link" target="_blank" rel="noopener">PDF</a>
    </p>
    <p class="closing-line">One clear move at a time.</p>
  </div>

</main>

<script>
let timerInterval = null;
let secondsLeft = 120;
let timerRunning = false;

function showScreen(n) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('s' + n).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
function nextScreen(n) { showScreen(n + 1); }
function prevScreen(n) { showScreen(n - 1); }

function pad(n) { return n < 10 ? '0' + n : n; }
function updateDisplay() {
  const m = Math.floor(secondsLeft / 60);
  const s = secondsLeft % 60;
  document.getElementById('timer-display').textContent = m + ':' + pad(s);
}
function toggleTimer() {
  if (timerRunning) {
    clearInterval(timerInterval);
    timerRunning = false;
    document.getElementById('timer-btn').textContent = 'Resume';
    document.getElementById('timer-btn').classList.remove('running');
    document.getElementById('timer-sub').textContent = 'Paused — press resume when ready';
  } else {
    if (secondsLeft <= 0) return;
    timerRunning = true;
    document.getElementById('timer-btn').textContent = 'Pause';
    document.getElementById('timer-btn').classList.add('running');
    document.getElementById('timer-sub').textContent = 'Focus. Come back when done.';
    timerInterval = setInterval(() => {
      secondsLeft--;
      updateDisplay();
      if (secondsLeft <= 0) {
        clearInterval(timerInterval);
        timerRunning = false;
        document.getElementById('timer-display').textContent = 'Done';
        document.getElementById('timer-display').classList.add('done');
        document.getElementById('timer-sub').textContent = 'Nice. Whenever you\'re ready.';
        document.getElementById('timer-btn').textContent = 'Start';
        document.getElementById('timer-btn').classList.remove('running');
      }
    }, 1000);
  }
}
function resetTimer() {
  clearInterval(timerInterval);
  timerRunning = false;
  secondsLeft = 120;
  document.getElementById('timer-display').classList.remove('done');
  updateDisplay();
  document.getElementById('timer-sub').textContent = 'Press start — then focus';
  document.getElementById('timer-btn').textContent = 'Start';
  document.getElementById('timer-btn').classList.remove('running');
}

function subscribeAndContinue() {
  const email   = document.getElementById('s5-email').value.trim();
  const errorEl = document.getElementById('s5-error');
  const msgEl   = document.getElementById('s5-message');
  errorEl.textContent = '';
  msgEl.textContent   = '';
  if (!email || !email.includes('@')) {
    errorEl.textContent = 'Please enter a valid email.';
    document.getElementById('s5-email').style.borderColor = '#B86A43';
    return;
  }
  document.getElementById('s5-email').style.borderColor = 'rgba(26,29,46,.14)';
  msgEl.textContent = 'Sending...';
  msgEl.style.color = 'var(--ink3)';
  fetch('https://velani-subscribe.velani-app.workers.dev/', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email })
  })
  .then(() => done())
  .catch(() => done());
  function done() {
    msgEl.textContent = '✓ Check your inbox to confirm!';
    msgEl.style.color = 'var(--sage)';
    setTimeout(() => { nextScreen(5); }, 1800);
  }
}

updateDisplay();
</script>

</Base>