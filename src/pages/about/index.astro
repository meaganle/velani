---
import Base from '../../layouts/Base.astro';

const domains = [
  { glyph: '◆', name: 'Material',   desc: 'The financial stability and resources that create breathing room. Not the whole picture — but a necessary foundation beneath everything else.' },
  { glyph: '○', name: 'Inner',      desc: 'Your emotional life. Your sense of self. The quiet relationship you have with your own thoughts and feelings. This is often the first thing that gets neglected.' },
  { glyph: '△', name: 'Liveliness', desc: 'Energy, movement, creativity, rest. The parts of life that make you feel alive — not just functional.' },
  { glyph: '◇', name: 'Connection', desc: 'The relationships and moments of belonging that remind you why any of this matters. Tended with care, not just maintained.' },
];

const principles = [
  { label: 'You are not the problem', body: 'Modern women are not overwhelmed because they are disorganized. They are overwhelmed because they are carrying more than any one person was designed to carry.' },
  { label: 'Carrying less is not doing less', body: 'It\'s being more intentional about what actually deserves your energy. One clear thing, moved forward, creates more relief than ten things half-done.' },
  { label: 'Small practices change everything', body: 'Not dramatic overhauls. Not another system to manage. Just a few quiet daily habits that help you feel less scattered and more like yourself.' },
  { label: 'You deserve to be on your own list', body: 'The goal isn\'t optimization. It\'s making room — for rest, for possibility, for the parts of you that got buried beneath responsibility.' },
];

const faqs = [
  { q: 'Is Velani a productivity app?',    a: 'No. Most productivity systems ask you to do more. Velani exists to help you carry less — to make space for what actually matters to you, including yourself.' },
  { q: 'Who is Velani for?',               a: 'Women who are carrying a lot. Parents, professionals, caregivers, creators. Women who spend their lives making room for everyone else and have very little left for themselves.' },
  { q: 'What does Velani actually do?',    a: 'It helps you decide what matters today, notice what moved forward, and gently reset for tomorrow. No scheduling. No perfect routine required. Just one clear move at a time.' },
  { q: 'Is this therapy or self-help?',    a: 'Neither. Velani is a practical daily structure — not a substitute for professional support. Think of it as a calm companion for ordinary days.' },
  { q: 'Is Velani free?',                  a: 'Yes. Velani Lite is completely free and available in multiple formats — Notion, PDF, and Google Docs.' },
  { q: 'How long does it take?',           a: 'About 2–10 minutes a day. One question in the morning, one reflection at night. The weekly reset takes about 20 minutes on Sunday.' },
  { q: 'What if I miss a day?',            a: 'Nothing breaks. Velani isn\'t a streak system. Life gets in the way — that\'s exactly what it\'s designed for. You pick it back up when you\'re ready.' },
  { q: 'Do I need Notion?',                a: 'No. The PDF and Google Doc versions work just as well. Notion gives the most flexibility, but any format is fine.' },
];
---
<Base
  title="About Velani"
  description="You spent years making room for everyone else. Velani helps you make room for yourself again."
  currentPath="/about"
>
<style>
  main { flex: 1; }

  .v-label {
    font-size: .6rem; letter-spacing: .2em;
    text-transform: uppercase; color: var(--terra);
    font-weight: 500; margin-bottom: 1rem;
  }

  /* Intro two-col */
  .intro-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: start;
  }

  .prose p {
    font-size: .95rem; color: var(--ink2);
    line-height: 1.9; margin-bottom: 1.1rem;
  }
  .prose p:last-child { margin-bottom: 0; }
  .prose em { font-style: italic; color: var(--sage); }
  .prose strong { color: var(--ink); font-weight: 500; }

  .pull {
    font-family: var(--display);
    font-size: 1rem; font-weight: 300;
    font-style: italic; color: var(--ink);
    border-left: 2px solid var(--sage);
    padding: .85rem 0 .85rem 1.4rem;
    margin: 1.8rem 0; line-height: 1.75;
  }

  /* Founder */
  .founder-strip {
    display: flex; align-items: center; gap: 1rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 11px; padding: 1.1rem 1.3rem; margin-bottom: 1.3rem;
  }
  .founder-photo {
    width: 52px; height: 52px; border-radius: 50%;
    object-fit: cover; object-position: center top;
    border: 1.5px solid var(--border2); flex-shrink: 0;
  }
  .founder-fallback {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--sage-gl); border: 1.5px solid rgba(91,140,122,.25);
    display: none; align-items: center; justify-content: center;
    font-family: var(--display); font-size: 1rem;
    color: var(--sage); font-style: italic; flex-shrink: 0;
  }
  .founder-name { font-family: var(--display); font-size: .9rem; font-weight: 400; color: var(--ink); margin-bottom: .1rem; }
  .founder-role { font-size: .74rem; color: var(--ink3); line-height: 1.5; }

  /* Is/Isn't */
  .what-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .what-row { display: flex; gap: 1rem; padding: .85rem 1.3rem; border-bottom: 1px solid var(--border); align-items: flex-start; }
  .what-row:last-child { border-bottom: none; }
  .what-badge { font-size: .58rem; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; min-width: 38px; flex-shrink: 0; padding-top: .2em; }
  .what-badge.yes { color: var(--sage); }
  .what-badge.no  { color: var(--ink3); }
  .what-value { font-size: .84rem; color: var(--ink2); line-height: 1.65; }

  /* Domains + Principles */
  .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .domains { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
  .domain-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem 1.3rem; }
  .domain-head { display: flex; align-items: center; gap: .5rem; margin-bottom: .5rem; }
  .domain-glyph { font-size: .9rem; color: var(--sage); }
  .domain-name { font-family: var(--display); font-size: .88rem; font-weight: 400; color: var(--ink); }
  .domain-desc { font-size: .78rem; color: var(--ink3); line-height: 1.7; }

  .principles { display: flex; flex-direction: column; }
  .principle { padding: 1.1rem 0; border-bottom: 1px solid var(--border); }
  .principle:last-child { border-bottom: none; }
  .principle-label { font-family: var(--display); font-size: .9rem; font-weight: 400; color: var(--ink); margin-bottom: .35rem; line-height: 1.3; }
  .principle-body  { font-size: .82rem; color: var(--ink3); line-height: 1.8; }

  /* FAQ */
  .faq-list { max-width: 680px; }
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-btn {
    width: 100%; display: flex; align-items: center;
    justify-content: space-between; gap: 1rem;
    padding: .95rem 0; background: none; border: none;
    cursor: pointer; text-align: left;
    font-family: var(--display); font-size: .9rem;
    font-weight: 400; color: var(--ink); line-height: 1.35;
    transition: color .15s;
  }
  .faq-btn:hover { color: var(--sage); }
  .faq-chevron { flex-shrink: 0; color: var(--ink3); transition: transform .2s; font-size: .62rem; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); }
  .faq-body {
    font-size: .83rem; color: var(--ink2); line-height: 1.8;
    max-height: 0; overflow: hidden;
    transition: max-height .25s ease, padding .25s ease;
  }
  .faq-item.open .faq-body { max-height: 220px; padding-bottom: 1rem; }

  /* CTA */
  .cta-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 2.5rem 2.8rem; max-width: 560px; margin-top: 3rem;
  }
  .cta-box-text {
    font-family: var(--display); font-size: 1.05rem;
    font-style: italic; font-weight: 300; color: var(--ink2);
    line-height: 1.8; margin-bottom: 1.5rem;
  }
  .cta-box-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .intro-grid { grid-template-columns: 1fr; gap: 2rem; }
    .content-grid { grid-template-columns: 1fr; gap: 2rem; }
    .domains { grid-template-columns: 1fr; }
    .cta-box { padding: 2rem; }
  }
</style>

<main>
<div class="page-wrap">

  <div class="page-hero">
    <div class="eyebrow">About Velani</div>
    <h1 class="page-title">You spent years making room<br>for everyone else.<br><em>Velani helps you make room<br>for yourself again.</em></h1>
  </div>

  <!-- Why it exists + Who built it -->
  <div class="intro-grid">
    <div>
      <div class="v-label">Why Velani exists</div>
      <div class="prose">
        <p>Modern women are not overwhelmed because they are disorganized.</p>
        <p>They are overwhelmed because they are carrying more responsibilities, decisions, expectations, and invisible load than ever before.</p>
        <p>Work. Family. Children. Partners. Parents. Household. Health. Finances. Emotional support. Future planning. The mental load of remembering everything for everyone.</p>
        <div class="pull">
          Over time, responsibility accumulates. Life becomes maintenance. And there is less and less room left for you.
        </div>
        <p>Most systems ask you to do more. <em>Velani helps you carry less.</em></p>
        <p>Not through complicated routines. Not through perfect discipline. Through small, practical daily habits that help you feel clearer, lighter, and more like yourself again.</p>
      </div>
    </div>
    <div>
      <div class="v-label">Who built it</div>
      <div class="founder-strip">
        <img src="/images/meagan.jpg" alt="Meagan Le, founder of Velani" class="founder-photo"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
        <div class="founder-fallback">M</div>
        <div>
          <div class="founder-name">Meagan Le</div>
          <div class="founder-role">Founder of Velani · Mom · Systems thinker</div>
        </div>
      </div>
      <div class="prose">
        <p>I built Velani because I needed it myself.</p>
        <p>I was a senior executive, a new mother, building a business, managing a household, supporting everyone around me — and quietly disappearing in the process. I was capable. I was responsible. I was exhausted.</p>
        <p>I tried every productivity system. None of them addressed what was actually happening. The problem wasn't my discipline. It was the weight I was carrying.</p>
        <p>When I built something simpler — just one clear question each morning, a quiet win each night — things started to shift. Not dramatically. Quietly. <em>That's what Velani is.</em></p>
      </div>
    </div>
  </div>

  <div class="v-divider"></div>

  <!-- What it is/isn't -->
  <div class="v-label">What Velani is</div>
  <div class="what-card" style="max-width:680px;">
    <div class="what-row"><span class="what-badge yes">Is</span><span class="what-value">A practical daily structure that helps you carry less and feel more like yourself</span></div>
    <div class="what-row"><span class="what-badge yes">Is</span><span class="what-value">Built for women who spend their lives making room for everyone else</span></div>
    <div class="what-row"><span class="what-badge yes">Is</span><span class="what-value">Free to start — no setup, no account, no commitment required</span></div>
    <div class="what-row"><span class="what-badge no">Not</span><span class="what-value">A productivity app, self-help system, or therapy</span></div>
    <div class="what-row"><span class="what-badge no">Not</span><span class="what-value">Another thing to manage or optimize</span></div>
    <div class="what-row"><span class="what-badge no">Not</span><span class="what-value">Built to make you do more — built to help you feel like yourself again</span></div>
  </div>

  <div class="v-divider"></div>

  <!-- Domains + Principles -->
  <div class="content-grid">
    <div>
      <div class="v-label">Four areas of a full life</div>
      <div class="domains">
        {domains.map(d => (
          <div class="domain-card">
            <div class="domain-head">
              <span class="domain-glyph">{d.glyph}</span>
              <span class="domain-name">{d.name}</span>
            </div>
            <p class="domain-desc">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
    <div>
      <div class="v-label">How we think about it</div>
      <div class="principles">
        {principles.map(p => (
          <div class="principle">
            <div class="principle-label">{p.label}</div>
            <p class="principle-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="v-divider"></div>

  <!-- FAQ -->
  <div class="v-label">Common questions</div>
  <div class="faq-list" id="faq-list">
    {faqs.map((faq, i) => (
      <div class="faq-item" id={`faq-${i}`}>
        <button class="faq-btn" onclick={`window.toggleFaq(${i})`}>
          <span>{faq.q}</span>
          <span class="faq-chevron">▾</span>
        </button>
        <div class="faq-body">{faq.a}</div>
      </div>
    ))}
  </div>

  <!-- CTA -->
  <div class="cta-box">
    <p class="cta-box-text">
      The easiest way to understand Velani<br>is to try it — it takes about two minutes.
    </p>
    <div class="cta-box-actions">
      <a href="/start" class="btn-dark">Start here</a>
      <a href="/letters" class="btn-link">Read the letters</a>
    </div>
  </div>

</div>
</main>

<script>
  window.toggleFaq = function(i) {
    const item = document.getElementById(`faq-${i}`);
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  };
</script>

</Base>
