---
import Base from '../layouts/Base.astro';
---
<Base
  title="Velani — Make room for yourself again."
  description="You spent years making room for everyone else. Velani helps you make room for yourself again. A simple daily practice for women carrying too much."
  currentPath="/"
>
<style>
  main { flex: 1; }

  /* ── Section base ── */
  .section {
    padding: 7rem 3rem;
    position: relative; z-index: 1;
  }
  .section.surface {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .section.ink-bg {
    background: var(--ink);
    border-top: none; border-bottom: none;
  }

  /* ── Hero ── */
  .hero {
    padding: 5rem 3rem 4.5rem;
    max-width: 860px;
    margin: 0 auto;
    animation: rise .9s cubic-bezier(.22,1,.36,1) forwards;
    position: relative; z-index: 1;
  }
  .hero-eyebrow {
    font-size: .6rem; letter-spacing: .22em;
    text-transform: uppercase; color: var(--sage);
    font-weight: 500; margin-bottom: 1.4rem;
    display: flex; align-items: center; gap: .75rem;
  }
  .hero-eyebrow::before {
    content: ''; display: block;
    width: 24px; height: 1.5px; background: var(--sage);
    flex-shrink: 0;
  }
  .hero-headline {
    font-family: var(--display);
    font-size: clamp(2.6rem, 5.5vw, 4rem);
    font-weight: 300; line-height: 1.08;
    letter-spacing: -.025em; color: var(--ink);
    margin-bottom: 2.2rem;
  }
  .hero-headline em { font-style: italic; color: var(--sage); }

  /* The list — short breath, one per line */
  .hero-list {
    list-style: none;
    margin-bottom: 2.5rem;
    display: flex; flex-direction: column; gap: 0;
    padding-left: .15rem;
    border-left: 1.5px solid var(--border2);
    padding-left: 1.4rem;
    max-width: 320px;
  }
  .hero-list li {
    font-family: var(--display);
    font-size: 1rem; font-weight: 300;
    color: var(--ink3); line-height: 1.75;
    font-style: italic;
  }

  .hero-close {
    font-size: 1.05rem; color: var(--ink2);
    line-height: 1.85; margin-bottom: 2.5rem;
    max-width: 500px;
  }
  .hero-close strong {
    color: var(--ink); font-weight: 500;
    font-family: var(--display); font-style: italic;
  }

  .hero-cta { display: flex; align-items: center; gap: 1.4rem; flex-wrap: wrap; }
  .hero-sub-text {
    font-size: .76rem; color: var(--ink3);
    font-style: italic; font-family: var(--display);
  }

  /* ── Section 2 ── */
  .s2-inner { max-width: 700px; margin: 0 auto; }
  .s2-headline {
    font-family: var(--display);
    font-size: clamp(1.9rem, 3.5vw, 2.7rem);
    font-weight: 300; line-height: 1.12;
    color: var(--ink); margin-bottom: 1.8rem;
    letter-spacing: -.018em;
  }
  .s2-headline em { font-style: italic; color: var(--ink2); }
  .s2-body {
    font-size: .98rem; color: var(--ink2);
    line-height: 1.9; margin-bottom: 2rem;
    max-width: 540px;
  }
  .s2-list {
    list-style: none;
    margin-bottom: 2rem;
    display: flex; flex-direction: column; gap: .3rem;
    max-width: 380px;
  }
  .s2-list li {
    display: flex; align-items: baseline; gap: .8rem;
    font-size: .93rem; color: var(--ink2); line-height: 1.65;
  }
  .s2-list li::before {
    content: '·'; color: var(--ink3);
    flex-shrink: 0; font-size: 1.2rem; line-height: 1;
  }
  .s2-answer {
    font-family: var(--display);
    font-size: 1.08rem; font-weight: 300;
    font-style: italic; color: var(--ink);
    margin-top: 2.2rem; line-height: 1.7;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .s2-answer strong { font-style: normal; font-weight: 400; color: var(--sage); }

  /* ── Bridge quote section ── */
  .bridge {
    padding: 6rem 3rem;
    position: relative; z-index: 1;
    text-align: center;
  }
  .bridge-inner { max-width: 620px; margin: 0 auto; }
  .bridge-mark {
    display: flex; align-items: center; justify-content: center;
    gap: .6rem; margin-bottom: 2.8rem;
  }
  .bridge-mark span {
    display: block; height: 1px; width: 36px; background: var(--sage);
    opacity: .5;
  }
  .bridge-mark svg { flex-shrink: 0; opacity: .5; }
  .bridge-q1 {
    font-family: var(--display);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 300; color: var(--ink3);
    line-height: 1.65; letter-spacing: -.01em;
    margin-bottom: 1.2rem;
  }
  .bridge-q2 {
    font-family: var(--display);
    font-size: clamp(1.45rem, 3vw, 2rem);
    font-weight: 300; color: var(--ink);
    line-height: 1.35; letter-spacing: -.02em;
    margin-bottom: 2.8rem;
  }
  .bridge-q2 em { font-style: italic; color: var(--sage); }

  /* ── Section 3 ── */
  .s3-inner {
    max-width: 960px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  .s3-headline {
    font-family: var(--display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300; line-height: 1.12;
    color: var(--ink); margin-bottom: 1rem;
    letter-spacing: -.018em;
  }
  .s3-headline em { font-style: italic; color: var(--sage); }
  .s3-body { font-size: .93rem; color: var(--ink2); line-height: 1.9; margin-bottom: 2rem; }
  .s3-checks { display: flex; flex-direction: column; gap: .55rem; margin-bottom: 2.5rem; }
  .s3-check {
    display: flex; align-items: flex-start; gap: .75rem;
    font-size: .88rem; color: var(--ink2); line-height: 1.65;
  }
  .check-mark {
    color: var(--sage); font-size: .75rem;
    flex-shrink: 0; margin-top: .28em; font-weight: 600;
  }

  /* Feeling card — parallel columns */
  .feeling-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    box-shadow: 0 2px 24px rgba(26,29,46,.05);
  }
  .feeling-half { padding: 2.2rem 2rem; }
  .feeling-half.before { border-right: 1px solid var(--border); }
  .feeling-label {
    font-size: .58rem; letter-spacing: .2em;
    text-transform: uppercase; font-weight: 600;
    margin-bottom: 1.2rem;
  }
  .feeling-label.before { color: var(--ink3); }
  .feeling-label.after  { color: var(--sage); }
  .feeling-items { display: flex; flex-direction: column; gap: .5rem; }
  .feeling-item {
    font-size: .83rem; line-height: 1.5;
    display: flex; align-items: baseline; gap: .55rem;
  }
  .feeling-item.before { color: var(--ink3); }
  .feeling-item.after  { color: var(--ink2); }
  .fi-marker { flex-shrink: 0; font-size: .65rem; line-height: 1; }
  .fi-marker.before { color: var(--border2); }
  .fi-marker.after  { color: var(--sage); }

  /* ── Section 4 dark promise ── */
  .s4-inner { max-width: 640px; margin: 0 auto; text-align: center; }
  .s4-headline {
    font-family: var(--display);
    font-size: clamp(1.9rem, 3.5vw, 2.7rem);
    font-weight: 300; line-height: 1.18;
    color: var(--bg); margin-bottom: 1.6rem;
    letter-spacing: -.018em;
  }
  .s4-headline em { font-style: italic; color: rgba(91,140,122,.85); }
  .s4-body {
    font-size: .95rem; color: rgba(247,246,243,.55);
    line-height: 1.9; margin-bottom: 3rem;
    max-width: 460px; margin-left: auto; margin-right: auto;
  }

  /* ── Section 5 signup ── */
  .s5-inner { max-width: 500px; margin: 0 auto; }
  .s5-eyebrow {
    font-size: .58rem; letter-spacing: .22em;
    text-transform: uppercase; color: var(--terra);
    font-weight: 600; margin-bottom: 1rem;
  }
  .s5-headline {
    font-family: var(--display);
    font-size: clamp(1.7rem, 3vw, 2.1rem);
    font-weight: 300; line-height: 1.18;
    color: var(--ink); margin-bottom: .8rem;
    letter-spacing: -.015em;
  }
  .s5-headline em { font-style: italic; color: var(--sage); }
  .s5-body { font-size: .9rem; color: var(--ink2); line-height: 1.85; margin-bottom: 2.2rem; }

  .s5-form { max-width: 420px; }
  .s5-row { display: flex; gap: .55rem; margin-bottom: .5rem; }
  .s5-email {
    flex: 1; min-width: 0; background: var(--bg);
    border: 1.5px solid var(--border2); border-radius: 10px;
    padding: .85rem 1rem; font-family: var(--body);
    font-size: .88rem; color: var(--ink); outline: none;
    transition: border-color .2s;
  }
  .s5-email:focus { border-color: var(--sage); }
  .s5-email::placeholder { color: var(--ink3); }
  .s5-btn {
    background: var(--ink); color: var(--bg);
    font-family: var(--body); font-size: .72rem; font-weight: 500;
    letter-spacing: .07em; text-transform: uppercase;
    padding: .85rem 1.4rem; border-radius: 10px; border: none;
    cursor: pointer; white-space: nowrap; flex-shrink: 0;
    transition: background .2s, transform .15s;
  }
  .s5-btn:hover { background: var(--sage2); transform: translateY(-1px); }
  .s5-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .s5-error { display: block; font-size: .7rem; color: var(--terra); min-height: .85rem; margin-bottom: .3rem; }
  .s5-consent { font-size: .63rem; color: var(--ink3); line-height: 1.6; }
  .s5-consent a { color: var(--sage); text-decoration: none; }

  /* Success */
  .s5-success { display: none; }
  .s5-success.visible { display: block; }
  .success-mark {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--sage-gl); border: 1.5px solid rgba(91,140,122,.25);
    display: flex; align-items: center; justify-content: center; margin-bottom: 1.2rem;
  }
  .success-title { font-family: var(--display); font-size: 1.2rem; font-weight: 300; color: var(--ink); margin-bottom: .4rem; }
  .success-title em { font-style: italic; color: var(--sage); }
  .success-sub { font-size: .83rem; color: var(--ink3); line-height: 1.75; }

  @media (max-width: 900px) {
    .hero { padding: 4rem 1.5rem 3.5rem; }
    .section { padding: 5rem 1.5rem; }
    .bridge { padding: 4.5rem 1.5rem; }
    .s3-inner { grid-template-columns: 1fr; gap: 3rem; }
    .feeling-card { grid-template-columns: 1fr; }
    .feeling-half.before { border-right: none; border-bottom: 1px solid var(--border); }
  }
  @media (max-width: 640px) {
    .hero-cta { flex-direction: column; align-items: flex-start; gap: .8rem; }
    .s5-row { flex-direction: column; }
    .s5-btn { width: 100%; padding: .9rem; }
  }
</style>

<main>

  <!-- ── HERO ── -->
  <section class="hero">
    <p class="hero-eyebrow">A daily practice for women carrying too much</p>
    <h1 class="hero-headline">
      Somewhere along the way,<br>
      life became all <em>responsibility.</em>
    </h1>

    <ul class="hero-list">
      <li>Work.</li>
      <li>Family.</li>
      <li>Appointments.</li>
      <li>Planning.</li>
      <li>Remembering.</li>
      <li>Supporting.</li>
      <li>Managing.</li>
    </ul>

    <p class="hero-close">
      Everything started filtering through responsibility.<br>
      And there was less room left for <strong>you.</strong>
    </p>

    <div class="hero-cta">
      <a class="btn-dark" href="/start">Start here</a>
      <p class="hero-sub-text">Free. No account needed.</p>
    </div>
  </section>

  <!-- ── SECTION 2: Life wasn't supposed to feel like maintenance ── -->
  <section class="section surface">
    <div class="s2-inner">
      <h2 class="s2-headline">
        Life wasn't supposed to<br>feel like <em>maintenance.</em>
      </h2>
      <p class="s2-body">
        You weren't meant to spend every day managing logistics,
        carrying everyone else's needs, remembering everything,
        solving every problem, postponing yourself.
      </p>
      <ul class="s2-list">
        <li>Managing logistics</li>
        <li>Carrying everyone else's needs</li>
        <li>Remembering everything</li>
        <li>Solving every problem</li>
        <li>Postponing yourself</li>
      </ul>
      <p class="s2-answer">
        The answer isn't doing more.<br>
        The answer is <strong>carrying less.</strong>
      </p>
    </div>
  </section>

  <!-- ── BRIDGE QUOTE ── -->
  <section class="bridge">
    <div class="bridge-inner">
      <div class="bridge-mark">
        <span></span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="4" fill="#5B8C7A"/>
        </svg>
        <span></span>
      </div>
      <p class="bridge-q1">When life feels heavy, we often try to solve everything at once.</p>
      <p class="bridge-q2">What if making room for yourself<br>started with <em>one meaningful move?</em></p>
      <a class="btn-dark" href="/start">Start here</a>
    </div>
  </section>

  <!-- ── SECTION 3: Velani helps you carry less ── -->
  <section class="section surface">
    <div class="s3-inner">

      <div>
        <h2 class="s3-headline">
          Velani helps you<br><em>carry less.</em>
        </h2>
        <p class="s3-body">
          Not through complicated systems.<br>
          Not through perfect routines.<br>
          Just small practices that help you:
        </p>
        <div class="s3-checks">
          <div class="s3-check"><span class="check-mark">✓</span><span>Focus on what matters today</span></div>
          <div class="s3-check"><span class="check-mark">✓</span><span>Reduce the mental clutter</span></div>
          <div class="s3-check"><span class="check-mark">✓</span><span>Stop carrying everything at once</span></div>
          <div class="s3-check"><span class="check-mark">✓</span><span>Make room for yourself again</span></div>
          <div class="s3-check"><span class="check-mark">✓</span><span>Reconnect with the parts of you that got buried</span></div>
        </div>
        <a class="btn-dark" href="/start">Start here</a>
      </div>

      <!-- Before / After feeling card -->
      <div class="feeling-card">
        <div class="feeling-half before">
          <div class="feeling-label before">How it feels now</div>
          <div class="feeling-items">
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>Exhausted</span></div>
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>Scattered</span></div>
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>Carrying everything</span></div>
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>Always responsible</span></div>
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>No room for yourself</span></div>
            <div class="feeling-item before"><span class="fi-marker before">·</span><span>Life feels like maintenance</span></div>
          </div>
        </div>
        <div class="feeling-half">
          <div class="feeling-label after">How it can feel</div>
          <div class="feeling-items">
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>More space</span></div>
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>More capacity</span></div>
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>More presence</span></div>
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>More possibility</span></div>
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>Time for yourself again</span></div>
            <div class="feeling-item after"><span class="fi-marker after">✓</span><span>Feel like yourself again</span></div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── SECTION 4: Brand promise — dark ── -->
  <section class="section ink-bg">
    <div class="s4-inner">
      <h2 class="s4-headline">
        You spent years making<br>room for everyone else.<br>
        <em>Velani helps you make room<br>for yourself again.</em>
      </h2>
      <p class="s4-body">
        Not a productivity app. Not a self-help system.<br>
        A practical daily practice that helps you carry less,<br>
        feel more like yourself, and find space again.
      </p>
      <a class="btn-dark" href="/start" style="background:var(--bg);color:var(--ink);margin:0 auto;display:inline-flex;">
        Start here
      </a>
    </div>
  </section>

  <!-- ── SECTION 5: Signup ── -->
  <section class="section surface">
    <div class="s5-inner">
      <p class="s5-eyebrow">The Velani Letter</p>
      <h2 class="s5-headline">
        A quieter way <em>forward.</em>
      </h2>
      <p class="s5-body">
        Weekly letters for women who want to carry less and feel more like themselves.
        Thoughtful, practical, and calm — arriving every Sunday.
      </p>

      <div id="s5-form" class="s5-form">
        <div class="s5-row">
          <input type="email" id="s5-email" class="s5-email" placeholder="your@email.com" autocomplete="email">
          <button class="s5-btn" id="s5-btn" onclick="window.hpSignup()">Join Velani</button>
        </div>
        <span class="s5-error" id="s5-error"></span>
        <p class="s5-consent">
          By joining, you agree to receive occasional Velani emails. <a href="/privacy" target="_blank">Privacy policy</a>.
        </p>
      </div>

      <div class="s5-success" id="s5-success">
        <div class="success-mark">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M5 12.5L10 17.5L19 7" stroke="#5B8C7A" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="success-title">You're in.<br><em>Check your inbox.</em></div>
        <p class="success-sub">Confirm your email to complete signup.<br>Your first letter arrives Sunday.</p>
      </div>
    </div>
  </section>

</main>

<script>
  window.hpSignup = function() {
    const email   = document.getElementById('s5-email').value.trim();
    const errorEl = document.getElementById('s5-error');
    const btn     = document.getElementById('s5-btn');
    errorEl.textContent = '';
    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.';
      document.getElementById('s5-email').style.borderColor = '#B86A43';
      return;
    }
    document.getElementById('s5-email').style.borderColor = 'rgba(26,29,46,.14)';
    btn.disabled = true; btn.textContent = 'Sending…';
    fetch('https://velani-subscribe.velani-app.workers.dev/', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    }).then(() => ok()).catch(() => ok());
    function ok() {
      document.getElementById('s5-form').style.display = 'none';
      document.getElementById('s5-success').classList.add('visible');
    }
  };
</script>

</Base>
