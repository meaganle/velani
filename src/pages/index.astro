---
import Base from '../layouts/Base.astro';
---
<Base
  title="Velani — One clear move. One clearer day."
  description="Stop managing everything. Move one meaningful thing forward. No setup. Free forever."
  currentPath="/"
>
  <a slot="nav-right" class="nav-link" href="#how">How it works</a>

<style>
main { flex: 1; position: relative; z-index: 1; }

.hero {
  display: flex; flex-direction: column;
  align-items: center; text-align: center;
  padding: 6.5rem 2rem 5rem;
  max-width: 680px; margin: 0 auto;
  animation: rise .85s cubic-bezier(.22,1,.36,1) forwards;
}
@keyframes rise {
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: translateY(0); }
}
.hero-headline {
  font-family: var(--display);
  font-size: clamp(2.6rem, 5.5vw, 3.6rem);
  font-weight: 300;
  line-height: 1.07;
  letter-spacing: -.025em;
  color: var(--ink);
  margin-bottom: 1.3rem;
}
.hero-headline em { font-style: italic; color: var(--sage); }
.hero-sub {
  font-size: 1.05rem;
  color: var(--ink2);
  line-height: 1.72;
  margin-bottom: 2.8rem;
  max-width: 380px;
}
.cta-group {
  display: flex; flex-direction: column;
  align-items: center; gap: .85rem;
  margin-bottom: 1rem;
}
.btn-dark {
  display: inline-flex; align-items: center; gap: .55rem;
  background: var(--ink); color: var(--bg);
  font-family: var(--body);
  font-size: .82rem; font-weight: 500;
  letter-spacing: .07em; text-transform: uppercase;
  padding: .95rem 2.4rem;
  border-radius: 100px;
  text-decoration: none; border: none; cursor: pointer;
  transition: background .2s, transform .15s;
}
.btn-dark:hover { background: var(--sage2); transform: translateY(-1px); }
.btn-dark svg { transition: transform .2s; }
.btn-dark:hover svg { transform: translateX(3px); }
.btn-outline {
  display: inline-flex; align-items: center; gap: .4rem;
  background: transparent; color: var(--ink2);
  font-family: var(--body);
  font-size: .8rem; font-weight: 400;
  padding: .65rem 1.5rem;
  border-radius: 100px;
  border: 1.5px solid var(--border2);
  text-decoration: none; cursor: pointer;
  transition: border-color .2s, color .2s;
}
.btn-outline:hover { border-color: var(--ink2); color: var(--ink); }
.hero-footnote {
  font-size: .7rem; color: var(--ink3);
  letter-spacing: .04em;
}
.hero-footnote span { margin: 0 .35rem; opacity: .5; }

.preview-wrap {
  max-width: 680px; margin: 0 auto;
  padding: 0 2rem 5.5rem;
  animation: rise .85s .1s cubic-bezier(.22,1,.36,1) both;
}
.section-eyebrow {
  text-align: center;
  font-size: .6rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--ink3); font-weight: 500;
  margin-bottom: 1.6rem;
}
.preview-card {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 2rem 2.4rem;
  max-width: 420px;
  margin: 0 auto;
  box-shadow: 0 2px 20px rgba(26,29,46,.04);
}
.preview-date {
  font-size: .62rem; font-weight: 500;
  letter-spacing: .16em; text-transform: uppercase;
  color: var(--ink3); margin-bottom: 1.6rem;
}
.preview-row { margin-bottom: 1.3rem; }
.preview-row:last-child { margin-bottom: 0; }
.preview-row-label {
  font-size: .6rem; letter-spacing: .18em;
  text-transform: uppercase; color: var(--terra);
  font-weight: 500; margin-bottom: .5rem;
}
.preview-item {
  display: flex; align-items: center; gap: .7rem;
  font-size: .88rem; color: var(--ink2); line-height: 1.5;
}
.preview-dot {
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--sage-gl);
  border: 1.5px solid rgba(91,140,122,.28);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.preview-divider { height: 1px; background: var(--border); margin: 1.2rem 0; }

.pillars-wrap {
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 5rem 2rem;
}
.pillars-inner { max-width: 720px; margin: 0 auto; }
.pillars {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: 2.8rem;
}
.pillar { padding: 0 .5rem; }
.pillar-num {
  font-family: var(--display);
  font-size: 1.8rem; font-weight: 300;
  font-style: italic; color: var(--sage);
  margin-bottom: .5rem; line-height: 1;
}
.pillar-name { font-size: .88rem; font-weight: 500; color: var(--ink); margin-bottom: .4rem; }
.pillar-desc { font-size: .78rem; color: var(--ink3); line-height: 1.7; }

.quote-wrap {
  padding: 5rem 2rem;
  text-align: center;
  max-width: 520px; margin: 0 auto;
}
.quote-text {
  font-family: var(--display);
  font-size: 1.08rem; font-style: italic; font-weight: 300;
  color: var(--ink2); line-height: 1.85; margin-bottom: .9rem;
}
.quote-attr { font-size: .68rem; color: var(--ink3); letter-spacing: .1em; text-transform: uppercase; }

.signup-wrap {
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 5.5rem 2rem;
}
.signup-inner { max-width: 420px; margin: 0 auto; text-align: center; }
.signup-eyebrow {
  font-size: .6rem; letter-spacing: .22em;
  text-transform: uppercase; color: var(--terra);
  font-weight: 500; margin-bottom: 1rem;
}
.signup-headline {
  font-family: var(--display);
  font-size: 1.65rem; font-weight: 300;
  line-height: 1.18; color: var(--ink);
  margin-bottom: .8rem; letter-spacing: -.01em;
}
.signup-headline em { font-style: italic; color: var(--sage); }
.signup-subline { font-size: .88rem; color: var(--ink3); line-height: 1.72; margin-bottom: 1.8rem; }
.field-email {
  width: 100%; background: var(--bg);
  border: 1.5px solid var(--border2); border-radius: 10px;
  padding: .95rem 1.1rem; font-family: var(--body);
  font-size: .9rem; color: var(--ink);
  outline: none; transition: border-color .2s;
  margin-bottom: .6rem;
}
.field-email:focus { border-color: var(--sage); background: var(--surface); }
.field-email::placeholder { color: var(--ink3); }
.field-error { display: block; font-size: .7rem; color: var(--terra); min-height: 1.1rem; margin-bottom: .4rem; text-align: left; }
.consent-row { display: flex; align-items: flex-start; gap: .65rem; margin-bottom: .5rem; text-align: left; }
.consent-row input[type="checkbox"] { width: 15px; height: 15px; cursor: pointer; accent-color: var(--sage); flex-shrink: 0; margin-top: .2em; }
.consent-label { font-size: .7rem; color: var(--ink3); line-height: 1.6; cursor: pointer; }
.consent-label a { color: var(--sage); text-decoration: none; }
.field-footnote { font-size: .65rem; color: var(--ink3); letter-spacing: .02em; margin-bottom: 1.4rem; text-align: left; }
.field-message { display: block; font-size: .72rem; color: var(--sage); min-height: 1rem; margin-top: .7rem; text-align: center; }

@media (max-width: 640px) {
  .hero { padding: 4.5rem 1.5rem 4rem; }
  .preview-wrap { padding: 0 1.5rem 4rem; }
  .pillars { grid-template-columns: 1fr; gap: 0; margin-top: 2rem; }
  .pillar { padding: 1.4rem 0; border-bottom: 1px solid var(--border); }
  .pillar:last-child { border-bottom: none; }
  .quote-wrap { padding: 4rem 1.5rem; }
  .signup-wrap { padding: 4rem 1.5rem; }
}
</style>

<main>

  <section class="hero">
    <h1 class="hero-headline">
      One clear move.<br><em>One clearer day.</em>
    </h1>
    <p class="hero-sub">Stop managing everything. Move one meaningful thing forward.</p>
    <div class="cta-group">
      <a class="btn-dark" href="/start">
        Start your first move
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a class="btn-outline" href="#how">See how it works</a>
    </div>
    <p class="hero-footnote">No setup <span>·</span> Free forever <span>·</span> Takes about a minute</p>
  </section>

  <div class="preview-wrap" id="how">
    <p class="section-eyebrow">What Velani looks like</p>
    <div class="preview-card">
      <div class="preview-date">Today · Monday</div>
      <div class="preview-row">
        <div class="preview-row-label">One Move</div>
        <div class="preview-item">
          <div class="preview-dot">
            <svg width="9" height="9" viewBox="0 0 12 12" fill="none">
              <path d="M2 6.5L5 9.5L10 4" stroke="#5B8C7A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          Send the proposal that's been hanging
        </div>
      </div>
      <div class="preview-divider"></div>
      <div class="preview-row">
        <div class="preview-row-label">Quiet Win</div>
        <div class="preview-item">
          <div class="preview-dot">
            <svg width="9" height="9" viewBox="0 0 12 12" fill="none">
              <path d="M2 6.5L5 9.5L10 4" stroke="#5B8C7A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          Proposal sent — first draft out the door
        </div>
      </div>
      <div class="preview-divider"></div>
      <div class="preview-row">
        <div class="preview-row-label">Tomorrow's Move</div>
        <div class="preview-item">
          <div class="preview-dot" style="background:transparent; border-color: rgba(26,29,46,.14);">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="#6E7191" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          Get sunlight within 30 minutes of waking
        </div>
      </div>
    </div>
  </div>

  <div class="pillars-wrap">
    <div class="pillars-inner">
      <p class="section-eyebrow" style="text-align:center; color: var(--terra);">How it works</p>
      <div class="pillars">
        <div class="pillar">
          <div class="pillar-num">01</div>
          <div class="pillar-name">Choose one move</div>
          <p class="pillar-desc">Not a list. One clear thing that matters today.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">02</div>
          <div class="pillar-name">Move it forward</div>
          <p class="pillar-desc">Two minutes or two hours. Small progress counts.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">03</div>
          <div class="pillar-name">Log a Quiet Win</div>
          <p class="pillar-desc">Notice what moved. Set tomorrow's move. Done.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="quote-wrap">
    <p class="quote-text">"I stopped managing my productivity system and started moving things forward."</p>
    <div class="quote-attr">— Founding member</div>
  </div>

  <div class="signup-wrap">
    <div class="signup-inner">
      <p class="signup-eyebrow">Stay connected</p>
      <h2 class="signup-headline">A quieter way <em>forward</em></h2>
      <p class="signup-subline">Quiet, practical emails for clearer days.</p>
      <input type="email" id="hp-email" class="field-email" placeholder="your@email.com" autocomplete="email">
      <span class="field-error" id="hp-error"></span>
      <div class="consent-row">
        <input type="checkbox" id="hp-consent">
        <label class="consent-label" for="hp-consent">
          Send me Velani letters and updates. See our <a href="/privacy" target="_blank">privacy policy</a>.
        </label>
      </div>
      <p class="field-footnote">Quiet inbox. Unsubscribe anytime.</p>
      <button class="btn-dark" onclick="window.subscribeHomepage()">
        I'm in
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="field-message" id="hp-message"></span>
    </div>
  </div>

</main>

<script>
window.submitToKit = function(email) {
  return fetch('https://velani-subscribe.velani-app.workers.dev/', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email })
  });
};

window.subscribeHomepage = function() {
  const email   = document.getElementById('hp-email').value.trim();
  const consent = document.getElementById('hp-consent').checked;
  const errorEl = document.getElementById('hp-error');
  const msgEl   = document.getElementById('hp-message');
  errorEl.textContent = '';
  msgEl.textContent   = '';
  if (!email || !email.includes('@')) {
    errorEl.textContent = 'Please enter a valid email.';
    document.getElementById('hp-email').style.borderColor = '#B86A43';
    return;
  }
  if (!consent) {
    errorEl.textContent = 'Please check the box to continue.';
    return;
  }
  document.getElementById('hp-email').style.borderColor = 'rgba(26,29,46,.14)';
  msgEl.textContent = 'Sending...';
  msgEl.style.color = 'var(--ink3)';
  window.submitToKit(email)
    .then(res => res.json())
    .then(() => {
      msgEl.textContent = '✓ Check your inbox to confirm!';
      msgEl.style.color = 'var(--sage)';
      document.getElementById('hp-email').value = '';
      document.getElementById('hp-consent').checked = false;
    })
    .catch(() => {
      msgEl.textContent = '✓ Check your inbox to confirm!';
      msgEl.style.color = 'var(--sage)';
      document.getElementById('hp-email').value = '';
      document.getElementById('hp-consent').checked = false;
    });
};
</script>

</Base>