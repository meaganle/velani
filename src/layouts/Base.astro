---
// src/layouts/Base.astro
import '../styles/global.css';

const {
  title = 'Velani',
  description = 'A life well lived, daily.',
  ogImage = '/og-default.png',
  currentPath = ''
} = Astro.props;

const navLinks = [
  { href: '/letter',     label: 'Letter' },
  { href: '/library',    label: 'Library' },
  { href: '/philosophy', label: 'Philosophy' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Velani</title>
  <meta name="description" content={description}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} — Velani`}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={`https://velani.app${currentPath}`}>
  <meta property="og:type" content="website">

  <!-- Canonical -->
  <link rel="canonical" href={`https://velani.app${currentPath}`}>

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml">
</head>
<body>

<nav class="main-nav">
  <a class="nav-brand" href="/">
    <svg width="18" height="18" viewBox="0 0 80 80" fill="none">
      <circle cx="40" cy="40" r="33" stroke="#1A1D2E" stroke-width="2.2" fill="none" opacity=".16"/>
      <circle cx="40" cy="40" r="21" stroke="#1A1D2E" stroke-width="2.2" fill="none" opacity=".4"/>
      <circle cx="40" cy="40" r="6" fill="#5B8C7A"/>
    </svg>
    VELANI
  </a>
  {Astro.slots.has('nav-right') ? (
    <slot name="nav-right" />
  ) : (
    <div class="nav-links">
      {navLinks.map(link => (
        <a
          class={`nav-link${currentPath.startsWith(link.href) ? ' active' : ''}`}
          href={link.href}
        >{link.label}</a>
      ))}
    </div>
  )}
</nav>

<slot />

<footer>
  <div class="foot-brand">VELANI</div>
  <div class="foot-links">
    <a class="foot-link" href="mailto:hello@velani.app">hello@velani.app</a>
    <a class="foot-link" href="/privacy">Privacy</a>
  </div>
  <div class="foot-copy">© 2026 · A life well lived, daily.</div>
</footer>

</body>
</html>
